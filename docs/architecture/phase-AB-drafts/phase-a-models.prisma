// It is the identity+team FOUNDATION SLICE only — none of the other Phase-0
// models (Contact, Deal, Tour, …) are part of Phase A.
//
// Conventions (consistent with GOS-phase0-prisma-schema-draft.prisma):
//   * id = app-supplied UUID v7 (Prisma 5.22 has no uuid(7) default → the
//     backfill script supplies ids; new app writes must too).
//   * DateTime = @db.Timestamptz(6); money = BigInt minor units + currency.
//   * citext columns need the citext extension (see raw SQL below).
//   * Soft-delete-aware uniqueness = PARTIAL unique index via raw SQL (Prisma
//     cannot express it) — listed at the bottom. The `legacyAdminUserId`,
//     `recruitmentExternalId`, `Role.key`, `Permission.key` uniques ARE plain
//     Prisma @unique (nullable uniques are already unique-where-not-null).
// =============================================================================

// ----- ENUMS (new) -----------------------------------------------------------
enum UserStatus { invited active suspended }
enum PermissionScope { own team all } // seed own/all; `team` deferred
enum TeamMemberStatus { active on_leave inactive former }

// ----- IDENTITY & ACCESS (new) ----------------------------------------------

/// Login principal. username = primary login handle (from AdminUser.username);
/// email optional, NOT the login identity at this stage. legacyAdminUserId is a
/// migration-aid bridge to AdminUser (nullable, unique, removable post-cutover).
/// Bootstrap/setup is design-only (see reconciliation plan §2) — no code here.
model User {
  id                String     @id // app-supplied UUID v7
  username          String     @db.Citext
  email             String?    @db.Citext
  passwordHash      String? // scrypt "salt:key" carried verbatim from AdminUser
  displayName       String
  status            UserStatus @default(invited)
  lastLoginAt       DateTime?  @db.Timestamptz(6)
  legacyAdminUserId String?    @unique // bridge to AdminUser.id (migration aid)

  teamMemberId String?     @unique
  teamMember   TeamMember? @relation(fields: [teamMemberId], references: [id])

  userRoles UserRole[]

  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)
  deletedById String?

  /// PARTIAL-UNIQUE: (username) WHERE deleted_at IS NULL
  /// PARTIAL-UNIQUE: (email)    WHERE deleted_at IS NULL AND email IS NOT NULL
  @@index([status])
  @@index([teamMemberId])
}

/// Named bundle of permissions. Reference/config: archived, not soft-deleted.
model Role {
  id          String  @id
  key         String  @unique
  name        String
  description String?
  isSystem    Boolean @default(false)
  archived    Boolean @default(false)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

/// A single capability = resource + action + scope. Seeded reference set.
model Permission {
  id          String          @id
  key         String          @unique
  resource    String
  action      String
  scope       PermissionScope
  description String?

  rolePermissions RolePermission[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

/// RBAC join: User ↔ Role.
model UserRole {
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId      String
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedAt   DateTime @default(now()) @db.Timestamptz(6)
  grantedById String?

  @@id([userId, roleId])
  @@index([roleId])
}

/// RBAC join: Role ↔ Permission.
model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedAt    DateTime   @default(now()) @db.Timestamptz(6)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// ----- TEAM (new) ------------------------------------------------------------

/// Internal staff identity. GOS-owned source of truth (post-Phase-C). In
/// Phase A/B it is a READ MIRROR backfilled from PersonRef/PersonProfile;
/// PersonRef stays the writer for portal/learning until Phase C.
/// recruitmentExternalId = bridge to PersonRef.externalPersonId (unique).
/// Relations are trimmed to the Phase-A slice (no Note/Attachment/Assignment/
/// FormResponse — those models don't exist in the live schema yet).
model TeamMember {
  id                    String           @id // GOS-generated UUID v7
  firstName             String?
  lastName              String?
  displayName           String
  memberTypes           String[]         @default([]) // guide | office | manager | sales
  status                TeamMemberStatus @default(active)
  primaryEmail          String?          @db.Citext
  primaryPhoneE164      String?
  skills                String[]         @default([])
  startDate             DateTime?        @db.Timestamptz(6)
  endDate               DateTime?        @db.Timestamptz(6)
  defaultPayRateMinor   BigInt?
  currency              String           @default("ILS") @db.Char(3)
  recruitmentExternalId String?          @unique // bridge to PersonRef.externalPersonId

  user      User?
  profile   TeamMemberProfile?
  personRefs PersonRef[] // back-relation for the PersonRef.teamMemberId link

  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime? @db.Timestamptz(6)
  deletedById  String?
  anonymizedAt DateTime? @db.Timestamptz(6)

  @@index([status])
}

/// Operational / sensitive guide data (mirrors the live PersonProfile split).
/// 1:1 with TeamMember. bankDetails is sensitive PII.
model TeamMemberProfile {
  teamMemberId String     @id
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  imageUrl     String?
  description  String?
  notes        String?
  bankDetails  Json?

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
}

