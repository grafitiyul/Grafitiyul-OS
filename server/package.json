{
  "name": "grafitiyul-os-server",
  "version": "0.1.0",
  "private": true,
  "description": "Grafitiyul OS backend (Express + Prisma)",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
    "test": "node --test \"src/**/*.test.js\" \"scripts/**/*.test.js\"",
    "smoke:startup": "node scripts/startup-smoke.mjs",
    "validate:migrations": "node scripts/validate-migrations.mjs",
    "purge:whatsapp": "node scripts/purge-whatsapp-account.mjs",
    "start": "prisma migrate deploy && node src/index.js",
    "build": "prisma generate",
    "postinstall": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^5.22.0",
    "bidi-js": "^1.0.3",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pdf-lib": "^1.17.1",
    "prisma": "^5.22.0",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "pg-query-emscripten": "^5.1.0"
  }
}
