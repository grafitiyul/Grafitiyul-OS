# Server configuration
PORT=4000

# PostgreSQL connection string
# Railway will inject this automatically when you attach a Postgres plugin.
DATABASE_URL="postgresql://user:password@localhost:5432/grafitiyul_os?schema=public"

# ── Admin authentication ────────────────────────────────────────
#
# Admin credentials are stored in the AdminUser table (see Prisma
# schema). Until the first AdminUser row exists, the server runs in
# bootstrap mode: /admin is reachable, and POST /api/auth/setup
# accepts a one-time create-first-user request. Once the first
# active admin exists, /api/auth/setup is locked and admin routes
# require a session cookie.
#
# SESSION_SECRET is REQUIRED and must be at least 16 characters.
# Without it the auth endpoints return 500 "auth_misconfigured".
# Rotating it invalidates every existing admin session.
#
# (The old ADMIN_USERNAME / ADMIN_PASSWORD env vars are no longer
# read by the server — credentials live in the DB.)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-16-chars

# ── iCount payment links ("תשלום באייקאונט") ────────────────────
#
# Personal payment links are generated via paypage/generate_sale with
# legacy body auth (cid/user/pass) — the PROVEN shape that makes iCount
# prefill customer details. Without these vars the feature returns a
# clean "icount_not_configured" error (deploying without them is safe).
ICOUNT_CID=
ICOUNT_USER=
ICOUNT_PASS=
# The iCount paypage TEMPLATE the personal sale links are generated from
# (e.g. the VAT template id). Required for link generation.
ICOUNT_DEFAULT_PAYPAGE_ID=
# Optional overrides
# ICOUNT_API_BASE=https://api.icount.co.il/api/v3.php
# ICOUNT_MAX_PAYMENTS=10

# IPN (webhook) — optional but recommended. When BOTH ICOUNT_WEBHOOK_SECRET
# and PUBLIC_ORIGIN are set, generated links carry an ipn_url; the receiver
# ONLY logs raw payloads (no state changes in this slice).
ICOUNT_WEBHOOK_SECRET=

# This server's public URL (no trailing slash), e.g.
#   https://app.grafitiyul.co.il
# It is the SINGLE source for every customer-/user-facing absolute URL the
# server generates:
#   • permanent payment URLs      ${PUBLIC_ORIGIN}/pay/<token>
#   • iCount IPN webhook url       ${PUBLIC_ORIGIN}/api/webhooks/icount/<secret>
#   • Gmail OAuth callback         ${PUBLIC_ORIGIN}/api/email/connect/callback
#   • email open-tracking pixel    ${PUBLIC_ORIGIN}/api/track/email-open/<id>.gif
# Only stable tokens are stored in the DB, so moving to a custom domain updates
# every displayed/sent URL with NO migration. When unset, these fall back to the
# requesting host (fine locally; set it in production so links + the OAuth
# redirect are stable regardless of which host the request arrived on).
#
# IMPORTANT on cutover to a new domain:
#   1. Set this to the new origin (e.g. https://app.grafitiyul.co.il).
#   2. Add ${PUBLIC_ORIGIN}/api/email/connect/callback to the Google Cloud
#      OAuth client's Authorized redirect URIs — Gmail connect breaks otherwise.
#   3. Keep the OLD domain resolving (or 301 → new) during transition so payment
#      links, guide portal links, and tracking pixels ALREADY sent keep working.
PUBLIC_ORIGIN=

# ── Email / Gmail integration ───────────────────────────────────
#
# Google OAuth (Workspace "Internal" app) + Gmail API. Without all three the
# email module stays dormant (accounts can't connect; the UI shows which vars
# are missing). Scopes are read-only + send — GOS never mutates the mailbox.
#   GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET — from the Google Cloud OAuth client
#     (Web application). Its Authorized redirect URI must be
#     ${PUBLIC_ORIGIN}/api/email/connect/callback (see PUBLIC_ORIGIN note above).
#   EMAIL_TOKEN_KEY — 16+ random chars; AES-256-GCM key for OAuth tokens at
#     rest. Rotating it forces every connected mailbox to reconnect.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_TOKEN_KEY=

# ── Cloudflare R2 (private file storage) ────────────────────────
#
# Deal files, email attachments and WhatsApp media live in R2; downloads are
# short-lived presigned GETs, independent of PUBLIC_ORIGIN (they carry the R2
# endpoint, not this app's domain — the domain move does not affect them).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ── WhatsApp bridges (one Railway service per number) ───────────
#
# accountId → bridge base URL over Railway's PRIVATE network
# (comma-separated key=url pairs). The accountId keys must match each
# bridge's WHATSAPP_ACCOUNT_ID env var.
# Example:
#   WHATSAPP_BRIDGE_URLS=main=http://gos-whatsapp-main.railway.internal:3000,office=http://gos-whatsapp-office.railway.internal:3000
WHATSAPP_BRIDGE_URLS=
# Shared secret for GOS → bridge calls. Must equal BRIDGE_INTERNAL_SECRET
# on every bridge service.
WHATSAPP_BRIDGE_SECRET=
