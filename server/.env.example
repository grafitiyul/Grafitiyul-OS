# Server configuration
PORT=4000

# PostgreSQL connection string
# Railway will inject this automatically when you attach a Postgres plugin.
DATABASE_URL="postgresql://user:password@localhost:5432/grafitiyul_os?schema=public"

# ── Admin authentication ────────────────────────────────────────
#
# REQUIRED in production. Without these the /admin UI is unreachable
# (login returns 500 "auth_misconfigured"). The guide portal /p/:token
# and the public runtime continue to work without these set.
#
# SESSION_SECRET must be at least 16 characters. Use a long random
# string (e.g. `openssl rand -base64 48`). Rotating it invalidates
# every existing admin session.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
SESSION_SECRET=change-me-to-a-long-random-string-at-least-16-chars
