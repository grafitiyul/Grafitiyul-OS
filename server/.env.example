# Server configuration
PORT=4000

# PostgreSQL connection string
# Railway will inject this automatically when you attach a Postgres plugin.
DATABASE_URL="postgresql://user:password@localhost:5432/grafitiyul_os?schema=public"

# ── Admin authentication ────────────────────────────────────────
#
# Admin credentials are stored in the AdminUser table (see Prisma
# schema). Until the first AdminUser row exists, the server runs in
# bootstrap mode: /admin is reachable, and POST /api/auth/setup
# accepts a one-time create-first-user request. Once the first
# active admin exists, /api/auth/setup is locked and admin routes
# require a session cookie.
#
# SESSION_SECRET is REQUIRED and must be at least 16 characters.
# Without it the auth endpoints return 500 "auth_misconfigured".
# Rotating it invalidates every existing admin session.
#
# (The old ADMIN_USERNAME / ADMIN_PASSWORD env vars are no longer
# read by the server — credentials live in the DB.)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-16-chars

# ── iCount payment links ("תשלום באייקאונט") ────────────────────
#
# Personal payment links are generated via paypage/generate_sale with
# legacy body auth (cid/user/pass) — the PROVEN shape that makes iCount
# prefill customer details. Without these vars the feature returns a
# clean "icount_not_configured" error (deploying without them is safe).
ICOUNT_CID=
ICOUNT_USER=
ICOUNT_PASS=
# The iCount paypage TEMPLATE the personal sale links are generated from
# (e.g. the VAT template id). Required for link generation.
ICOUNT_DEFAULT_PAYPAGE_ID=
# Optional overrides
# ICOUNT_API_BASE=https://api.icount.co.il/api/v3.php
# ICOUNT_MAX_PAYMENTS=10

# IPN (webhook) — optional but recommended. When BOTH ICOUNT_WEBHOOK_SECRET
# and PUBLIC_ORIGIN are set, generated links carry an ipn_url; the receiver
# ONLY logs raw payloads (no state changes in this slice).
ICOUNT_WEBHOOK_SECRET=

# This server's public URL (no trailing slash), e.g.
# https://gos-api-production.up.railway.app — used to build the PERMANENT
# customer payment URLs (${PUBLIC_ORIGIN}/pay/<token>) and the iCount ipn_url.
# Only the token is stored in the DB, so changing this (e.g. moving to a
# custom domain) updates every displayed/sent URL with no migration. When
# unset, /pay URLs fall back to the requesting host.
PUBLIC_ORIGIN=
