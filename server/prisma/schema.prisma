// Grafitiyul OS - Prisma schema (V1: Learning / Procedures module)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Internal admin user. The whole point of this table is to take admin
// credentials OFF Railway env vars and INTO the DB so the user can
// manage them from inside the system.
//
// Bootstrap rule (enforced server-side, see auth.js):
//   * Zero ACTIVE admins → /admin is reachable, POST /api/auth/setup
//     creates the first user. No login required.
//   * One+ active admins → /admin requires a valid session, /setup is
//     locked out (403). The "first-user-wins" pattern.
//
// `passwordHash` is a scrypt KDF output ("<saltHex>:<derivedKeyHex>") —
// no plaintext, no need for an external bcrypt/argon2 dependency.
// `role` is reserved for future role-based access; today everyone is
// 'admin'. `isActive=false` is a soft-delete; the bootstrap count
// only considers active users so a deactivated admin doesn't
// re-open bootstrap mode.
model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         String    @default("admin")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Nested organisational folder for the item bank. Folders can contain items
// (content + question) and/or other folders — no depth cap at the data level.
// parentId=null means the folder sits at the root. sortOrder is scoped by
// parent, so reindexing only touches siblings in the same parent.
// ON DELETE SET NULL on the self-relation mirrors the behaviour on items:
// deleting a parent unparents its children rather than cascading.
model ItemBankFolder {
  id            String           @id @default(cuid())
  name          String
  parent        ItemBankFolder?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: SetNull)
  parentId      String?
  children      ItemBankFolder[] @relation("FolderChildren")
  sortOrder     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  contentItems  ContentItem[]
  questionItems QuestionItem[]
  // Reverse relation for FlowNode.kind='folderRef' — flow nodes that
  // include this folder by reference. SetNull on delete (mirrored on
  // FlowNode.bankFolder) so deleting a referenced bank folder
  // gracefully degrades the folderRef to an empty block instead of
  // orphaning rows.
  flowNodeRefs  FlowNode[]       @relation("FlowNodeBankFolderRef")

  @@index([parentId, sortOrder])
}

// Reusable content item in the bank.
// `title` holds HTML (single-line TipTap output) so dynamic-field chips can
// live in the title. Plain-text titles remain valid HTML, so no migration is
// required for the column itself — only the read sites adapt.
model ContentItem {
  id           String          @id @default(cuid())
  title        String
  body         String          @default("")
  internalNote String?
  sortOrder    Int             @default(0)
  folder       ItemBankFolder? @relation(fields: [folderId], references: [id])
  folderId     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  flowNodes    FlowNode[]

  @@index([folderId, sortOrder])
}

// Reusable question item in the bank. Unified model — a single question
// can present predefined choices, a free-text field, or both, with a
// single `requirement` field controlling when an answer is required.
//
//   options          — choice labels; empty = no choices
//   allowTextAnswer  — show the free-text field to the learner
//   requirement      — one of:
//     'optional' — the question can be skipped
//     'choice'   — learner must select a choice (text is optional)
//     'text'     — learner must fill the text (choice is optional)
//     'any'      — learner must fill at least one of choice / text
//     'both'     — learner must fill both choice and text
//   Only the values that make sense for the current shape are allowed at
//   the API / editor layer; see lib/questionRequirement.js.
//
// `answerType` is kept as a deprecated column for one release cycle so
// a rollback is safe. New behaviour reads the three fields above and
// ignores answerType. The column will be removed in a follow-up slice.
model QuestionItem {
  id              String          @id @default(cuid())
  title           String
  questionText    String          @default("")
  answerType      String // DEPRECATED — see block comment above
  options         String[]        @default([])
  allowTextAnswer Boolean         @default(false)
  requirement     String          @default("optional")
  internalNote    String?
  sortOrder       Int             @default(0)
  folder          ItemBankFolder? @relation(fields: [folderId], references: [id])
  folderId        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  flowNodes       FlowNode[]

  @@index([folderId, sortOrder])
}

// status: 'draft' | 'published'
// Assignment model: any of openToAll / team targets / person targets grants
// visibility to a learner (union). `mandatory` drives the ללמידה vs זמינים
// split in the learner portal — a non-mandatory visible flow sits in זמינים
// until the learner chooses to take it.
model Flow {
  id           String             @id @default(cuid())
  title        String
  description  String?
  status       String             @default("draft")
  sortOrder    Int                @default(0)
  openToAll    Boolean            @default(false)
  mandatory    Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  nodes        FlowNode[]
  attempts     Attempt[]
  targetTeams  FlowTargetTeam[]
  targetPeople FlowTargetPerson[]
}

// Recursive tree: a node is a content ref, question ref, group container,
// or a folderRef — a reference to a bank folder. The folderRef is
// authoring-time only; at attempt creation time the referenced folder
// is snapshotted into Attempt.expansion so in-flight attempts don't
// see structural changes the admin makes to the bank folder. Item
// CONTENT (titles, bodies, options) still resolves live by id, so
// typo fixes / wording changes propagate to in-flight attempts. Only
// the FOLDER STRUCTURE is frozen per attempt.
model FlowNode {
  id              String          @id @default(cuid())
  flow            Flow            @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId          String
  parent          FlowNode?       @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  parentId        String?
  children        FlowNode[]      @relation("NodeChildren")
  order           Int
  kind            String // 'content' | 'question' | 'group' | 'folderRef'
  contentItem     ContentItem?    @relation(fields: [contentItemId], references: [id])
  contentItemId   String?
  questionItem    QuestionItem?   @relation(fields: [questionItemId], references: [id])
  questionItemId  String?
  groupTitle      String?
  checkpointAfter Boolean         @default(false)
  // Set when kind='folderRef'. SetNull so deleting the bank folder
  // degrades the folderRef to an empty block; the flow node row stays
  // (preserves admin's intent) but the runtime expansion sees no
  // contents.
  bankFolder      ItemBankFolder? @relation("FlowNodeBankFolderRef", fields: [bankFolderId], references: [id], onDelete: SetNull)
  bankFolderId    String?
  answers         FlowAnswer[]
  currentFor      Attempt[]       @relation("AttemptCurrentNode")

  @@index([bankFolderId])
}

// status: 'in_progress' | 'submitted' | 'approved'
// A rejected question does NOT move the attempt to "rejected" — rejection
// lives only on FlowAnswer. An attempt becomes 'approved' only when every
// question's latest FlowAnswer has status='approved'.
//
// externalPersonId links an attempt to a PersonRef (the guide who took it)
// by their stable upstream id. Nullable to stay backward-compatible with
// pre-guide-management attempts that only carried learnerName. When real
// auth lands, this is the field the resolver will populate; nothing else
// in the attempt/answer pipeline needs to change.
model Attempt {
  id               String       @id @default(cuid())
  flow             Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId           String
  learnerName      String
  workerIdentifier String?
  externalPersonId String?
  status           String       @default("in_progress")
  // Authoring-side cursor (deprecated). Kept for legacy attempts that
  // predate `expansion`. New runtime uses `currentStepId` against the
  // expansion. Old attempts (expansion=null) still use this.
  currentNode      FlowNode?    @relation("AttemptCurrentNode", fields: [currentNodeId], references: [id])
  currentNodeId    String?
  // Per-attempt resolved step list. Snapshots folderRef expansion so
  // bank structural changes don't disrupt in-flight attempts. Item
  // CONTENT still resolves live by id (typo fixes etc.). null on
  // legacy attempts created before this slice — runtime falls back to
  // computing from flow.nodes.
  expansion        Json?
  // Stable step id within `expansion`. For non-folderRef steps this
  // matches the FlowNode id; for folderRef-expanded steps it's a
  // synthetic id of the form `<folderRefNodeId>::<bankItemId>`.
  currentStepId    String?
  submittedAt      DateTime?
  approvedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  answers          FlowAnswer[]

  @@index([externalPersonId])
}

// Versioned answer. Each worker edit appends a new row; existing rows are
// never mutated (except status/adminComment/reviewedAt when an admin reviews).
// status: 'pending' | 'approved' | 'rejected'
//
// `stepId` (not `flowNodeId`) is the canonical identity used by the new
// runtime. For non-folderRef steps stepId == flowNodeId. For folderRef-
// expanded steps stepId is synthetic (`<folderRefNodeId>::<bankItemId>`)
// and flowNodeId is null — there's no real FlowNode row for those.
// Legacy answers had flowNodeId set; the migration backfills stepId =
// flowNodeId so they keep working.
model FlowAnswer {
  id             String    @id @default(cuid())
  attempt        Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId      String
  // Real FlowNode link — kept for non-folderRef steps so reviews and
  // legacy queries that join on flowNodeId still work. Nullable for
  // folderRef-expanded steps.
  flowNode       FlowNode? @relation(fields: [flowNodeId], references: [id], onDelete: Cascade)
  flowNodeId     String?
  // Attempt-stable step identifier. Matches expansion.steps[].stepId.
  stepId         String
  questionItemId String
  openText       String?
  answerChoice   String?
  answerLabel    String?
  version        Int
  status         String    @default("pending")
  adminComment   String?
  createdAt      DateTime  @default(now())
  reviewedAt     DateTime?

  @@unique([attemptId, stepId, version])
  @@index([attemptId, stepId])
}

// Embedded media uploaded by admins and referenced inside item HTML.
// `bytes` holds the raw file. The content is immutable for a given id.
// kind: 'image' | 'video'
model MediaAsset {
  id        String   @id @default(cuid())
  kind      String
  mimeType  String
  filename  String
  byteSize  Int
  bytes     Bytes
  createdAt DateTime @default(now())
}

// ============================================================================
// Business Documents module (V1)
// ============================================================================

// Global fixed fields (company name, VAT, bank details, etc.). Referenced by
// DocumentField.valueSource = 'business_field'. Editing the value here is
// reflected in draft instances (live preview), never in finalized ones
// (instance carries its own frozen field snapshot).
model BusinessField {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  // Bilingual values — each field carries its Hebrew and English text so
  // documents can render either language without duplicating field rows.
  valueHe   String   @default("")
  valueEn   String   @default("")
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A signer (person or entity). Has identity + free-form extra fields map
// (e.g. supplier_code, national_id). Extra fields are document-specific —
// they're referenced by DocumentField.signerFieldKey.
model SignerPerson {
  id          String        @id @default(cuid())
  displayName String
  role        String?
  email       String?
  phone       String?
  extraFields Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  assets      SignerAsset[]
}

// Signature / stamp / combined asset. renderedBytes is canonical (PNG) and
// used by all document renders. drawBytes + stampConfigJson are retained
// informationally for 'combined' re-composition or stamp re-render.
// assetType: 'draw' | 'stamp' | 'combined'
model SignerAsset {
  id              String       @id @default(cuid())
  person          SignerPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId        String
  assetType       String
  label           String?
  renderedBytes   Bytes
  drawBytes       Bytes?
  stampConfigJson Json?
  byteSize        Int
  createdAt       DateTime     @default(now())

  @@index([personId])
}

// The ORIGINAL uploaded file. V1 = PDF only. Immutable for a given id.
model DocumentSource {
  id         String             @id @default(cuid())
  filename   String
  mimeType   String
  sourceKind String
  bytes      Bytes
  byteSize   Int
  createdAt  DateTime           @default(now())
  snapshots  DocumentSnapshot[]
}

// A stable PDF rendering of a DocumentSource. V1 generator = 'passthrough'
// (PDF source → same bytes; no conversion). Reserved for future Word/Excel
// support without schema churn.
model DocumentSnapshot {
  id               String             @id @default(cuid())
  source           DocumentSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId         String
  pdfBytes         Bytes
  pageCount        Int
  generator        String             @default("passthrough")
  generatorVersion String             @default("v1")
  createdAt        DateTime           @default(now())
  templates        DocumentTemplate[]
}

// Reusable template: a named wrapper around a snapshot + a set of fields.
// Editing fields is ONLY allowed when no instance exists. Deleting is blocked
// if instances exist.
model DocumentTemplate {
  id          String             @id @default(cuid())
  title       String
  description String?
  snapshot    DocumentSnapshot   @relation(fields: [snapshotId], references: [id])
  snapshotId  String
  status      String             @default("draft") // 'draft' | 'published'
  origin      String             @default("library") // 'adhoc' | 'library'
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  fields      DocumentField[]
  instances   DocumentInstance[]

  @@index([origin])
}

// A placement on the template PDF. Percentage coordinates (0..100) from the
// page top-left. valueSource + the matching reference column determine what
// value the field gets at render time.
//
// fieldType:    'text' | 'signature' | 'stamp' | 'date' | 'number' | 'email' | 'phone'
// valueSource:  'business_field' | 'signer_field' | 'signer_asset' | 'static' | 'override_only'
// signerAssetMode: 'draw' | 'stamp' | 'combined'
model DocumentField {
  id              String           @id @default(cuid())
  template        DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId      String
  page            Int
  xPct            Float
  yPct            Float
  wPct            Float
  hPct            Float
  fieldType       String
  label           String           @default("")
  required        Boolean          @default(false)
  order           Int              @default(0)
  valueSource     String           @default("override_only")
  businessFieldId String?
  signerPersonId  String?
  signerFieldKey  String?
  signerAssetMode String?
  staticValue     String?
  // Language selector for business_field resolution. Defaults to Hebrew.
  language        String           @default("he") // 'he' | 'en'

  @@index([templateId, page])
}

// A specific use of a template. ALWAYS carries its own frozen field list and
// PDF bytes so later template/field/snapshot edits cannot mutate it.
// status: 'draft' | 'finalized'
model DocumentInstance {
  id                  String                     @id @default(cuid())
  template            DocumentTemplate           @relation(fields: [templateId], references: [id])
  templateId          String
  title               String
  status              String                     @default("draft")
  fieldsSnapshot      Json // frozen DocumentField list at create time
  snapshotPdfBytes    Bytes // frozen PDF bytes at create time
  snapshotPageCount   Int
  businessSnapshot    Json // frozen BusinessField map (key → value) at create time
  signersSnapshot     Json // frozen SignerPerson (+ assets) list at create time
  // Free-form visual annotations (check/x/highlight/line/note). Separate
  // from fieldsSnapshot so annotations never flow through value resolution.
  annotationsSnapshot Json                       @default("[]")
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  finalizedAt         DateTime?
  overrides           DocumentInstanceOverride[]
  finalDocuments      FinalDocument[]

  @@index([templateId])
}

// Per-field override scoped to one instance. Never mutates global values.
// A field can have at most one override row. Either textValue (for text-like
// fields) or assetBytes (for signature/stamp uploads).
model DocumentInstanceOverride {
  id              String           @id @default(cuid())
  instance        DocumentInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  instanceId      String
  snapshotFieldId String // id from the frozen fieldsSnapshot
  textValue       String?
  assetBytes      Bytes?
  updatedAt       DateTime         @updatedAt

  @@unique([instanceId, snapshotFieldId])
}

// The rendered final PDF for an instance. Append-only audit trail (one row
// per finalization; V1 finalizes once and locks the instance).
model FinalDocument {
  id               String           @id @default(cuid())
  instance         DocumentInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  instanceId       String
  pdfBytes         Bytes
  pdfSize          Int
  generatorVersion String           @default("v1")
  generatedAt      DateTime         @default(now())

  @@index([instanceId])
}

// ============================================================================
// Guide Management module — people + teams + flow assignment
// ============================================================================

// Team — managed natively in this system. The recruitment system is NOT
// a source of truth for teams (it doesn't model teams at all), so TeamRef
// has no external id. Admins create, rename, and delete teams here; guide
// ↔ team membership is managed here too via PersonRef.teamRefId.
model TeamRef {
  id          String           @id @default(cuid())
  displayName String
  meta        Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  members     PersonRef[]
  flowTargets FlowTargetTeam[]
}

// Identity layer for a guide. Today `identitySource='recruitment'` means
// name / email / phone are a read-only mirror of the upstream recruitment
// record. When management takes over as source of truth for a given
// person, the flag flips to 'management' and the same fields become
// writable here — with NO schema migration required.
//
// `externalPersonId` is stable across that ownership transition. All
// procedures data (FlowTargetPerson, Attempt.externalPersonId) references
// this id — not PersonRef.id — so ownership flips never break audit or
// assignment data.
//
// `portalToken` is the learner portal's only auth for now (see CLAUDE.md
// §12). It is regenerated on demand by the admin; `portalEnabled=false`
// blocks access even when the token is known.
model PersonRef {
  id               String                   @id @default(cuid())
  externalPersonId String                   @unique
  identitySource   String                   @default("recruitment") // 'recruitment' | 'management'
  displayName      String
  email            String?
  phone            String?
  identitySyncedAt DateTime?
  status           String                   @default("active") // 'active' | 'blocked'
  team             TeamRef?                 @relation(fields: [teamRefId], references: [id])
  teamRefId        String?
  portalToken      String                   @unique
  portalEnabled    Boolean                  @default(true)
  // Lifecycle hint from the upstream source-of-truth (recruitment).
  // Stable mappable values: 'trainee' | 'staff' | 'evaluator'.
  // Hebrew labels live in the client; the server NEVER reads display
  // text. Null means upstream didn't tell us (older guides, or upstream
  // hasn't shipped the field yet).
  lifecycleHint    String?
  // Audit timestamps for the access grant. portalEnabled is the gate;
  // these two record WHEN it last flipped, for the access UI to show
  // "granted X days ago" / "revoked Y days ago". They are independent
  // of the upstream lifecycle and never touched by sync.
  accessGrantedAt  DateTime?
  accessRevokedAt  DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  profile          PersonProfile?
  flowTargets      FlowTargetPerson[]
  tourAssignments  TourAssignment[]
  planAssignments  DealTourPlanAssignment[]
  stationAccess    GuideStationAccess[]
  payrollEntries   PayrollEntry[]

  @@index([teamRefId])
}

// Operational data, always owned by management. Split out from PersonRef so
// the identity-vs-operational authority line is structural, not
// convention-based. One-to-one with PersonRef.
model PersonProfile {
  personRef           PersonRef @relation(fields: [personRefId], references: [id], onDelete: Cascade)
  personRefId         String    @id
  imageUrl            String?
  // Avatar recrop support: the untouched original upload + the crop metadata
  // ({x, y, zoom}) that produced imageUrl. Recropping re-reads the original —
  // no forced re-upload. Old assets are never deleted (history previews).
  imageOriginalUrl    String?
  imageCrop           Json?
  // Training onboarding facts (management-owned, shown on the staff list +
  // profile header): official training start ("YYYY-MM-DD") and the cohort
  // label (free text — "מרץ 2026", "מחזור 14").
  trainingStartDate   String?
  trainingCohort      String?
  // Admin-only payroll facts (NEVER exposed to the guide portal — the portal
  // profile DTO whitelists its fields explicitly):
  //   vatStatus            'exempt' | 'vat_18' (validated scalar, Hebrew in UI)
  //   senioritySupplement  plain decimal amount (no currency semantics baked
  //                        in — the payroll convention of minor-unit BigInt is
  //                        reserved for explicit currency columns)
  vatStatus           String?
  senioritySupplement Decimal?  @db.Decimal(10, 2)
  //   travelAllowance      "נסיעות" — same plain-decimal convention as
  //                        senioritySupplement
  travelAllowance     Decimal?  @db.Decimal(10, 2)
  // Personal identity color — a stable key from the canonical palette
  // (shared/staffColors.mjs). Admin-managed; tours DERIVE their display
  // color from the assigned guide (never stored on TourEvent).
  displayColor        String?
  description         String?
  notes               String?
  bankDetails         Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// Guide → training-content Station permission (מערכי הדרכה). EXPLICIT rows
// are the ONE source of truth — "select all stations in a tour" is only a
// bulk convenience that creates rows, "clear all" deletes them, and single
// stations toggle freely afterwards (Gmail-selection semantics). There is
// deliberately NO stored "whole tour" rule: one truth, no exclusions logic.
// Enforced server-side on the guide portal training routes.
model GuideStationAccess {
  station     TourStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  stationId   String
  personRef   PersonRef   @relation(fields: [personRefId], references: [id], onDelete: Cascade)
  personRefId String
  grantedAt   DateTime    @default(now())

  @@id([stationId, personRefId])
  @@index([personRefId])
}

// Flow → teams assignment. The WHERE for "flows visible to team T" indexes
// on teamRefId, which is why this is a join table (not a string[] column
// on Flow).
model FlowTargetTeam {
  flow       Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId     String
  teamRef    TeamRef  @relation(fields: [teamRefId], references: [id], onDelete: Cascade)
  teamRefId  String
  assignedAt DateTime @default(now())

  @@id([flowId, teamRefId])
  @@index([teamRefId])
}

// Flow → people assignment. FK is to PersonRef, but the stable handle is
// externalPersonId — callers that resolve "flows for this person" should
// match on externalPersonId so data survives PersonRef row reshuffles.
model FlowTargetPerson {
  flow        Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId      String
  personRef   PersonRef @relation(fields: [personRefId], references: [id], onDelete: Cascade)
  personRefId String
  assignedAt  DateTime  @default(now())

  @@id([flowId, personRefId])
  @@index([personRefId])
}

// ============================================================================
// CRM module (Phase 1 foundation) — Organizations, Units, Contacts
// ============================================================================
//
// This is the reference-data foundation for the future Deals/Activities
// workflow (the Pipedrive replacement). Phase 1 builds ONLY foundation:
// Organizations, Organization Units, Organization Types, Contacts, phones,
// emails, and contact↔organization links. NO Deals, NO Activities, NO
// WhatsApp/Gmail/iCount/automation yet.
//
// Conventions: this slice follows the LIVE app conventions (cuid ids, string
// status/type fields, no Postgres enums/citext) for consistency with the
// existing 20+ models. The Phase-0 design (UUID v7 + enums + citext +
// timestamptz, see docs/architecture/) remains the FUTURE TARGET applied during
// the governed migration — not here.
//
// Source-of-truth notes:
//   * Organization is the parent; Organization Units (departments/divisions)
//     belong to it. An Organization may have zero units.
//   * Organization Type belongs to the Organization (School/Corporate/…). It
//     will later drive pricing, quote wording, payment terms, templates.
//   * Organization SUBTYPE does NOT belong to the Organization — it belongs to
//     the future Deal. OrganizationSubtype here is a prepared catalog with NO
//     consumer yet; a Deal will reference it once Deals are built.
//   * Finance fields exist on both Organization and Organization Unit to support
//     the future resolution priority: Deal override → Unit → Organization →
//     Organization Type defaults. That resolution is NOT implemented yet.

// Configurable organization type. `key` is the stable internal key (logic never
// reads the Hebrew label). Will later affect pricing/templates/terms/workflows.
model OrganizationType {
  id                 String                @id @default(cuid())
  key                String                @unique
  label              String // Hebrew display label
  labelEn            String?
  // Quote content owned by the org classification (rich HTML). Inserted into
  // future quotes by selected type/subtype. NOT wired to Quotes yet.
  quoteContentHe     String?
  quoteContentEn     String?
  sortOrder          Int                   @default(0)
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  organizations      Organization[]
  subtypes           OrganizationSubtype[]
  // Deals that point directly at this type (used only while a deal has no linked
  // Organization — see Deal.organizationType).
  deals              Deal[]
  // Pricing (Slice 2): default price list for deals of this org type. Subtype
  // overrides this. Null → fall back to the system default price list.
  defaultPriceList   PriceList?            @relation("OrgTypeDefaultPriceList", fields: [defaultPriceListId], references: [id], onDelete: SetNull)
  defaultPriceListId String?

  // Payment defaults (additive). The terms/methods CATALOG is owned by Payment
  // Configuration (PaymentTerm/PaymentMethod) — we only reference it, never copy
  // it. `defaultPaymentMethod` is an OPTIONAL OVERRIDE: when null, the effective
  // method is INHERITED from the chosen term's own default
  // (PaymentTerm.defaultPaymentMethod). When set, it overrides that inherited
  // value. NOT wired to Quotes/Deals yet.
  defaultPaymentTerm     PaymentTerm?   @relation("OrgTypeDefaultPaymentTerm", fields: [defaultPaymentTermId], references: [id], onDelete: SetNull)
  defaultPaymentTermId   String?
  defaultPaymentMethod   PaymentMethod? @relation("OrgTypeDefaultPaymentMethod", fields: [defaultPaymentMethodId], references: [id], onDelete: SetNull)
  defaultPaymentMethodId String?
  paymentTermsNote       String?

  @@index([sortOrder])
}

// Subtype belongs to the DEAL, not the Organization. Prepared as a catalog now;
// it has NO consumer until Deals exist (a Deal will reference a subtype). May be
// scoped to an OrganizationType (e.g. School → Teachers / Students).
model OrganizationSubtype {
  id                 String            @id @default(cuid())
  key                String            @unique
  label              String
  labelEn            String?
  // Quote content owned by the org classification (rich HTML). Overrides the
  // type's content when set. Inserted into future quotes. NOT wired to Quotes yet.
  quoteContentHe     String?
  quoteContentEn     String?
  organizationType   OrganizationType? @relation(fields: [organizationTypeId], references: [id], onDelete: SetNull)
  organizationTypeId String?
  sortOrder          Int               @default(0)
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deals              Deal[]
  // Pricing (Slice 2): default price list for this subtype. Overrides the
  // OrganizationType default. Null → fall back to the type / system default.
  defaultPriceList   PriceList?        @relation("OrgSubtypeDefaultPriceList", fields: [defaultPriceListId], references: [id], onDelete: SetNull)
  defaultPriceListId String?
  priceRules         PriceRule[]
  pricingSegments    PricingSegment[]

  @@index([organizationTypeId])
}

// The parent organization. Departments/divisions are OrganizationUnit children.
// Finance fields are optional — many organizations have no departments. When a
// Deal is tied to a Unit, the Unit's finance values normally win (see resolution
// priority above).
model Organization {
  id                 String                @id @default(cuid())
  name               String
  organizationType   OrganizationType?     @relation(fields: [organizationTypeId], references: [id], onDelete: SetNull)
  organizationTypeId String?
  notes              String?
  // Optional finance / identity fields.
  taxId              String?
  address            String?
  financeContactName String?
  financePhone       String?
  financeEmail       String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  units              OrganizationUnit[]
  contactLinks       ContactOrganization[]
  deals              Deal[]

  @@index([organizationTypeId])
  @@index([name])
}

// A department / division / business unit. Belongs to one Organization. Every
// unit may behave differently, so it carries its own optional finance fields.
model OrganizationUnit {
  id                 String                @id @default(cuid())
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId     String
  name               String
  taxId              String?
  address            String?
  financeContactName String?
  financePhone       String?
  financeEmail       String?
  sortOrder          Int                   @default(0)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  contactLinks       ContactOrganization[]
  deals              Deal[]

  @@index([organizationId])
}

// A person. Bilingual required names (He + En). Full names are DERIVED at the
// API/UI layer, not stored (no duplicate full-name columns). A contact may
// belong to zero, one, or many organizations (via ContactOrganization), and
// optionally to a specific unit.
model Contact {
  id                    String                @id @default(cuid())
  firstNameHe           String
  lastNameHe            String
  firstNameEn           String
  lastNameEn            String
  notes                 String?
  // Preferred communication language with this person (he | en). Lives on the
  // Contact — the Deal/Quote never copies it; a future Quote defaults from here.
  communicationLanguage String?
  // ת.ז / ע.מ for PRIVATE-customer accounting documents (iCount vat_id). The
  // organization's ח.פ lives on Organization/OrganizationUnit.taxId — this is
  // only the person-level fallback, written back from the הפק מסמך modal.
  taxId                 String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  phones                ContactPhone[]
  emails                ContactEmail[]
  orgLinks              ContactOrganization[]
  dealContacts          DealContact[]
  whatsAppChats         WhatsAppChat[]
  emailThreads          EmailThread[]

  @@index([lastNameHe])
  @@index([lastNameEn])
}

// One of a contact's phone numbers. Exactly one should be primary (enforced at
// the API layer for now; a partial unique index is the future-target version).
model ContactPhone {
  id        String   @id @default(cuid())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  value     String
  label     String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
}

// One of a contact's email addresses. One primary (API-enforced for now).
model ContactEmail {
  id        String   @id @default(cuid())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  value     String
  label     String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
}

// Contact ↔ Organization membership, with an optional specific Unit. A contact
// may be linked to many organizations; within an organization it may be tied to
// a unit or to the organization as a whole (organizationUnitId null).
model ContactOrganization {
  id                 String            @id @default(cuid())
  contact            Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId          String
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId     String
  organizationUnit   OrganizationUnit? @relation(fields: [organizationUnitId], references: [id], onDelete: SetNull)
  organizationUnitId String?
  role               String?
  isPrimary          Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([contactId, organizationId, organizationUnitId])
  @@index([organizationId])
  @@index([organizationUnitId])
  @@index([contactId])
}

// ============================================================================
// Deal module (commercial core) — Deal, DealStage, DealContact
// ============================================================================
//
// The Deal is the COMMERCIAL object (the Pipedrive "deal"). It OWNS the
// commercial agreement: agreed value, discount, payment terms, pipeline stage
// and outcome status. Operational execution (tours, scheduling) and finance
// documents (quotes, payments, invoices) are SEPARATE and not built yet — a
// Deal will link to Tours via a Booking and to iCount via finance later.
//
// Money: integer MINOR units (agorot) as BigInt + a currency code. Never float.
// The server serializes BigInt → number in JSON (see index.js json replacer)
// and converts incoming numbers → BigInt on write.
//
// `key`/slug pattern and live conventions (cuid ids, string status) mirror the
// rest of the live schema; the Phase-0 UUID/enum target stays for the governed
// migration.

// Pipeline stage (configuration, ordered). Managed in CRM settings, drag-
// orderable. A stage is a pipeline POSITION; won/lost is the Deal's `status`,
// kept separate (Pipedrive model) so a closed deal still remembers its stage.
model DealStage {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  labelEn     String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  // Platform inline-edit Display Mode for deals in this stage: 'read' (Read First —
  // fields shown as read-only, click to edit) or 'edit' (Edit First — fields open
  // as inputs for data entry). Configurable in CRM settings; not hardcoded.
  displayMode String   @default("read")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deals       Deal[]

  @@index([sortOrder])
}

// The commercial agreement. Owns money + stage + outcome. Optional links to an
// Organization, a specific Unit, and the deal's Subtype (subtype belongs to the
// Deal, not the Organization).
model Deal {
  id                    String                  @id @default(cuid())
  // "מספר הזמנה" — the business-facing sequential deal number. Assigned by a
  // dedicated Postgres sequence that starts at 27000 and only ever grows (gaps
  // from deleted deals are fine, numbers are never reused). Shown in the Deal
  // header and used as the Deal URL; the cuid `id` stays the internal PK/FK key.
  orderNo               Int                     @unique @default(dbgenerated("nextval('deal_order_no_seq')"))
  title                 String
  organization          Organization?           @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationId        String?
  organizationUnit      OrganizationUnit?       @relation(fields: [organizationUnitId], references: [id], onDelete: SetNull)
  organizationUnitId    String?
  organizationSubtype   OrganizationSubtype?    @relation(fields: [organizationSubtypeId], references: [id], onDelete: SetNull)
  organizationSubtypeId String?
  // Activity classification (group | private | business). Applies to the Deal
  // now and later to the actual tour/activity. Nullable for backward compat;
  // no Postgres enum (project convention is string enums validated at the API).
  activityType          String?
  // The deal's organization type — authoritative ONLY while no Organization is
  // linked (manual classification). Once an Organization is attached the deal is
  // forced to activityType='business' and this field is force-cleared by the API
  // (see src/deals/classification.js): the ORGANIZATION's own type is the single
  // effective type, so a contradicting copy can never be persisted on the deal.
  // Readers resolve: org's type when linked, else this field.
  organizationType      OrganizationType?       @relation(fields: [organizationTypeId], references: [id], onDelete: SetNull)
  organizationTypeId    String?
  // Operational tour selection: the chosen Product and its Product×Location
  // variant ("city"). Pricing reads these as engine context; nullable so a deal
  // can exist before a product is picked. SetNull so catalog edits never delete deals.
  product               Product?                @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId             String?
  productVariant        ProductVariant?         @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  productVariantId      String?
  // Operational tour CITY. Usually the location of the chosen productVariant, but
  // may be ANY CRM location (manual override) even if no variant exists for it —
  // pricing still resolves via productVariantId (null → manual). SetNull on delete.
  location              Location?               @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationId            String?
  dealStage             DealStage               @relation(fields: [dealStageId], references: [id])
  dealStageId           String
  status                String                  @default("open") // 'open' | 'won' | 'lost'
  valueMinor            BigInt                  @default(0)
  currency              String                  @default("ILS")
  discountMinor         BigInt?
  // No-payment WAIVER (canonical) — an independent commercial decision layered on
  // top of the fully-commercial builder. QuoteLines keep real prices; this records
  // which ticket quantities were waived. valueMinor (the payable total) = gross −
  // waived. Shape: { reason, waivedAt, lines: [{ cardGroupId, ticketTypeId,
  // quantityWaived }] }. null = no waiver. See src/deals/waiver.js.
  noPaymentWaiver       Json?
  // Payment — FK to the CRM catalog (the source of truth). The Deal stores only
  // IDs, never names, so renaming a term/method in settings never affects deals.
  paymentTerm           PaymentTerm?            @relation(fields: [paymentTermId], references: [id], onDelete: SetNull)
  paymentTermId         String?
  paymentMethodRef      PaymentMethod?          @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  paymentMethodId       String?
  // DEPRECATED back-compat only — no longer written. Superseded by the FK fields.
  paymentTerms          String?
  // Lead source. `dealSource` references the admin-managed DealSource catalog
  // (the structured "how did this lead arrive"). `source` is kept as the OPTIONAL
  // free-text detail (specific campaign / referrer name / conference, …).
  dealSource            DealSource?             @relation(fields: [dealSourceId], references: [id], onDelete: SetNull)
  dealSourceId          String?
  source                String?
  ownerUserId           String? // loose actor id (no User model yet)
  expectedCloseDate     DateTime?
  wonAt                 DateTime?
  // Audit snapshot of the PRIMARY quote at the moment the deal was marked WON:
  // { offerId, offerNo, versionNo, quoteDocumentId, publicToken, publicUrl,
  //   producedAt, stampedAt }. Written only on the open/lost → won transition
  // (never retroactively); preserved on reopen like wonAt. Null when the deal
  // had no generated primary quote when it was won.
  wonQuoteRef           Json?
  lostAt                DateTime?
  // LOST outcome — structured. lostReasonRef points at the shared LostReason
  // catalog (required at the API layer when status='lost'); lostNotes is free
  // optional detail. `lostReason` (legacy free text) is RETAINED only as a
  // backward-compat display fallback for old rows — new saves leave it null and
  // write the structured fields instead.
  lostReasonRef         LostReason?             @relation(fields: [lostReasonId], references: [id], onDelete: SetNull)
  lostReasonId          String?
  lostNotes             String?
  lostReason            String?
  notes                 String?
  // "פרטי הסיור" — working fields for the sales-call workspace. Simple Deal
  // scalars (single source of truth = the Deal). String enums validated at the
  // API (no Postgres enum). Product/City/pricing remain in the deferred quote
  // slice and are NOT stored here yet.
  tourDate              String? // "YYYY-MM-DD"
  tourTime              String? // "HH:MM"
  participants          Int?
  // DEPRECATED back-compat only — no longer written. Superseded by paymentMethodId.
  paymentMethod         String?
  communicationLanguage String? // he | en
  tourLanguage          String? // he | en | es | fr | ru
  customerInfo          String? // internal working note (lightweight rich HTML)
  // "פתיח אישי למייל" — commercial (Quote) card. Temporary home on Deal until the
  // QuoteVersion model lands (then it becomes per-quote, this stays as a default).
  quoteEmailIntro       String?
  // Legacy flag from the inline base-price input (now unused — per-line override
  // lives on QuoteLine.overridden). Kept to avoid a destructive drop; removable later.
  basePriceOverridden   Boolean                 @default(false)
  // PERMANENT customer-facing payment token: the customer always gets
  // ${PUBLIC_ORIGIN}/pay/<token>, which redirects to the CURRENT iCount link
  // (regenerated behind the scenes when payment data changes). Only the token
  // is stored — the display URL is built from PUBLIC_ORIGIN at request time,
  // so a future domain change needs no DB migration. Created lazily.
  paymentToken          String?                 @unique
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  contacts              DealContact[]
  quoteVersions         QuoteVersion[]
  quoteDocuments        QuoteDocument[]
  quoteOffers           QuoteOffer[]
  paymentLinks          DealPaymentLink[]
  icountDocuments       IcountDocument[]
  customPaymentLinks    DealCustomPaymentLink[]
  paymentRequests       PaymentRequest[]
  tasks                 Task[]
  files                 DealFile[]
  emailThreads          EmailThread[]
  // Tours: the ONLY Deal↔TourEvent relationship (see Booking). Never add a
  // direct tourEventId here.
  bookings              Booking[]
  // Canonical ticket registrations linked to this deal (CRM context only; seat
  // truth is the TicketRegistration itself, not the Booking).
  ticketRegistrations   TicketRegistration[]
  // Pre-WON tour PLANNING (team/components/notes) — see DealTourPlan.
  tourPlan              DealTourPlan?

  @@index([organizationId])
  @@index([organizationUnitId])
  @@index([organizationSubtypeId])
  @@index([organizationTypeId])
  @@index([productId])
  @@index([productVariantId])
  @@index([locationId])
  @@index([paymentTermId])
  @@index([paymentMethodId])
  @@index([dealStageId])
  @@index([lostReasonId])
  @@index([dealSourceId])
  @@index([status])
}

// ── CRM Tasks (משימות) ──────────────────────────────────────────────────────
// A Task is a FUTURE action on a Deal (call, follow-up, collection, WhatsApp…).
// Types are configurable in CRM settings (TaskType) — the UI never hard-codes
// them. Open tasks live in the Deal focus area; completed/cancelled/sent/
// not_sent tasks leave that list and surface as TimelineEntry events in history
// (one source of truth — the timeline is not a second store for tasks).
//
// A 'whatsapp' task links 1:1 to a WhatsAppScheduledMessage. The Task NEVER
// sends — the existing claim-based scheduled worker owns sending; the Task only
// tracks the outcome. Ticking a WhatsApp task's checkbox BEFORE it sends does
// NOT send — it cancels the scheduled message and records status 'not_sent'
// ("בסוף לא נשלחה").
model TaskType {
  id                   String   @id @default(cuid())
  key                  String   @unique
  nameHe               String
  icon                 String   @default("check") // client-side icon key
  color                String? // optional accent (client maps to a tone)
  isActive             Boolean  @default(true)
  sortOrder            Int      @default(0)
  defaultText          String?
  // How the default due date is derived when a task of this type is created.
  defaultDueOffsetType String   @default("today") // today | tomorrow | days_from_now | none
  defaultDueOffsetDays Int      @default(0)
  defaultTime          String? // "HH:MM"
  requiresTime         Boolean  @default(false)
  channel              String   @default("none") // none | whatsapp
  isSystem             Boolean  @default(false) // seeded defaults; protected from delete
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tasks                Task[]

  @@index([isActive, sortOrder])
}

model Task {
  id                      String    @id @default(cuid())
  deal                    Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId                  String
  // Type is optional at the FK level (SetNull) so deleting a type never destroys
  // task history; the channel/text were snapshotted onto the Task at create.
  taskType                TaskType? @relation(fields: [taskTypeId], references: [id], onDelete: SetNull)
  taskTypeId              String?
  title                   String
  dueDate                 DateTime // required for every task
  dueTime                 String? // "HH:MM" — optional (WhatsApp defaults 10:00)
  priority                String? // null | low | medium | high  ("סדר עדיפות")
  ownerUserId             String // AdminUser id — loose key (no FK), always set
  createdByUserId         String?
  status                  String    @default("open") // open | completed | cancelled | sent | not_sent
  completedAt             DateTime?
  cancelledAt             DateTime?
  notes                   String?
  channel                 String    @default("none") // snapshot: none | whatsapp
  // WhatsApp linkage (loose keys — the scheduled worker owns the send).
  scheduledMessageId      String? // → WhatsAppScheduledMessage.id
  whatsappSenderAccountId String? // → WhatsAppAccount.id
  whatsappChatId          String? // → WhatsAppChat.id
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([dealId, status])
  @@index([ownerUserId, status])
}

// Private files attached to a Deal. R2-backed, PRIVATE by contract: unlike
// MediaFile there is NO public `url` column — downloads go only through an
// admin-authed route that mints a short-lived presigned GET (§15: no public
// file URLs). Objects live under `deals/<dealId>/…`.
model DealFile {
  id           String   @id @default(cuid())
  deal         Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId       String
  r2Key        String   @unique
  bucket       String
  filename     String
  mimeType     String
  sizeBytes    Int
  uploadedById String? // AdminUser id — loose key
  createdAt    DateTime @default(now())

  @@index([dealId, createdAt])
}

// Deal ↔ Contact link. A deal often has MULTIPLE contacts with different roles
// and per-deal communication preferences. `roles` is a structured set (array,
// not a single flattened role): coordinator | payer | decisionMaker |
// participant | invoiceContact | other. Preferences are operational routing,
// later gated by Contact-level consent.
model DealContact {
  id                        String   @id @default(cuid())
  deal                      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId                    String
  contact                   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId                 String
  roles                     String[] @default([])
  isPrimary                 Boolean  @default(false)
  receiveConfirmations      Boolean  @default(false)
  receiveOperationalUpdates Boolean  @default(false)
  receivePaymentLinks       Boolean  @default(false)
  receiveQuotes             Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@unique([dealId, contactId])
  @@index([contactId])
  @@index([dealId])
}

// ── iCount payment links ("תשלום באייקאונט" — Deal payment module) ───────────
// GOS stays the operational source of truth; iCount is ONLY the payment/invoice
// provider. One row per generate action: regenerating marks the previous row
// 'superseded' and inserts a new one (full history kept; the latest 'created'
// row is THE deal's personal link). Customer/amount fields are FROZEN copies of
// what was actually sent to iCount — the deal may change later, the link won't.
// Generating a link NEVER changes deal status or marks anything paid; payment
// confirmation is a future slice (webhook processing / manual admin action).
model DealPaymentLink {
  id                  String   @id @default(cuid())
  deal                Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId              String
  provider            String   @default("icount")
  status              String   @default("created") // 'created' | 'superseded'
  paymentLinkUrl      String
  paypageId           String? // iCount paypage template the sale was generated from
  amountMinor         BigInt // agorot, VAT-inclusive gross (Deal.valueMinor at generation time)
  currency            String   @default("ILS")
  productName         String
  customerName        String?
  customerPhone       String?
  customerEmail       String?
  createdBy           String? // loose AdminUser id (same convention as Deal.ownerUserId)
  rawProviderResponse Json? // iCount generate_sale response, for audit/debug
  createdAt           DateTime @default(now())

  @@index([dealId])
}

// ── iCount accounting documents ──────────────────────────────────────────────
// One row per accounting document GOS knows about for a deal: issued from the
// "הפק מסמך" modal (source 'user'), or captured from an iCount IPN webhook
// (source 'webhook'). GOS stays the operational source of truth; iCount is the
// accounting provider — the row stores the ISSUED snapshot (type/number/amount/
// customer/url) plus the raw provider response for audit. `idempotencyKey` is
// UNIQUE and dedupes both a double-clicked modal submit and a retried webhook.
model IcountDocument {
  id             String   @id @default(cuid())
  deal           Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId         String
  provider       String   @default("icount")
  source         String   @default("user") // 'user' | 'webhook'
  doctype        String // iCount doctype: 'deal'|'invoice'|'invrec'|'receipt'|'refund'
  docnum         String? // iCount document number (string — provider-owned format)
  providerDocId  String? // iCount internal doc_id (used as origin_doc_id for credits)
  status         String   @default("issued") // 'issued' (failed attempts are never stored)
  amountMinor    BigInt // agorot, VAT-inclusive gross as issued
  currency       String   @default("ILS")
  clientName     String
  clientVatId    String? // ח.פ / ע.מ / ת.ז as sent to iCount
  docUrl         String? // iCount pdf/original link (admin-facing, not a customer URL)
  basedOnDoctype String? // base document this one closed/credited (if any)
  basedOnDocnum  String?
  idempotencyKey String?  @unique
  issuedBy       String? // loose AdminUser id; null for webhook/system
  raw            Json? // iCount doc/create response (or webhook payload extract)
  createdAt      DateTime @default(now())

  @@index([dealId])
}

// ── Custom payment links ("קישור לתשלום מותאם אישית") ────────────────────────
// A per-deal payment link whose invoice line/amount intentionally DIFFER from
// the deal's products (customer asked for a different description on the
// document). Frozen at creation — the iCount sale link is generated once and
// reused; the customer always gets the GOS URL /pay/c/<token> (same redirect
// pattern as the regular /pay/<Deal.paymentToken>, which stays untouched).
model DealCustomPaymentLink {
  id                  String   @id @default(cuid())
  deal                Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId              String
  token               String   @unique
  status              String   @default("active") // 'active' | 'disabled'
  description         String // the custom invoice/product line the customer sees
  amountMinor         BigInt // agorot, VAT-inclusive gross
  currency            String   @default("ILS")
  notes               String?
  paymentLinkUrl      String? // generated iCount sale_url (created eagerly, reused)
  rawProviderResponse Json?
  createdBy           String?
  createdAt           DateTime @default(now())

  @@index([dealId])
}

// ── Cardcom tourist payment requests ─────────────────────────────────────────
// A provider-tagged payment INTENT with its own lifecycle (pending → paid |
// canceled) — distinct from DealPaymentLink (a regenerating link with no paid
// state). GOS stays the source of truth; Cardcom ONLY clears (3DS tourist
// cards); iCount stays the accounting provider. The customer always receives the
// stable GOS URL /payment/cardcom/<token>, which lazily creates/refreshes the
// Cardcom LowProfile behind the scenes (never at create/edit time). Frozen GOS
// business identity (product/version) is preserved for long-term reporting even
// though only the English description is shown on the page/document.
//
// INVARIANT — at most ONE pending cardcom request per deal: enforced by a
// PARTIAL UNIQUE INDEX in the migration (dealId WHERE status='pending' AND
// provider='cardcom'), so even concurrent creates can't produce a second.
model PaymentRequest {
  id       String @id @default(cuid())
  deal     Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId   String
  provider String @default("cardcom")
  status   String @default("pending") // 'pending' | 'paid' | 'canceled'
  token    String @unique // public /payment/cardcom/<token>

  // Frozen customer-facing values
  currency             String  @default("ILS")
  amountMinor          BigInt // minor units, VAT-inclusive gross
  quantity             Int     @default(1)
  productDescriptionEn String // English line shown on the page + accounting document
  customerName         String?
  customerEmail        String?
  customerPhone        String?
  vatExempt            Boolean @default(false) // inherited from Deal pricing, frozen

  // Frozen GOS business identity (SSOT for reporting/audit — NOT sent to Cardcom)
  productId        String?
  productVariantId String?
  quoteVersionId   String?

  // Cardcom target — the currently-active LowProfile (created lazily on open)
  cardcomLowProfileId String?
  cardcomPayUrl       String?
  snapshotHash        String? // frozen-field fingerprint → regenerate when it drifts

  // Payment result
  paidAt               DateTime?
  cardcomTransactionId String?
  paidRaw              Json?

  // Accounting outcome (auto-issue is best-effort; payment stays paid regardless)
  docStatus        String  @default("none") // 'none' | 'issued' | 'failed'
  icountDocumentId String?

  createdBy           String? // loose AdminUser id
  rawProviderResponse Json? // last Cardcom LowProfile/Create response, for audit
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([dealId])
  @@index([dealId, status])
}

// Raw Cardcom webhook payloads — logged BEFORE processing (audit + retroactive
// reprocessing). Not an FK: the log survives deal deletion.
model CardcomWebhookLog {
  id        String   @id @default(cuid())
  token     String? // ReturnValue carried by the payload, when present
  payload   Json
  createdAt DateTime @default(now())

  @@index([token])
}

// ── WhatsApp module (Slice 1 — accounts + Baileys sessions) ──────────────────
//
// GOS runs ONE bridge service per WhatsApp number (gos-whatsapp-main /
// gos-whatsapp-office — same code, same DB, different WHATSAPP_ACCOUNT_ID env).
// Everything is scoped by accountId: no singleton assumptions, no hardcoded
// number. The account row is the sender profile AND the live connection state —
// the bridge upserts its own row at boot (id comes from env, so deployment
// identity = account identity) and mirrors every Baileys connection.update into
// it; the admin UI reads the row via the GOS API without touching Baileys.
model WhatsAppAccount {
  id                   String                        @id // stable key from bridge env, e.g. 'main' | 'office'
  label                String // display name, editable in admin ("מספר ראשי")
  active               Boolean                       @default(true)
  sortOrder            Int                           @default(0)
  // Live connection state (written by this account's bridge only).
  status               String                        @default("disconnected") // disconnected | qr_required | pairing | connecting | connected
  qr                   String? // current pairing QR payload (null when not pairing)
  phoneJid             String? // our own number's JID after pairing
  deviceName           String?
  lastQrAt             DateTime?
  lastConnectedAt      DateTime?
  lastDisconnectAt     DateTime?
  lastDisconnectReason String?
  lastMessageAt        DateTime? // any-direction heartbeat
  lastInboundMessageAt DateTime? // inbound-only — detects "connected but silent" zombies
  reconnectAttempts    Int                           @default(0)
  lastMediaError       String?
  lastMediaErrorAt     DateTime?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  sessions             WhatsAppSession[]
  dataGaps             WhatsAppDataGap[]
  chats                WhatsAppChat[]
  messages             WhatsAppMessage[]
  reactions            WhatsAppMessageReaction[]
  outboundIdempotency  WhatsAppOutboundIdempotency[]
  scheduledMessages    WhatsAppScheduledMessage[]
}

// One WhatsApp conversation as seen by ONE of our numbers. The same customer
// can legitimately have a separate thread per account, so chats are unique on
// (accountId, externalChatId) — never globally.
//
// Identity columns (ported from the proven Challenge System resolution):
//   externalChatId — the JID WhatsApp reports (@lid privacy id, @s.whatsapp.net
//                    phone form, or @g.us group). lidJid/phoneJid hold the two
//                    canonical person forms once learned (cross-referenced from
//                    contacts events + v7 lidPnMappings); phoneNumber is the
//                    counterparty's digits — NEVER the connected owner's.
//   savedContactName / pushName / groupSubject — display-name sources, written
//                    only by their dedicated event paths.
//
// CRM matching is LINK-ONLY: contactId points at an existing Contact (matched
// by normalized phone → matchSource='phone', or linked by an admin →
// 'manual'). WhatsApp never creates or edits Contacts; unlinking clears these
// two fields and nothing else.
model WhatsAppChat {
  id                 String                     @id @default(cuid())
  account            WhatsAppAccount            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId          String
  externalChatId     String
  type               String // 'private' | 'group'
  savedContactName   String?
  pushName           String?
  groupSubject       String?
  phoneNumber        String? // counterparty digits, international form
  lidJid             String?
  phoneJid           String?
  profilePictureUrl  String?
  contact            Contact?                   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId          String?
  matchSource        String? // 'phone' | 'manual'
  lastMessageAt      DateTime?
  // Inbox workflow state (team-level, not per-admin): pinned floats the chat
  // to the top; snooze hides it from the active scope until snoozedUntil —
  // UNLESS a new message arrives after snoozedAt (Gmail-style early wake).
  pinnedAt           DateTime?
  snoozedUntil       DateTime?
  snoozedAt          DateTime?
  // PROVIDER state (mirrors the phone, written by the bridge): archived /
  // deleted on WhatsApp itself. Rows are never deleted — the active inbox
  // excludes them while CRM history keeps the full mirror.
  providerArchivedAt DateTime?
  providerDeletedAt  DateTime?
  // GOS-side manual hide ("הסתר מהרשימה") — cleanup for chats deleted on the
  // phone BEFORE provider-state tracking existed (no retroactive signal).
  hiddenAt           DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  messages           WhatsAppMessage[]
  scheduledMessages  WhatsAppScheduledMessage[]

  @@unique([accountId, externalChatId])
  @@index([accountId, lastMessageAt])
  @@index([accountId, phoneNumber])
  @@index([accountId, lidJid])
  @@index([accountId, phoneJid])
  @@index([contactId])
}

// One mirrored message. accountId is deliberately DENORMALIZED (also derivable
// via chat) — the purge/query contract: every WhatsApp model carries a direct
// accountId. Dedup is the (accountId, externalMessageId) unique — Baileys
// delivers the same message via live event AND history sync.
//
// Media lifecycle (media is downloaded AT INGEST — WhatsApp media expires):
//   mediaStatus: 'pending'  row created, download in flight
//                'stored'   bytes in R2 under mediaKey
//                'failed'   live download failed (placeholder in UI)
//                'expired'  history-synced message whose media is gone
//                'too_large' over the configured cap
//                'disabled' R2 not configured on the bridge
//   mediaKey:    R2 object key — ALWAYS `whatsapp/<accountId>/…` (purge contract)
//   mediaThumbBase64: tiny embedded jpegThumbnail (images/videos) for instant
//                previews even before/without the full download.
model WhatsAppMessage {
  id                  String          @id @default(cuid())
  account             WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId           String
  chat                WhatsAppChat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId              String
  externalMessageId   String?
  direction           String? // 'incoming' | 'outgoing'
  senderName          String?
  senderPhone         String?
  messageType         String // text | image | video | audio | document | sticker | system
  textContent         String?
  mediaKey            String?
  mediaStatus         String?
  mediaMimeType       String?
  mediaSizeBytes      Int?
  mediaOriginalName   String?
  mediaThumbBase64    String?
  quotedExternalId    String?
  // Outgoing delivery ladder from WhatsApp acks (messages.update):
  // 'sent' | 'delivered' | 'read' | 'played'. Null for incoming rows.
  deliveryStatus      String?
  // Team-level star (message bookmarks) — set from the GOS UI only.
  starredAt           DateTime?
  rawPayload          Json?
  // Slice 6: proto-encoded outbound payload, kept for WhatsApp's retransmit
  // replay (getMessage) — without it a recipient whose device asks for a
  // resend sees "waiting for this message". Null for inbound rows.
  outboundPayload     Bytes?
  timestampFromSource DateTime
  createdAt           DateTime        @default(now())

  @@unique([accountId, externalMessageId])
  @@index([chatId, timestampFromSource])
  @@index([accountId, createdAt])
}

// Outbound send idempotency (Slice 6) — one row per caller-supplied key so a
// retried send replays the recorded outcome instead of double-messaging a
// customer. Ported from the proven Challenge System bridge.
model WhatsAppOutboundIdempotency {
  key               String          @id
  account           WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId         String
  outcome           String // 'ok' | 'failed'
  externalMessageId String?
  errorCode         String?
  errorMessage      String?
  createdAt         DateTime        @default(now())

  @@index([accountId])
  @@index([createdAt])
}

// Scheduled outbound messages (Slice 7) — text-only V1, claim-based worker in
// the GOS server (claimedAt/claimedBy + atomic updateMany claim = safe across
// restarts/instances; the idempotency key derives from id+scheduledAt+attempt
// so a recovered row can never double-send).
model WhatsAppScheduledMessage {
  id                      String          @id @default(cuid())
  account                 WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId               String
  chat                    WhatsAppChat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId                  String
  content                 String
  scheduledAt             DateTime
  status                  String          @default("pending") // pending | sending | sent | failed | cancelled | skipped
  attemptCount            Int             @default(0)
  lastAttemptAt           DateTime?
  nextRetryAt             DateTime?
  connectionDeferredCount Int             @default(0)
  claimedAt               DateTime?
  claimedBy               String?
  sentAt                  DateTime?
  externalMessageId       String?
  failureReason           String?
  createdById             String?
  // Optional back-link to the CRM Task that scheduled this message (WhatsApp
  // tasks). LOOSE key (no FK relation, same convention as createdById) so the
  // sensitive scheduled-message table stays decoupled from CRM. The worker
  // reads it to move the linked Task to 'sent' the moment the send succeeds.
  taskId                  String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([status, scheduledAt])
  @@index([accountId, status])
  @@index([chatId, status])
  @@index([taskId])
}

// Emoji reactions, keyed by the target message's external id. emoji='' is a
// removal (kept as the current state). Stored account-scoped like everything.
model WhatsAppMessageReaction {
  id                String          @id @default(cuid())
  account           WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId         String
  externalMessageId String
  reactorPhone      String
  reactorName       String?
  emoji             String
  reactedAt         DateTime
  createdAt         DateTime        @default(now())

  @@unique([accountId, externalMessageId, reactorPhone])
}

// Baileys auth state (creds + signal keys) — Postgres-backed so a Railway
// redeploy resumes the session without re-pairing (volumes don't survive).
// Mirrors the proven Challenge System store: kind = the file-auth "type"
// ('creds' | 'pre-key' | 'session' | ...), keyId = the key id, data =
// BufferJSON-serialized. Scoped per account so the two bridges sharing this
// DB can never overwrite each other.
model WhatsAppSession {
  id        String          @id @default(cuid())
  account   WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String
  kind      String
  keyId     String
  data      Json
  updatedAt DateTime        @updatedAt

  @@unique([accountId, kind, keyId])
}

// Honest outage ledger: one row per disconnected window, per account. Opened
// on disconnect, closed on reconnect. Operator visibility only — messages in
// the window may be missing and we never claim recovery.
model WhatsAppDataGap {
  id               String          @id @default(cuid())
  account          WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId        String
  disconnectedAt   DateTime
  reconnectedAt    DateTime?
  durationMs       Int?
  disconnectReason String?
  createdAt        DateTime        @default(now())

  @@index([accountId, reconnectedAt])
}

// Raw iCount IPN payloads — audit log ONLY in this slice. The receiver persists
// the payload and returns 200; it changes NO deal/payment state (processing is
// a future slice). Logged now so links generated today aren't deaf: every
// payment made through them is captured and can be processed retroactively.
model IcountWebhookLog {
  id        String   @id @default(cuid())
  dealId    String? // from the ipn_url query param, when present (not an FK — log survives deal deletion)
  payload   Json
  createdAt DateTime @default(now())

  @@index([dealId])
}

// ── Quote Offers ─────────────────────────────────────────────────────────────
// An Offer is ONE commercial path of a deal (הצעה 1 / הצעה 2 — parallel
// alternatives that never supersede each other). Within one offer, generated
// QuoteDocuments are numbered VERSIONS (v1, v2 …); a newer produced version
// supersedes older unsigned ones (their public URL shows a "newer proposal"
// screen). Exactly one offer per deal is primary — the offer a WON deal refers
// to. Terminology (locked): Offer = alternative; Version = revision within an
// offer (QuoteDocument.versionNo); QuoteVersion below = PRICING lines (historic
// name, distinct concept).
model QuoteOffer {
  id               String          @id @default(cuid())
  deal             Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId           String
  offerNo          Int // 1, 2, 3 … per deal
  isPrimary        Boolean         @default(false)
  // ── Commercial context ─────────────────────────────────────────────────────
  // INVARIANT: the PRIMARY offer is always contextMode='deal' — the Deal IS the
  // primary offer's commercial truth (product, variant, pricing headline,
  // participants, technical context). Non-primary (parallel) offers are always
  // contextMode='own': they carry their OWN context here and compose from it,
  // fully immune to Deal edits. "Make Primary" adopts the offer's context onto
  // the Deal, freezes the outgoing primary's context as 'own', and flips the
  // new primary to 'deal'. WON is only the customer's acceptance — it never
  // changes the Deal. Context fields are meaningful only when contextMode='own'.
  contextMode      String          @default("deal") // 'deal' | 'own'
  product          Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId        String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  productVariantId String?
  location         Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationId       String?
  participants     Int?
  tourDate         String? // "YYYY-MM-DD"
  tourTime         String? // "HH:MM"
  valueMinor       BigInt? // the offer's gross (Builder-computed) — headline when promoted to primary
  // Soft removal. An offer WITH generated documents is never hard-deleted —
  // archiving hides it from the workspace tabs while history/admin access to
  // its immutable documents stays intact. Hard delete is allowed only for an
  // offer that never generated anything (and never with a signed document).
  archivedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  quoteVersions    QuoteVersion[]
  quoteDocuments   QuoteDocument[]

  @@unique([dealId, offerNo])
  @@index([dealId])
}

// ── Quote model (canonical line storage) ────────────────────────────────────
// QuoteVersion + QuoteLine are the SINGLE source of truth for a deal's pricing
// lines. Each offer has exactly ONE working version (isWorking=true) that the
// Price Builder edits. Deal.valueMinor caches the working version's gross.
model QuoteVersion {
  id             String          @id @default(cuid())
  deal           Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId         String
  // The offer this priced version belongs to. Nullable for legacy rows;
  // backfilled to offer #1. SetNull so pricing survives an offer row's removal.
  offer          QuoteOffer?     @relation(fields: [offerId], references: [id], onDelete: SetNull)
  offerId        String?
  status         String          @default("draft") // draft | produced | accepted | rejected (only 'draft' used now)
  isWorking      Boolean         @default(true) // the version the builder/panel edits (exactly one per deal for now)
  isSelected     Boolean         @default(false) // the accepted/main version (unused until the quote workflow)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  lines          QuoteLine[]
  quoteDocuments QuoteDocument[]

  @@index([dealId])
  @@index([offerId])
}

// One priced line on a quote version. Same shape the Price Builder UI uses; refs
// are typed (productVariant for the product line, addon for add-on lines) with
// SetNull so catalog edits never break a saved quote line (the price is frozen on
// the line). kind: product | addon | discount | credit | manual.
model QuoteLine {
  id                String          @id @default(cuid())
  quoteVersion      QuoteVersion    @relation(fields: [quoteVersionId], references: [id], onDelete: Cascade)
  quoteVersionId    String
  kind              String
  label             String          @default("")
  productVariant    ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  productVariantId  String?
  addon             Addon?          @relation(fields: [addonId], references: [id], onDelete: SetNull)
  addonId           String?
  quantity          Int             @default(1)
  unitPriceMinor    BigInt          @default(0)
  vatMode           String          @default("inherit") // inherit | included | excluded | exempt
  vatRate           Int?
  active            Boolean         @default(true)
  // `note` is USER content only — never a system identifier. Safe to edit, clear or
  // translate without affecting what the line represents (see structured identity).
  note              String?
  overridden        Boolean         @default(false)
  // Structured identity for Group Ticket Builder lines. A group-ticket line is ONE
  // ticket type sold from ONE Pricing Card, so it persists exactly that — never
  // encoded into `note`. All additive/nullable; regular builder lines leave them
  // null. `sourceKind` names the originating workspace (e.g. 'group_ticket').
  // `sourceCardGroupId` is a LOOSE key (cardGroupId is shared across a card's
  // sibling PriceRules; there is no CardGroup table — same loose-key approach as
  // FlowAnswer.stepId / ownerUserId). `ticketType` is a real FK (SetNull) so a
  // catalog delete degrades gracefully like productVariant/addon.
  sourceKind        String?
  sourceCardGroupId String?
  ticketType        TicketType?     @relation(fields: [ticketTypeId], references: [id], onDelete: SetNull)
  ticketTypeId      String?
  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([quoteVersionId])
  @@index([productVariantId])
  @@index([addonId])
  @@index([ticketTypeId])
}

// ============================================================================
// Products & Pricing — Slice 1 (Catalog + Files + Payment configuration)
// ============================================================================
//
// Product = what we sell; Pricing (Slice 2) = how price is computed; Deal lines
// (Slice 3) = the frozen snapshot. This slice adds ONLY the catalog, the R2 file
// metadata, the activity-type seed, and payment config. No pricing, no add-ons,
// no Deal changes. See docs/architecture/GOS-products-pricing-architecture.md.
//
// Images live in Cloudflare R2; the DB stores only metadata + object keys/URLs
// (no DB blobs for this module). Money = BigInt minor units + currency.

// R2 object metadata. Foundation for a reusable Files service (images now;
// PDFs/documents later).
model MediaFile {
  id           String   @id @default(cuid())
  r2Key        String   @unique
  url          String
  bucket       String
  filename     String
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  kind         String   @default("image") // image | pdf | doc
  uploadedById String? // loose actor id (no FK)
  createdAt    DateTime @default(now())

  variantMeetingImages  ProductVariant[]      @relation("VariantMeetingImage")
  variantGalleryLinks   ProductVariantImage[]
  locationMeetingImages Location[]            @relation("LocationMeetingImage")
  quoteDocumentRenders  QuoteDocumentRender[]
  // Shared Content Library items that use this file as their image (by reference;
  // no byte copy — a MediaFile is already reusable-by-reference).
  sharedContentImages   SharedContent[]
  // Tour Content (Phase 1a) — hero images on stations and re-hosted block assets
  // reference R2/MediaFile (never DB binary). By reference; no byte copy.
  tourStationHeroes     TourStation[]         @relation("TourStationHero")
  tourBlockAssets       TourBlockAsset[]      @relation("TourBlockAssetMedia")
  // Quote Image Library items backed by this file (by reference; no byte copy).
  quoteImages           QuoteImage[]          @relation("QuoteImageMedia")
}

// Simple location catalog (e.g. "תל אביב - פלורנטין"). No City/Area split.
model Location {
  id                    String               @id @default(cuid())
  nameHe                String
  nameEn                String?
  meetingPointHe        String? // rich HTML
  meetingPointEn        String? // rich HTML
  // City marketing content for quotes — owned by the Location (NOT a generic
  // QuoteSection). Bilingual rich HTML. Referenced by the City content block.
  marketingDescHe       String? // rich HTML
  marketingDescEn       String? // rich HTML
  meetingPointImage     MediaFile?           @relation("LocationMeetingImage", fields: [meetingPointImageId], references: [id], onDelete: SetNull)
  meetingPointImageId   String?
  active                Boolean              @default(true)
  // Business setting: the single "home base" location. At most one row is true —
  // enforced at the API (setting one unsets the previous), matching the
  // PriceList.isDefault convention. Drives a visual-only reminder on the Deal panel
  // when a deal's city differs from home; never affects pricing or any workflow.
  isHomeLocation        Boolean              @default(false)
  sortOrder             Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  variants              ProductVariant[]
  deals                 Deal[]
  quoteOffers           QuoteOffer[]
  // Shared Content Library items anchored to this location. Back-relation only.
  sharedContent         SharedContent[]      @relation("SharedContentAnchor")
  // Location Defaults (source of truth per type; a variant link is an override).
  // Explicit references to Shared Content — no block mutation when chosen. SetNull
  // so deleting the block clears the default. Resolution: variant link → these →
  // legacy columns. Arrival/safety/etc. can be added the same way later.
  defaultMeetingPoint   SharedContent?       @relation("LocationDefaultMeeting", fields: [defaultMeetingPointId], references: [id], onDelete: SetNull)
  defaultMeetingPointId String?
  defaultEndingPoint    SharedContent?       @relation("LocationDefaultEnding", fields: [defaultEndingPointId], references: [id], onDelete: SetNull)
  defaultEndingPointId  String?
  // Quote Image Library items tagged as applicable to this location.
  quoteImageLinks       QuoteImageLocation[]
  tourEvents            TourEvent[]
  openTourTemplates     OpenTourTemplate[]

  @@index([sortOrder])
  @@index([defaultMeetingPointId])
  @@index([defaultEndingPointId])
}

// What we sell. Bilingual name + rich marketing descriptions. No pricing, no
// location/operational data (those live on the variant).
model Product {
  id                String             @id @default(cuid())
  nameHe            String
  nameEn            String?
  marketingDescHe   String? // rich HTML
  marketingDescEn   String? // rich HTML
  active            Boolean            @default(true)
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  variants          ProductVariant[]
  priceRules        PriceRule[]
  deals             Deal[]
  quoteOffers       QuoteOffer[]
  tourEvents        TourEvent[]
  tourScheduleRules TourScheduleRule[]

  @@index([sortOrder])
}

// Product × Location. Owns all product-location detail incl. operational data,
// guide-pay defaults, and per-format availability.
model ProductVariant {
  id                       String                            @id @default(cuid())
  product                  Product                           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId                String
  location                 Location                          @relation(fields: [locationId], references: [id])
  locationId               String
  marketingDescHe          String? // rich HTML
  marketingDescEn          String?
  guideDescHe              String? // internal, rich HTML
  guideDescEn              String? // internal, rich HTML
  durationHours            Float? // numeric source of truth; display derived
  meetingPointHe           String? // rich HTML (long instructions, links, lists)
  meetingPointEn           String? // rich HTML
  endingPointHe            String? // rich HTML
  endingPointEn            String? // rich HTML
  // "אז מה בתוכנית?" — variant-specific programme copy for the quote section of the
  // same name. Title lives in the Quote Template (one source of truth); this is the
  // CONTENT only. NOT Shared Content / Location Defaults / meeting-ending points.
  programHe                String? // rich HTML
  programEn                String? // rich HTML
  meetingPointImage        MediaFile?                        @relation("VariantMeetingImage", fields: [meetingPointImageId], references: [id], onDelete: SetNull)
  meetingPointImageId      String?
  baseGuidePaymentMinor    BigInt                            @default(0)
  travelPaymentMinor       BigInt?
  currency                 String                            @default("ILS")
  // Per-format availability (defaults all true; admin disables manually).
  availablePublic          Boolean                           @default(true)
  availablePrivate         Boolean                           @default(true)
  availableBusiness        Boolean                           @default(true)
  active                   Boolean                           @default(true)
  sortOrder                Int                               @default(0)
  createdAt                DateTime                          @default(now())
  updatedAt                DateTime                          @updatedAt
  galleryImages            ProductVariantImage[]
  priceRules               PriceRule[]
  deals                    Deal[]
  quoteLines               QuoteLine[]
  // Explicit references to Shared Content Library items (meeting point, ending
  // point, …). Content is never copied onto the variant — see ProductVariantSharedContent.
  sharedContentLinks       ProductVariantSharedContent[]
  // Quote Image Library references per quote position (hero | slot1 | slot2).
  quoteImageLinks          ProductVariantQuoteImage[]
  quoteOffers              QuoteOffer[]
  tourEvents               TourEvent[]
  tourScheduleRules        TourScheduleRule[]
  activityComponents       ProductVariantActivityComponent[]
  openTourTemplateProducts OpenTourTemplateProduct[]
  ticketRegistrations      TicketRegistration[]

  @@unique([productId, locationId])
  @@index([productId])
  @@index([locationId])
}

// Ordered quote gallery for a variant (explicit per-owner join, not polymorphic).
// LEGACY (Quote Image Library refactor): no new uploads — the variant editor now
// references QuoteImage library items instead. Kept only because the hero image
// fallback chain still reads galleryImages[0] for variants with no hero pick.
model ProductVariantImage {
  id               String         @id @default(cuid())
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  productVariantId String
  mediaFile        MediaFile      @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  mediaFileId      String
  sortOrder        Int            @default(0)

  @@index([productVariantId])
  @@index([mediaFileId])
}

// ============================================================================
// Quote Image Library — reusable presentation images for quote documents
// ============================================================================
// An image is an independent asset, NOT owned by a Product Variant. Variants
// only REFERENCE library images per quote position (hero | slot1 | slot2) via
// ProductVariantQuoteImage — one image can serve many variants, and replacing
// it in the library updates every quote that references it. Locations are
// organizational metadata for filtering the picker; they never gate rendering.
model QuoteImage {
  id          String    @id @default(cuid())
  mediaFile   MediaFile @relation("QuoteImageMedia", fields: [mediaFileId], references: [id], onDelete: Cascade)
  mediaFileId String
  titleHe     String? // shown as the image caption in the quote (He)
  titleEn     String? // caption (En)
  description String? // internal organization note — never rendered to the customer
  tags        String[]  @default([]) // future metadata; no UI yet
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  locations    QuoteImageLocation[]
  variantLinks ProductVariantQuoteImage[]

  @@index([sortOrder])
}

// Image ↔ Location tagging (multi-select "applicable locations").
model QuoteImageLocation {
  quoteImage   QuoteImage @relation(fields: [quoteImageId], references: [id], onDelete: Cascade)
  quoteImageId String
  location     Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId   String

  @@id([quoteImageId, locationId])
  @@index([locationId])
}

// Variant → library image reference per quote position. Ordered within a
// position (slots may show several images together; hero uses the first).
// Deleting a library image removes its references — the quote just stops
// showing it (the delete UI surfaces usage before confirming).
model ProductVariantQuoteImage {
  id               String         @id @default(cuid())
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  productVariantId String
  quoteImage       QuoteImage     @relation(fields: [quoteImageId], references: [id], onDelete: Cascade)
  quoteImageId     String
  position         String // hero | slot1 | slot2
  sortOrder        Int            @default(0)

  @@unique([productVariantId, position, quoteImageId], map: "PVQuoteImage_variant_position_image_key")
  @@index([productVariantId])
  @@index([quoteImageId])
}

// Seeded: public | private | business. priceModel drives Slice-2 pricing.
model ActivityType {
  id              String           @id @default(cuid())
  key             String           @unique // public | private | business
  nameHe          String
  nameEn          String?
  priceModel      String // per_head | tiered
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  priceRules      PriceRule[]
  pricingSegments PricingSegment[]
}

// Payment terms ⇄ methods with bidirectional optional defaults. The auto-fill on
// the Deal happens in Slice 3.
model PaymentTerm {
  id                     String             @id @default(cuid())
  nameHe                 String
  nameEn                 String?
  defaultPaymentMethod   PaymentMethod?     @relation("TermDefaultMethod", fields: [defaultPaymentMethodId], references: [id], onDelete: SetNull)
  defaultPaymentMethodId String?
  active                 Boolean            @default(true)
  sortOrder              Int                @default(0)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  methodsDefaultingHere  PaymentMethod[]    @relation("MethodDefaultTerm")
  // Org types that point here as their default payment term (back-relation only).
  orgTypeDefaults        OrganizationType[] @relation("OrgTypeDefaultPaymentTerm")
  deals                  Deal[]

  @@index([sortOrder])
}

model PaymentMethod {
  id                   String             @id @default(cuid())
  nameHe               String
  nameEn               String?
  defaultPaymentTerm   PaymentTerm?       @relation("MethodDefaultTerm", fields: [defaultPaymentTermId], references: [id], onDelete: SetNull)
  defaultPaymentTermId String?
  active               Boolean            @default(true)
  sortOrder            Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  termsDefaultingHere  PaymentTerm[]      @relation("TermDefaultMethod")
  // Org types that point here as their override payment method (back-relation).
  orgTypeDefaults      OrganizationType[] @relation("OrgTypeDefaultPaymentMethod")
  deals                Deal[]

  @@index([sortOrder])
}

// ── Products & Pricing — Slice 2: Pricing Engine + Add-ons ──────────────────
// Not yet wired to Deals. No DealLineItem, no Quotes. This is the catalog +
// resolution foundation only.

// A named set of pricing rules. One row is the system default (isDefault), used
// when no organization type/subtype points at a specific list. VAT defaults here
// are inherited by rules that don't override them.
model PriceList {
  id             String   @id @default(cuid())
  nameHe         String
  nameEn         String?
  defaultVatMode String   @default("included") // included | excluded
  defaultVatRate Int      @default(18)
  currency       String   @default("ILS")
  isDefault      Boolean  @default(false) // exactly one system-default list
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rules                 PriceRule[]
  addonPriceRules       AddonPriceRule[]
  orgTypesDefaulting    OrganizationType[]    @relation("OrgTypeDefaultPriceList")
  orgSubtypesDefaulting OrganizationSubtype[] @relation("OrgSubtypeDefaultPriceList")

  @@index([sortOrder])
}

// A single pricing rule inside a PriceList. The four scope fields are optional;
// NULL means "wildcard / matches anything". A rule matches a context when every
// non-null scope equals the context. priceModel selects which price fields are
// used and must match the context ActivityType's priceModel.
model PriceRule {
  id          String    @id @default(cuid())
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  priceListId String

  // Scopes — null = wildcard. Cascade-delete the rule when a scoped target is
  // removed, so a specific rule never silently becomes a broader wildcard.
  product               Product?             @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId             String?
  productVariant        ProductVariant?      @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  productVariantId      String?
  activityType          ActivityType?        @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  activityTypeId        String?
  organizationSubtype   OrganizationSubtype? @relation(fields: [organizationSubtypeId], references: [id], onDelete: Cascade)
  organizationSubtypeId String?

  // Authoring layer (Slice A) — NOT used by resolution. `pricingSegment` tags the
  // rule with the business tab it was created under; `cardGroupId` ties sibling
  // rules (one per chosen location) into a single editable UI "card". The engine
  // ignores both and keeps resolving per scope as before.
  pricingSegment   PricingSegment? @relation(fields: [pricingSegmentId], references: [id], onDelete: SetNull)
  pricingSegmentId String?
  cardGroupId      String?

  priceModel String // per_head | tiered | tiered_group | fixed | ticket_types

  // per_head model fields. (per_person UX reuses per_head with a single price.)
  adultPriceMinor BigInt?
  childPriceMinor BigInt?

  // tiered (single-tier, legacy) model fields.
  basePriceMinor                BigInt?
  baseParticipants              Int?
  // Also the "every participant above the last tier" rate for tiered_group.
  perAdditionalParticipantMinor BigInt?

  // fixed model field — one flat total per group.
  fixedPriceMinor BigInt?

  // tiered_group model — ordered ladder of (uptoParticipants → totalPriceMinor).
  tiers PriceTier[]

  // ticket_types model — a price per TicketType (e.g. מבוגר/ילד). The set of
  // ticket categories is the editable TicketType catalog, NOT hard-coded.
  ticketPrices PriceRuleTicketPrice[]

  // Card-level add-ons. The Addon catalog owns the label/active/order; the price,
  // VAT mode and auto-apply rule live HERE (per card). Duplicated across a card's
  // sibling rules like tiers/ticketPrices; replace-synced on save.
  addons PriceRuleAddon[]

  // VAT override — null inherits the PriceList defaults.
  vatMode String? // included | excluded
  vatRate Int?

  priority                 Int      @default(0)
  // Business capability (card-level, business-driven): when true, this Pricing
  // Card is offered in the Group Ticket Builder. The Pricing Card itself is the
  // SOLE authority for what appears there — the builder NEVER filters by product,
  // city, activity type, segment, or any hardcoded rule. Default false so existing
  // cards stay out until the owner opts a card in. Duplicated across a card's
  // sibling rules (one per location) like cardSortOrder; replace-synced on save.
  availableForGroupTickets Boolean  @default(false)
  // Business-facing display order of the CARD within its tab. Shared across all
  // sibling rules of one cardGroupId. NOT used by the engine — resolution uses
  // `priority`; this only orders how cards render on the Pricing board.
  cardSortOrder            Int      @default(0)
  active                   Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([priceListId])
  @@index([productId])
  @@index([productVariantId])
  @@index([activityTypeId])
  @@index([organizationSubtypeId])
  @@index([pricingSegmentId])
  @@index([cardGroupId])
}

// A single tier row in a tiered_group price rule (model 1: base + tiers + extra
// participant). `uptoParticipants` is the inclusive upper bound for this tier;
// `totalPriceMinor` is the TOTAL group price for a group up to that size (not
// per-person). Tiers are read in `sortOrder` order; beyond the largest tier the
// rule's `perAdditionalParticipantMinor` applies per extra participant. No
// hard-coded count of tiers — the owner adds as many rows as needed.
model PriceTier {
  id               String    @id @default(cuid())
  priceRule        PriceRule @relation(fields: [priceRuleId], references: [id], onDelete: Cascade)
  priceRuleId      String
  uptoParticipants Int
  totalPriceMinor  BigInt
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([priceRuleId])
}

// Editable catalog of ticket categories (e.g. מבוגר / ילד). The SOURCE OF TRUTH
// for ticket-based pricing — adult/child are seed examples, never hard-coded in
// code. A type referenced by any price rule is deactivated, not hard-deleted
// (enforced in the route).
model TicketType {
  id            String                 @id @default(cuid())
  nameHe        String
  nameEn        String?
  descriptionHe String?
  descriptionEn String?
  active        Boolean                @default(true)
  sortOrder     Int                    @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  priceEntries  PriceRuleTicketPrice[]
  // Group-ticket quote lines that froze this ticket type as their structured
  // identity. SetNull on delete (see QuoteLine.ticketType).
  quoteLines    QuoteLine[]

  @@index([sortOrder])
}

// Per-rule price for one ticket type (ticket_types model). One row per
// (priceRule, ticketType). Cascade-deletes with either side.
model PriceRuleTicketPrice {
  id           String     @id @default(cuid())
  priceRule    PriceRule  @relation(fields: [priceRuleId], references: [id], onDelete: Cascade)
  priceRuleId  String
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  ticketTypeId String
  priceMinor   BigInt
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([priceRuleId, ticketTypeId])
  @@index([priceRuleId])
  @@index([ticketTypeId])
}

// The 6 business-facing pricing tabs (קבוצתי / פרטי / עסקי / בית ספר / סוכנים /
// מפיקים). This is an AUTHORING catalog only — it buckets pricing cards into
// tabs. The optional bindings let the owner map a tab to an ActivityType and/or
// OrganizationSubtype from the admin UI (NO hard-coded org mappings). Resolution
// does not read this table; the bindings are applied to a rule's own scope
// fields at authoring time, so the engine is unchanged.
model PricingSegment {
  id                    String               @id @default(cuid())
  key                   String               @unique
  nameHe                String
  nameEn                String?
  sortOrder             Int                  @default(0)
  active                Boolean              @default(true)
  // Owner-set resolution bindings — null until configured in the admin UI.
  activityType          ActivityType?        @relation(fields: [activityTypeId], references: [id], onDelete: SetNull)
  activityTypeId        String?
  organizationSubtype   OrganizationSubtype? @relation(fields: [organizationSubtypeId], references: [id], onDelete: SetNull)
  organizationSubtypeId String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  priceRules            PriceRule[]

  @@index([sortOrder])
}

// A sellable extra that is NOT a Product (e.g. transport, insurance, materials).
// Carries its own default price + VAT behaviour. Per-price-list overrides live
// in AddonPriceRule.
model Addon {
  id                String   @id @default(cuid())
  nameHe            String
  nameEn            String?
  // Stable key for SYSTEM add-ons (e.g. 'sabbath_holiday'). Null for ordinary
  // owner-created add-ons. Logic identifies the system surcharge by THIS key,
  // never by name. This Addon row is the global default (price/VAT/active) every
  // card inherits unless it stores a PriceRuleAddon override.
  systemKey         String?  @unique
  defaultPriceMinor BigInt   @default(0)
  currency          String   @default("ILS")
  // null = "כמו כרטיס התמחור" — the add-on inherits the Pricing Card's VAT.
  // included | excluded | exempt = the add-on fixes its own VAT (overrides card).
  vatMode           String?
  vatRate           Int      @default(18)
  defaultQuantity   Int      @default(1)
  active            Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  priceRules  AddonPriceRule[]
  cardEntries PriceRuleAddon[]
  quoteLines  QuoteLine[]

  @@index([sortOrder])
}

// Per-card add-on configuration (one row per card×addon, duplicated across the
// card's sibling rules). The Addon catalog is the label/active/order source of
// truth; price + VAT + auto-apply are owned HERE, per card.
//   vatMode null  → inherit the card's VAT; else included | excluded | exempt
//   autoApply     → 'manual' (toggled in Deal/Quote) | 'weekdays'
//   autoApplyWeekdays → 0=Sun … 6=Sat (matches JS getDay); e.g. [6] = Saturday.
//                       No weekday is hard-coded — this is owner-entered data.
model PriceRuleAddon {
  id                String    @id @default(cuid())
  priceRule         PriceRule @relation(fields: [priceRuleId], references: [id], onDelete: Cascade)
  priceRuleId       String
  addon             Addon     @relation(fields: [addonId], references: [id], onDelete: Cascade)
  addonId           String
  enabled           Boolean   @default(true)
  // Nullable = INHERIT for that field. For the system add-on, null price/VAT
  // inherits the Addon catalog default (resolved server-side); a concrete value
  // is a per-card override. (For ordinary add-ons the UI always sets a price.)
  priceMinor        BigInt?
  vatMode           String? // null = inherit (catalog default for system; card VAT otherwise)
  vatRate           Int?
  autoApply         String    @default("manual") // manual | weekdays
  autoApplyWeekdays Int[]     @default([])
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([priceRuleId, addonId])
  @@index([priceRuleId])
  @@index([addonId])
}

// Per-price-list override of an Addon's price / VAT. priceListId NULL = a global
// override applied regardless of the resolved price list.
model AddonPriceRule {
  id          String     @id @default(cuid())
  addon       Addon      @relation(fields: [addonId], references: [id], onDelete: Cascade)
  addonId     String
  priceList   PriceList? @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  priceListId String?
  priceMinor  BigInt     @default(0)
  currency    String     @default("ILS")
  vatMode     String     @default("included") // included | excluded
  vatRate     Int        @default(18)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([addonId])
  @@index([priceListId])
}

// ── CRM Settings — Lost Reasons & Quote Content (catalog only) ───────────────
// Reusable, admin-managed reference data. NOT yet wired to Deals or to quote
// generation — this is content/config the future deal-loss and quote-template
// flows will read. Additive only.

// Reasons a Deal was lost. Reusable picklist. Not wired to Deal.status yet.
model LostReason {
  id        String   @id @default(cuid())
  nameHe    String
  nameEn    String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Deals that selected this reason. SetNull on delete (see Deal.lostReasonRef)
  // so removing a catalog reason nulls the link rather than deleting deals.
  deals     Deal[]

  @@index([sortOrder])
}

// How a lead/deal arrived (admin-managed picklist used by the Create Deal flow):
// e.g. Facebook, website, referral, conference. Drag-orderable; `active` retires
// a source without deleting history. SetNull on delete (see Deal.dealSource).
model DealSource {
  id        String   @id @default(cuid())
  label     String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deals     Deal[]

  @@index([sortOrder])
}

// ── Timeline (reusable activity feed) ──────────────────────────────────────
// A single polymorphic "spine": every timeline item (V1 = note; later activity /
// email / whatsapp / file / system event) is one TimelineEntry, scoped to ANY
// subject via (subjectType, subjectId). There is intentionally NO database FK on
// the subject — integrity is enforced at the API (the same loose-key approach as
// FlowAnswer.stepId / ownerUserId). This is exactly what lets the SAME timeline
// component+feed attach to Deals, Contacts, Organizations and future entities
// with zero schema change. Light/variable payload lives in `data` (JSON); a heavy
// future type can get a 1:1 companion table keyed by id without touching the feed.
model TimelineEntry {
  id            String            @id @default(cuid())
  subjectType   String // 'deal' | 'contact' | 'organization' | future…
  subjectId     String
  kind          String            @default("note") // 'note' (V1) | future kinds
  body          String? // rich HTML for notes; optional text on other kinds
  data          Json? // kind-specific light payload, e.g. { origin: 'inquiry' }
  isPinned      Boolean           @default(false)
  pinSortOrder  Int               @default(0) // manual FOCUS order, scoped to the subject
  isSystem      Boolean           @default(false) // system events: not user-editable
  // Origin — every entry has an explicit, NON-anonymous source:
  //   'user'       → a logged-in admin (createdBy + createdByName set)
  //   'api'        → an external integration  (actorLabel, e.g. "API: ייבוא לידים")
  //   'automation' → a CRM rule / flow        (actorLabel, e.g. "אוטומציה: WhatsApp")
  //   'system'     → GOS itself               (actorLabel, e.g. "דיל נוצר")
  //   'import'     → a migration / import      (actorLabel, e.g. "ייבוא נתונים")
  // For non-'user' origins createdBy/createdByName are null and actorLabel names
  // the source. The API forbids an entry with neither a user nor an actorLabel.
  actorType     String            @default("user")
  actorLabel    String? // human-readable source label for non-'user' origins
  // Author attribution for the 'user' origin. createdBy = AdminUser.id (canonical
  // identity, ready for a future User model); createdByName = a username snapshot
  // so the feed renders the author with no join and survives rename/deactivation.
  createdBy     String?
  createdByName String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  editedAt      DateTime? // set on CONTENT edits (distinct from pin/reorder)
  deletedAt     DateTime? // soft delete (keeps history honest)
  comments      TimelineComment[]

  @@index([subjectType, subjectId, createdAt])
  @@index([subjectType, subjectId, isPinned, pinSortOrder])
}

// A comment ALWAYS belongs to exactly one entry (real FK + cascade — not
// polymorphic). Rendered white, nested under the (yellow) note. Future reactions
// can hang off this model.
model TimelineComment {
  id            String        @id @default(cuid())
  entry         TimelineEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId       String
  body          String
  // Same explicit-origin model as TimelineEntry (a comment may also come from a
  // user, an automation, etc.). Never anonymous.
  actorType     String        @default("user")
  actorLabel    String?
  createdBy     String? // AdminUser.id (canonical identity)
  createdByName String? // author username snapshot (see TimelineEntry)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  @@index([entryId, createdAt])
}

// Reusable fixed content sections for future quote templates. Rich HTML, He/En.
// Stored as content only — quote generation is not built yet.
model QuoteSection {
  id         String   @id @default(cuid())
  titleHe    String
  titleEn    String?
  richTextHe String? // HTML from the shared RichEditor
  richTextEn String? // HTML from the shared RichEditor
  // Library classification so content is structured, not an unstructured pile.
  // Validated at the API (no Postgres enum): faq | cancellation |
  // participant_policy | why_us | marketing | terms | custom.
  category   String?
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sortOrder])
}

// ============================================================================
// Quote Layout Template — the GLOBAL default quote composition (control center)
// ============================================================================
//
// Single-row settings record (enforced by the unique `singleton`). Holds the
// default quote LAYOUT as one flexible JSON blob so the screen can grow (hero,
// sections order/visibility, technical-detail fields today; colors, fonts, PDF
// later) without a migration per option. This is the DEFAULT SEED only: a
// per-quote QuoteDocument.compositionDraft still overrides section order/hidden
// for that one quote. Code (DEFAULT_QUOTE_BLOCKS) is the final fallback when no
// row exists, so behaviour is unchanged until an admin saves here.
model QuoteTemplate {
  id        String   @id @default(cuid())
  singleton String   @unique @default("global") // exactly one row
  layout    Json? // { hero, sections:[{key,hidden}], technical:{fields:[{key,visible}]} }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// שעות שבת וחג — Sabbath & Holiday hours (source of truth for time detection)
// ============================================================================
//
// Defines WHEN a date/time counts as שבת / חג / ערב חג. Two shapes feeding one
// detector: recurring weekly windows + dated holiday rows (imported or manual,
// with a review/approval workflow). NOT wired to pricing yet — a later slice
// switches PriceRuleAddon.autoApply='sabbath_holiday' to read these rules. No
// holiday date is hard-coded in code; weekly times are owner-entered, holidays
// come from the import source (Hebcal). Money/Deals/Quotes untouched.

// Recurring weekly window, e.g. "כניסת שבת — שישי מ-15:00", "שבת — כל היום".
// Times are minutes-from-midnight (Israel local wall-clock); null start = open,
// null end = until end of day. allDay covers the whole day.
model SabbathWeeklyRule {
  id          String   @id @default(cuid())
  nameHe      String
  nameEn      String?
  dayOfWeek   Int // 0=Sun … 6=Sat (matches JS getDay)
  allDay      Boolean  @default(false)
  startMinute Int? // 0..1439
  endMinute   Int?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

// One reviewable holiday row per date. `source`/`externalId` dedupe imports;
// `manuallyEdited` + `status='approved'` LOCK a row from being overwritten by a
// re-import (only the sourceName/sourceDate mirror refreshes, for change
// detection). Only `approved` + `active` rows will later affect pricing.
model HolidayRule {
  id             String    @id @default(cuid())
  nameHe         String
  nameEn         String?
  date           DateTime  @db.Date
  allDay         Boolean   @default(true)
  startMinute    Int? // ערב חג start (minutes from midnight, Israel local)
  endMinute      Int?
  type           String    @default("chag") // 'erev_chag' | 'chag' | 'other'
  source         String    @default("imported") // 'imported' | 'manual'
  status         String    @default("pending") // 'pending' | 'approved' | 'ignored'
  active         Boolean   @default(true)
  externalId     String? // stable key from the import source (dedupe)
  manuallyEdited Boolean   @default(false)
  reviewedAt     DateTime?
  reviewedBy     String? // loose actor id (no User model yet)
  sourceName     String? // raw source mirror — to flag "source changed since approval"
  sourceDate     DateTime? @db.Date
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([source, externalId])
  @@index([date])
  @@index([status])
}

// Reviewed classification for a recurring holiday, applied to FUTURE imports.
// When the owner marks a holiday as חג/ערב חג (or edits its type/times), we store
// the decision keyed by the source's stable name (year-independent), so next
// year's imported instance inherits the same type + times automatically. Pending
// rows only; approved/manuallyEdited rows are never overwritten.
model HolidayClassificationRule {
  id                   String   @id @default(cuid())
  source               String // matches HolidayRule.source ('imported')
  normalizedHolidayKey String // stable, year-independent (Hebcal title)
  defaultType          String // 'chag' | 'erev_chag' | 'other'
  defaultStartMinute   Int?
  defaultEndMinute     Int?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([source, normalizedHolidayKey])
}

// ============================================================================
// Calendar Markers — operational/informational date markers (NOT pricing)
// ============================================================================
//
// A SECOND, independent dimension alongside the pricing classification
// (SabbathWeeklyRule + HolidayRule.type). Markers are display/operational only
// (Chol HaMoed, school vacations, election day, municipal events, high-demand
// periods, …) and are NEVER read by the pricing engine or the preview route.
// New marker kinds need NO schema change — they are CalendarMarkerType rows.

// The extensible catalog of marker kinds. `source='system'` marks types the
// import depends on (e.g. chol_hamoed) — not hard-deletable.
model CalendarMarkerType {
  id        String           @id @default(cuid())
  key       String           @unique
  nameHe    String
  nameEn    String?
  color     String? // hex/token for Gantt/calendar display
  active    Boolean          @default(true)
  sortOrder Int              @default(0)
  source    String           @default("manual") // 'system' | 'manual'
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  markers   CalendarMarker[]

  @@index([sortOrder])
}

// A dated marker instance. A date RANGE (start..end) covers a single day
// (start==end), a multi-day Chol HaMoed, or a multi-week vacation in one row.
// `source`/`externalId` make the Hebcal import idempotent. Independent of
// HolidayRule (markers also apply to non-holiday dates).
model CalendarMarker {
  id           String             @id @default(cuid())
  markerType   CalendarMarkerType @relation(fields: [markerTypeId], references: [id], onDelete: Cascade)
  markerTypeId String
  startDate    DateTime           @db.Date
  endDate      DateTime           @db.Date
  nameHe       String? // optional label override (else the type name is used)
  note         String?
  source       String             @default("manual") // 'imported' | 'manual'
  externalId   String?
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([source, externalId])
  @@index([startDate])
  @@index([endDate])
  @@index([markerTypeId])
}

// ============================================================================
// Quote Module — Slice 1 (Quote document foundation)
// ============================================================================
//
// QuoteDocument is the DRAFT/PRODUCED composed proposal (Architecture B; see
// docs/architecture/GOS-quote-module-architecture.md §7B). It belongs to a Deal
// and references the priced QuoteVersion it renders. The renderer, public page,
// signature, PDF and delivery are NOT built in this slice — only the storage
// shape + a minimal draft service. No prices live here: the Pricing block reads
// QuoteVersion/QuoteLine (the Builder is the single source of commercial data).
//
// Three JSON shapes (renderer not built yet):
//   * compositionDraft     — ordered block list (structure: order, hidden, ad-hoc)
//   * overrideState        — per-block/field presentation overrides + overridden flags
//   * renderModelSnapshot  — frozen, fully-resolved render-model (null until produced)
// displayProductName is the ONE quote-level product-name override (display-only;
// never mutates Deal/product/Builder).
model QuoteDocument {
  id                  String                @id @default(cuid())
  deal                Deal                  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId              String
  // The priced version this document renders. Cascade with the deal; a produced
  // document's content survives independently inside renderModelSnapshot.
  quoteVersion        QuoteVersion          @relation(fields: [quoteVersionId], references: [id], onDelete: Cascade)
  quoteVersionId      String
  // The offer (commercial path) this document belongs to. Backfilled to offer #1
  // for legacy rows. versionNo is the customer-facing version WITHIN the offer
  // (v1, v2 …) — null while draft, assigned when the document is produced. The
  // newest produced versionNo per offer is the live one; older unsigned versions
  // are superseded (public URL shows the "newer proposal available" screen).
  offer               QuoteOffer?           @relation(fields: [offerId], references: [id], onDelete: SetNull)
  offerId             String?
  versionNo           Int?
  status              String                @default("draft") // draft | produced | accepted | rejected | expired
  // Resolved automatically from the relevant Contact.communicationLanguage at
  // create time (role priority: payer -> decisionMaker -> coordinator -> isPrimary),
  // falling back to the Deal's working language, then Hebrew. Admin-overridable.
  language            String                @default("he") // he | en
  // High-entropy capability token for the (future) public quote page. Present
  // now; no public route consumes it yet.
  publicToken         String                @unique
  expiresAt           DateTime?
  producedAt          DateTime?
  // Preview / Override layer (presentation-only; never writes back to source).
  displayProductName  String?
  // Draft + snapshot storage (renderer NOT built yet).
  compositionDraft    Json?
  overrideState       Json?
  renderModelSnapshot Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  renders             QuoteDocumentRender[]
  signature           QuoteSignature?

  @@unique([offerId, versionNo]) // no two produced versions share a number (drafts: versionNo null)
  @@index([dealId])
  @@index([quoteVersionId])
  @@index([offerId])
  @@index([status])
}

// The permanent audit record of a customer signing a proposal. Exactly ONE per
// QuoteDocument (the unique quoteDocumentId is the lock — a signed document can
// never be signed again; a change requires a NEW QuoteDocument revision). The
// signature is NEVER stored inside the quote HTML. `method` is the single source
// of truth for how it was signed (typed | uploaded | drawn) — no parallel boolean
// columns. For typed, signerName renders the signature; for uploaded/drawn,
// signatureImage holds the PNG as a data URL (public signing has no admin R2 path).
model QuoteSignature {
  id              String        @id @default(cuid())
  quoteDocument   QuoteDocument @relation(fields: [quoteDocumentId], references: [id], onDelete: Cascade)
  quoteDocumentId String        @unique
  quoteVersionId  String // the priced QuoteVersion that was signed (audit)
  method          String // typed | uploaded | drawn
  signerName      String
  signatureImage  String? // data URL (image/png) for uploaded/drawn; null for typed
  signedAt        DateTime      @default(now())
  ipAddress       String?
  userAgent       String?
  language        String        @default("he") // he | en (the language the customer saw)
  timezone        String? // IANA tz reported by the browser
  createdBy       String? // actor id if an admin signed on behalf; null for the customer
  createdAt       DateTime      @default(now())

  @@index([quoteDocumentId])
}

// Append-only record of each rendered artifact (HTML/PDF) for a QuoteDocument.
// The artifact bytes live in R2 via MediaFile (no duplicate r2Key/url here — the
// file platform is the single source for object storage). No renders are created
// in this slice; this is storage shape only.
model QuoteDocumentRender {
  id              String        @id @default(cuid())
  quoteDocument   QuoteDocument @relation(fields: [quoteDocumentId], references: [id], onDelete: Cascade)
  quoteDocumentId String
  format          String // html | pdf
  contentHash     String?
  rendererVersion String        @default("v1")
  mediaFile       MediaFile?    @relation(fields: [mediaFileId], references: [id], onDelete: SetNull)
  mediaFileId     String?
  byteSize        Int?
  generatedAt     DateTime      @default(now())

  @@index([quoteDocumentId])
  @@index([mediaFileId])
}

// ============================================================================
// Shared Content Library — platform-wide reusable content (Slice 1: foundation)
// ============================================================================
//
// SINGLE SOURCE OF TRUTH for reusable content that many consumers reference
// instead of duplicating. First consumer = Product Variants (meeting point,
// ending point, …); designed to grow into a platform-wide library (any future
// entity can reference the same rows through its own explicit join table).
//
// Design mirrors patterns ALREADY proven in this project:
//   * QuoteSection  — bilingual rich HTML classified by a validated string
//   * ContentItem   — reusable content referenced by many consumers by id
//   * ProductVariantImage — explicit per-owner join (NOT polymorphic)
//
// Locked principles (see docs/architecture/GOS-quote-content-model.md + audit):
//   * Explicit references, never copying. Editing a row updates every linked
//     DRAFT consumer automatically (they read it by reference).
//   * Produced quotes stay frozen forever via QuoteDocument.renderModelSnapshot —
//     they never re-read SharedContent.
//   * "Update only this variant" = FORK (clone into a new row + repoint the link),
//     never a silent copy. There is NO background synchronization.
//
// `type` is validated at the API against src/shared-content/sharedContentTypes.js
// (no Postgres enum — project convention). `isLocationDefault` marks the row a
// location's default for its (location, type): the fallback used when a variant
// has no explicit link (making today's silent meeting-point fallback EXPLICIT and
// reference-counted). `updatedById` is a loose actor id (no User model yet, same
// as MediaFile.uploadedById / HolidayRule.reviewedBy). `active=false` = archived.
model SharedContent {
  id                     String                        @id @default(cuid())
  type                   String // meeting_point | ending_point | arrival_instructions | walking_notes | safety | map | custom
  internalName           String // admin-facing library name (never shown to customers)
  description            String? // optional internal note
  bodyHe                 String? // rich HTML (shared RichEditor)
  bodyEn                 String? // rich HTML
  image                  MediaFile?                    @relation(fields: [imageId], references: [id], onDelete: SetNull)
  imageId                String?
  mapUrl                 String? // reserved (embedded map); not rendered in V1
  location               Location?                     @relation("SharedContentAnchor", fields: [locationId], references: [id], onDelete: SetNull)
  locationId             String?
  // DEPRECATED (kept, not removed): the Slice-2 location-default flag. Location
  // defaults now live as explicit FKs on Location (defaultMeetingPointId / …),
  // migrated from this flag. Resolution no longer reads it.
  isLocationDefault      Boolean                       @default(false)
  active                 Boolean                       @default(true)
  sortOrder              Int                           @default(0)
  updatedById            String? // loose actor id (no User model yet)
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  variantLinks           ProductVariantSharedContent[]
  // Locations that reference this block as their default (back-relations).
  locationDefaultMeeting Location[]                    @relation("LocationDefaultMeeting")
  locationDefaultEnding  Location[]                    @relation("LocationDefaultEnding")

  @@index([type])
  @@index([locationId])
  @@index([locationId, type])
  @@index([active, sortOrder])
}

// Explicit reference: a Product Variant uses a Shared Content row. Mirrors
// ProductVariantImage. The block's `type` lives on SharedContent, not here, so
// resolution is "the linked row whose type = X". onDelete:
//   * productVariant → Cascade (deleting a variant drops its links)
//   * sharedContent  → Restrict (a referenced row is NOT silently deletable;
//     deletion is a deliberate library operation guarded by "where used")
// V1 enforces at-most-one link per single-cardinality type at the API layer.
model ProductVariantSharedContent {
  id               String         @id @default(cuid())
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  productVariantId String
  sharedContent    SharedContent  @relation(fields: [sharedContentId], references: [id], onDelete: Restrict)
  sharedContentId  String
  sortOrder        Int            @default(0)

  @@unique([productVariantId, sharedContentId])
  @@index([productVariantId])
  @@index([sharedContentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Tour Content domain (Phase 1a — foundation)
//
// GOS is the source of truth for internal tour content (trainees + guides).
// Shape: Tour → Station → ordered Step → (reference) → ContentBlock → BlockAsset.
// Media lives in R2 via MediaFile (never DB binary). See
// docs/architecture/phase1-tour-content-domain.md for the full design.
//
// Deferred to later phases (NOT in this migration): station-level access
// (TourStationAccess, Phase 2) and quiet block versioning
// (TourContentBlockVersion). No recruitment data is migrated here.
//
// `sourceRef` (unique) preserves the recruitment source id for the future,
// idempotent, re-runnable ETL — unused at runtime in Phase 1a.
// ─────────────────────────────────────────────────────────────────────────────

model Tour {
  id            String        @id @default(cuid())
  sourceRef     String?       @unique // "tour:<recruitment.id>" (migration only)
  titleHe       String
  descriptionHe String?
  active        Boolean       @default(true)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  stations      TourStation[]
}

model TourStation {
  id             String     @id @default(cuid())
  sourceRef      String?    @unique // "station:<recruitment.id>" (migration only)
  tour           Tour       @relation(fields: [tourId], references: [id], onDelete: Cascade)
  tourId         String
  titleHe        String
  descriptionHe  String?
  // A stop is not always physical: location | artwork | printed_material | content_stop.
  kind           String     @default("location")
  // Hero image → R2/MediaFile (never DB binary). SetNull so removing a file
  // never deletes the station.
  heroImage      MediaFile? @relation("TourStationHero", fields: [heroImageId], references: [id], onDelete: SetNull)
  heroImageId    String?
  heroImageTitle String?
  // Optional future link to a GOS Location (decision 18) — unused in V1, no FK yet.
  locationId     String?
  active         Boolean    @default(true)
  sortOrder      Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  steps       TourStep[]
  notes       TourStationNote[]
  guideAccess GuideStationAccess[]

  @@index([tourId, sortOrder])
}

// The reusable unit. Stored once; referenced by many steps across stations/tours.
// Editing it updates every placement (by reference, never copied). `shared=false`
// = one-off/inline block (hidden from the reuse picker); `shared=true` = library.
model TourContentBlock {
  id           String   @id @default(cuid())
  sourceRef    String?  @unique
  titleHe      String?
  bodyHe       String   @default("") // rich HTML; inline images via R2 public URLs
  internalNote String?
  shared       Boolean  @default(false)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assets     TourBlockAsset[]
  placements TourStep[]
}

// The ordered placement of a content block into a station. The step order IS the
// presentation order (no separate ordering table). Restrict on the block relation
// prevents deleting a block that is still placed somewhere.
model TourStep {
  id             String           @id @default(cuid())
  station        TourStation      @relation(fields: [stationId], references: [id], onDelete: Cascade)
  stationId      String
  contentBlock   TourContentBlock @relation(fields: [contentBlockId], references: [id], onDelete: Restrict)
  contentBlockId String
  sortOrder      Int              @default(0)
  isVisible      Boolean          @default(true)
  // Optional label carried from recruitment parts (build_up etc.). Not a constraint.
  roleHint       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([stationId, sortOrder])
}

// Media/attachments on a content block. Stable external links (YouTube/Vimeo/Drive)
// stay as `url`; re-hosted binaries reference R2/MediaFile via `mediaId`.
// API invariant: exactly one of `url` / `mediaId` is present.
model TourBlockAsset {
  id             String           @id @default(cuid())
  sourceRef      String?          @unique
  contentBlock   TourContentBlock @relation(fields: [contentBlockId], references: [id], onDelete: Cascade)
  contentBlockId String
  assetType      String // video | image | file | link
  language       String? // he | en | null (he-only in V1; field kept for future)
  titleHe        String
  url            String?
  media          MediaFile?       @relation("TourBlockAssetMedia", fields: [mediaId], references: [id], onDelete: SetNull)
  mediaId        String?
  sortOrder      Int              @default(0)
  active         Boolean          @default(true)

  @@index([contentBlockId, sortOrder])
}

// Admin/curator annotations on a station. Never shown to the learner.
model TourStationNote {
  id        String      @id @default(cuid())
  station   TourStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  stationId String
  contentHe String      @default("")
  sortOrder Int         @default(0)

  @@index([stationId, sortOrder])
}

// ── Email module (Gmail integration) ─────────────────────────────────────────
// GOS mirrors Gmail READ-ONLY (scope gmail.readonly + gmail.send): it never
// archives/labels/deletes or marks read in the mailbox. Gmail is the transport;
// GOS owns the CRM truth — which Contact/Deal a thread belongs to, GOS-side
// read state, engagement data. Tokens are AES-256-GCM encrypted with the
// EMAIL_TOKEN_KEY env secret (see src/email/tokenCrypto.js) — never plaintext.

// One connected Gmail mailbox (business account, Workspace "internal" OAuth app).
model EmailAccount {
  id                   String         @id @default(cuid())
  provider             String         @default("gmail")
  emailAddress         String         @unique
  displayName          String?
  googleAccountId      String? // Google `sub` claim — stable across email renames
  accessTokenEnc       String? // encrypted, short-lived
  accessTokenExpiresAt DateTime?
  refreshTokenEnc      String? // encrypted; null = disconnected (must reconnect)
  scopes               String? // space-separated granted scopes snapshot
  // idle | syncing | error | disconnected — worker status surface for the UI.
  syncStatus           String         @default("idle")
  syncError            String?
  lastSyncAt           DateTime?
  // Gmail incremental cursor (users.history.list). Null until backfill completes.
  historyId            String?
  backfillDone         Boolean        @default(false)
  isActive             Boolean        @default(true)
  connectedById        String? // AdminUser.id (loose key, same convention as tasks)
  // Per-account email signature (sanitized rich HTML) — appended by the composer.
  signature            String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  threads              EmailThread[]
  messages             EmailMessage[]

  @@index([isActive])
}

// A Gmail conversation mirrored into the CRM. CRM linking lives HERE (thread
// level, like WhatsAppChat.contactId): contact by address match or manual;
// deal auto-linked ONLY when exactly one safe candidate exists, else manual.
model EmailThread {
  id                String         @id @default(cuid())
  account           EmailAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId         String
  gmailThreadId     String
  subject           String?
  normalizedSubject String? // Re:/Fwd:-stripped, for grouping/search
  // Counterparties [{ email, name }] — never includes the account's own address.
  participants      Json?
  snippet           String?
  lastMessageAt     DateTime?
  messageCount      Int            @default(0)
  // GOS-side unread state ONLY — never written back to Gmail. Sourced from
  // Gmail's UNREAD label; cleared by GOS reads (lastReadAt cutoff) OR by Gmail
  // reads (labelRemoved:UNREAD history event).
  unreadCount       Int            @default(0)
  lastReadAt        DateTime?
  // Manual "סמן כלא נקרא" (GOS-side only — the mailbox is never written).
  // Display flag like WhatsApp's manual unread: renders bold/dot but never
  // inflates the honest Gmail-matching unread count. Cleared on read.
  manualUnread      Boolean        @default(false)
  // ACTIVE-INBOX membership — true while ANY live message carries Gmail's
  // INBOX label. Archiving/deleting in Gmail drops the thread from the GOS
  // active inbox (the mirror row stays — CRM history never loses data).
  inInbox           Boolean        @default(true)
  contact           Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId         String?
  matchSource       String? // 'email' | 'manual' (auto-match only on exact single hit)
  linkedDeal        Deal?          @relation(fields: [linkedDealId], references: [id], onDelete: SetNull)
  linkedDealId      String?
  linkSource        String? // 'auto' | 'manual'
  pinnedAt          DateTime?
  snoozedUntil      DateTime?
  snoozedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  messages          EmailMessage[]

  @@unique([accountId, gmailThreadId])
  @@index([accountId, lastMessageAt])
  @@index([accountId, inInbox, lastMessageAt])
  @@index([contactId])
  @@index([linkedDealId])
}

// One email message (mirrored inbound/synced or GOS-sent outbound). bodyHtml is
// sanitized server-side AT INGEST (sanitize-html) and additionally rendered in
// a sandboxed iframe client-side. Duplicate Gmail events are idempotent via
// @@unique([accountId, gmailMessageId]).
model EmailMessage {
  id                String            @id @default(cuid())
  account           EmailAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId         String
  thread            EmailThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId          String
  gmailMessageId    String
  messageIdHeader   String? // RFC 822 Message-ID — reply threading
  inReplyTo         String?
  referencesHeader  String?
  direction         String // 'inbound' | 'outbound'
  fromEmail         String?
  fromName          String?
  toRecipients      Json? // [{ email, name }]
  ccRecipients      Json?
  bccRecipients     Json? // outbound-only (Gmail doesn't expose inbound BCC)
  subject           String?
  snippet           String?
  bodyText          String?
  bodyHtml          String? // sanitized
  sentAt            DateTime? // Gmail internalDate
  hasAttachments    Boolean           @default(false)
  // Gmail labels snapshot (["INBOX","UNREAD",…]) — kept current by the history
  // sync (labelAdded/labelRemoved). Null on rows mirrored before this column
  // existed; the worker's reconcile pass backfills those.
  labelIds          Json?
  // Stamped when Gmail reports the message deleted (history messageDeleted /
  // reconcile 404). Row is KEPT (CRM history); active views exclude it.
  providerDeletedAt DateTime?
  createdByUserId   String? // AdminUser.id when sent from GOS (loose key)
  // Open-tracking pixel token for GOS-sent messages (unguessable, public URL).
  trackingId        String?           @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  attachments       EmailAttachment[]
  engagement        EmailEngagement?

  @@unique([accountId, gmailMessageId])
  @@index([threadId, sentAt])
  @@index([accountId, sentAt])
}

// Attachment metadata captured at ingest; bytes stay in Gmail (it retains them,
// unlike WhatsApp media) and are cached into PRIVATE R2 on first download —
// after which r2Key is set and downloads mint short-lived presigned GETs
// (same contract as DealFile: no public URLs, ever).
model EmailAttachment {
  id                String       @id @default(cuid())
  message           EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId         String
  gmailAttachmentId String? // fetch-on-demand handle (may rotate; refetched by part)
  partId            String? // MIME part id inside the message
  // RFC 2392 Content-ID (angle brackets stripped) — inline images reference it
  // via cid: URLs in the HTML body; the thread view resolves those to presigned
  // downloads at render time.
  contentId         String?
  fileName          String
  mimeType          String?
  sizeBytes         Int?
  r2Key             String? // set once cached in R2
  bucket            String?
  createdAt         DateTime     @default(now())

  @@index([messageId])
}

// Engagement for GOS-sent messages (tracking pixel). Honest-by-design: opens
// are best-effort signals (Gmail proxy / Apple MPP / blockers distort them).
// Click columns exist now so link tracking can land later without a migration.
model EmailEngagement {
  id            String       @id @default(cuid())
  message       EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId     String       @unique
  openCount     Int          @default(0)
  firstOpenedAt DateTime?
  lastOpenedAt  DateTime?
  clickCount    Int          @default(0)
  lastClickedAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ============================================================================
// Tours operational module — TourEvent, Booking
// ============================================================================
// TourEvent is the OPERATIONAL execution instance ("סיור"). It is a different
// domain from the Tour/TourStation/… CONTENT models above (training/route
// content) — those are intentionally untouched. The Deal stays the commercial
// entity; the ONLY Deal↔TourEvent relationship is the Booking join. Never add
// a direct FK between Deal and TourEvent in either direction.

// kind: 'private' | 'business' — created automatically on the deal's first WON
//       transition (no draft state: creation is refused while required deal
//       fields are missing);
//       'group_slot' — scheduled ahead of time (a Tour Slot); deals join it
//       later via Bookings, and it is NEVER auto-cancelled when empty.
// Scheduling uses the SAME string conventions as the Deal working fields
// (date "YYYY-MM-DD", startTime "HH:MM") — tours are single-day by product
// decision, and the Deal↔TourEvent field sync stays type-identical.
// Catalog FKs are nullable ONLY so catalog deletes never destroy tour history
// (SetNull convention); required-ness is enforced at the API by the
// declarative field config in src/tours/requiredFields.js.
// status: cancellation is a STATUS, never a delete. Deleting a TourEvent is
// allowed only while it has no Bookings at all (DB-enforced via Restrict).
model TourEvent {
  id                      String          @id @default(cuid())
  kind                    String // 'private' | 'business' | 'group_slot'
  status                  String          @default("scheduled") // scheduled | completed | cancelled | postponed
  // Explicit business completion (tours/completion.js is the ONE transition):
  // when + why the tour completed. completedAt drives the tour summary's
  // post-completion edit window. reason: summaries | midnight | manual.
  completedAt             DateTime?
  completedReason         String?
  // date/startTime are null ONLY while status='postponed' (the tour is not
  // happening as scheduled and no replacement date was chosen yet — the SAME
  // TourEvent keeps its team/components/notes/gallery and returns to
  // 'scheduled' when the Deal applies a new date). Scheduled/completed/
  // cancelled tours always carry both (group slots gate on required fields;
  // deal tours are validated at WON).
  date                    String? // "YYYY-MM-DD"
  startTime               String? // "HH:MM"
  product                 Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId               String?
  productVariant          ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  productVariantId        String?
  location                Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationId              String?
  tourLanguage            String? // he | en | es | fr | ru (same vocabulary as Deal.tourLanguage)
  // Soft ceiling for group slots (warnings only — the operator may explicitly
  // overbook; never a DB constraint). Null for private/business tours.
  capacity                Int?
  // Operational notes — owned by the TourEvent (execution layer), unrelated to
  // the Deal's commercial notes.
  notes                   String?
  // Loose ref to the future auto-generation rule that minted this slot (no FK —
  // rules are config). Together with `date` it makes generation idempotent.
  // For Open Tours this holds the OpenTourScheduleRule id (or a synthetic id for
  // one-off `add` exceptions); openTourTemplateId records the parent template.
  generatedByRuleId       String?
  // Loose ref (no FK — templates are config) to the OpenTourTemplate that minted
  // this slot. Null for legacy/manual slots and deal tours.
  openTourTemplateId      String?
  // When true the operator manually pinned this slot's operational product and
  // the registration-driven derivation must NOT overwrite productVariantId /
  // activity components. Cleared when the manual override is removed.
  productManualOverride   Boolean         @default(false)
  cancelledAt             DateTime?
  // Loose ref (no FK) to the TourEvent that superseded this row. Set ONLY on
  // proven erroneous replacement duplicates (historical reopen→re-WON twins —
  // the 2026-07 lifecycle bug). Superseded rows are HIDDEN from every list/
  // calendar view (even under the בוטל filter: they are not genuine business
  // cancellations) and are never reactivation candidates. Going forward,
  // re-WON REACTIVATES the deal's auto-cancelled tour instead of creating a
  // twin, so this stays a historical/backstop marker.
  supersededByTourEventId String?
  // ── Google Calendar mirror (sync TARGET only — TourEvent stays the SSOT) ──
  // One Google event per tour, owned by the org account (loose ref to the
  // EmailAccount that created it — updates/deletes must use the same account).
  // gcalSyncStatus: null = never considered (past/cancelled before the feature)
  // | 'pending' (dirty — the sync worker reconciles) | 'synced' | 'failed'
  // (retries exhausted; any later mutation re-marks pending). The worker
  // derives the ENTIRE desired event state from this row at sync time — no
  // scheduling data is ever duplicated here beyond the event identity.
  gcalEventId             String?
  gcalAccountId           String?
  gcalSyncStatus          String?
  gcalSyncError           String?
  // Non-fatal sync warnings (e.g. assigned guides without an email) — the rest
  // of the tour still syncs; surfaced in the Tour modal status tooltip.
  gcalSyncWarning         String?
  gcalSyncedAt            DateTime?
  gcalAttempts            Int             @default(0)
  gcalNextRetryAt         DateTime?
  // Field-ownership baselines for PRESENTATION fields (title/description/
  // color): the value GOS last wrote to Google. While Google's current value
  // equals this baseline the field is GOS-owned and follows the derived
  // default; a divergent value is a manual edit made in Google Calendar and is
  // preserved (operational fields — times/attendees/location — always sync).
  // NOT a second source of truth for the tour: purely write-echo bookkeeping.
  gcalLastSummary         String?
  gcalLastDescription     String?
  gcalLastColorId         String?
  // ── WooCommerce mirror (sync TARGET only — TourEvent stays the SSOT) ──
  // GOS generates concrete TourEvents; the Woo sync worker mirrors each sellable
  // occurrence to a WooCommerce Variation. Same dirty-flag reconciler contract
  // as gcal: null = never considered | 'pending' (reconcile) | 'synced' |
  // 'failed' (retries exhausted) | 'skipped' (no mapped sellable card). The
  // per-variation identity + ids live on WooVariationLink; this is only the
  // per-tour outbox flag. Order ingestion (Woo→GOS) is a separate later slice.
  wooSyncStatus           String?
  wooSyncError            String?
  wooSyncedAt             DateTime?
  wooAttempts             Int             @default(0)
  wooNextRetryAt          DateTime?
  // Provenance of the LAST dirty-mark: 'explicit' (sync-one action) | 'bulk'
  // (backfill sweep / mapping-wide resync) | 'auto' (single-tour mutation) |
  // 'maintenance' (repair job). The worker consults it for the first-publication
  // gate: a never-linked occurrence may only be CREATED on Woo when bulk sync is
  // enabled or the occurrence was explicitly requested.
  wooSyncOrigin           String?
  // Canonical sellable-state revision. wooPendingPatch() bumps wooDesiredRevision
  // on every dirty-mark; the worker stamps wooSyncedRevision with the revision it
  // actually synced. desired ≠ synced ⇒ NOT truly synced — the sweep re-pends it,
  // so a lost/racing mutation can never remain falsely 'synced'.
  wooDesiredRevision      Int             @default(0)
  wooSyncedRevision       Int?

  // Registered-tour REPLACEMENT link: when a tour with registrations is moved,
  // the original is cancelled and points here at its replacement. Enables
  // idempotent replace (retry finds the existing replacement) + the "replaced"
  // state in the UI. Loose (no FK) so either side survives deletion.
  replacedByTourEventId String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  bookings              Booking[]
  assignments           TourAssignment[]
  activityComponents    TourEventActivityComponent[]
  ticketRegistrations   TicketRegistration[]
  wooVariationLinks     WooVariationLink[]
  gallery               TourGallery?
  payrollActivity       PayrollActivity?

  // Canonical identity of a GENERATED open-tour occurrence is (openTourTemplateId,
  // date, startTime) — NOT (generatedByRuleId, date). Rule id is unstable across
  // rule delete+recreate (which minted the 2026-07 duplicates: a deleted Thu rule
  // and its recreated twin each generated the same Thursdays under different rule
  // ids, so the old (generatedByRuleId, date) unique never fired). The structural
  // guard is now a PARTIAL unique index over active generated slots, created in
  // raw SQL (Prisma can't express a WHERE-filtered unique) in the
  // tour_canonical_slot_identity migration:
  //   UNIQUE (openTourTemplateId, date, startTime)
  //     WHERE kind='group_slot' AND status='scheduled' AND openTourTemplateId,date,startTime NOT NULL
  // It permits unlimited cancelled/postponed history, manual tours (template null)
  // and different clock times, but at most ONE active occurrence per logical slot.
  // generatedByRuleId keeps a plain index for ruleEdit's per-rule slot lookups.
  @@index([generatedByRuleId, date])
  @@index([date, startTime])
  @@index([kind, status, date])
  @@index([productId])
  @@index([productVariantId])
  @@index([locationId])
  @@index([openTourTemplateId, date])
  @@index([gcalSyncStatus, gcalNextRetryAt])
  @@index([wooSyncStatus, wooNextRetryAt])
}

// Canonical mapping — a sellable Pricing Card (cardGroupId) → its place in a
// WooCommerce Variable Product. Lives in GOS so business logic NEVER hardcodes a
// Woo product id. One mapping per card.
//
// The LIVE store keys occurrences with GLOBAL taxonomy attributes and sells
// adult/child as separate variations, so a single card is one ACTIVITY value
// (pa_פעילות) inside a city product, and each of its ticket types (מבוגר/ילד)
// becomes its own age variation (pa_גיל) at that ticket type's canonical price.
// `config` (Json) stores this per-product compatibility descriptor so nothing is
// hardcoded and different products may use different attribute names/ids:
//   {
//     taxonomyMode: 'global' | 'local',
//     date:     { attrId, attrName, format },      // global-taxonomy date attr
//     time:     { attrId, attrName } | null,       // separate time attr (null=none)
//     activity: { attrId, attrName, termName, termSlug } | null,  // THIS card's activity
//     age:      { attrId, attrName } | null,       // the age split attr
//     ticketAge:{ [ticketTypeId]: { termName, termSlug } }  // ticket type → age term
//   }
// `dateAttribute` is retained ONLY for the legacy local-attribute fallback.
model WooProductMapping {
  id            String   @id @default(cuid())
  cardGroupId   String   @unique
  wooProductId  Int
  dateAttribute String?
  config        Json?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// One WooCommerce variation per (TourEvent × sellable card × variant) — the
// STABLE link GOS keeps for idempotent updates + cancellation. A single
// occurrence produces MULTIPLE variations (one per ticket type / age term), so
// `variantKey` (the ticketTypeId, or 'default' in the single-variation fallback)
// disambiguates siblings. wooVariationId is null until first created; on cancel
// the variation is DISABLED/HIDDEN (never deleted, so existing orders keep their
// integrity). status mirrors the last reconcile.
model WooVariationLink {
  id             String    @id @default(cuid())
  tourEvent      TourEvent @relation(fields: [tourEventId], references: [id], onDelete: Cascade)
  tourEventId    String
  cardGroupId    String
  variantKey     String    @default("default")
  ticketTypeId   String?
  wooProductId   Int
  wooVariationId Int?
  status         String    @default("pending") // pending | synced | failed | disabled
  // Provenance of the variation's CREATION (set once, never overwritten):
  // 'sync_one' (explicit per-occurrence action) | 'bulk' (bulk generation) |
  // 'adoption' (existing Woo variation adopted by meta match) | 'repair'
  // (created while converging an already-linked occurrence).
  createdVia     String?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([tourEventId, cardGroupId, variantKey])
  @@index([tourEventId])
}

// Deleting a TourEvent that already owns a Google Calendar event must still
// cancel that event (attendees get Google's cancellation email) — but the tour
// row is gone, so the outbox flag can't live there. A tombstone survives the
// delete and the calendar sync worker processes it asynchronously (idempotent:
// a 404/410 from Google counts as done). No FK by design.
model TourCalendarTombstone {
  id            String   @id @default(cuid())
  tourEventId   String // loose ref, for logs only
  gcalEventId   String
  gcalAccountId String?
  status        String   @default("pending") // pending | done | failed
  attempts      Int      @default(0)
  nextRetryAt   DateTime @default(now())
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, nextRetryAt])
}

// The ONE relationship layer between Deal (commercial) and TourEvent
// (operational). seats = this deal's participant count on the tour (seeded from
// Deal.participants at WON). Tour occupancy is ALWAYS derived as
// SUM(seats WHERE status='active') — never stored on the TourEvent.
// status: 'active' | 'cancelled' | 'orphaned'. 'orphaned' = the deal left WON
// (reopen) but the operator chose to keep the tour — intentionally disconnected
// operational work, surfaced by the global header warning until reconnected or
// cancelled. A partial unique index (dealId WHERE status='active') enforces the
// product rule that a deal participates in at most ONE tour at a time (moving
// = "החלף סיור", which cancels the old row and creates a new one).
// Restrict on both FKs: a TourEvent with any bookings cannot be deleted, and a
// Deal with bookings must be disconnected from its tour before deletion.
model Booking {
  id                  String               @id @default(cuid())
  tourEvent           TourEvent            @relation(fields: [tourEventId], references: [id], onDelete: Restrict)
  tourEventId         String
  deal                Deal                 @relation(fields: [dealId], references: [id], onDelete: Restrict)
  dealId              String
  seats               Int                  @default(0)
  status              String               @default("active") // active | cancelled | orphaned
  cancelledAt         DateTime?
  orphanedAt          DateTime?
  // Per-booking operational note (this deal on this tour) — NOT tour-wide and
  // NOT commercial.
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  // Canonical ticket allocation rows this deal booking produced (source='deal').
  // Seat/product truth lives on TicketRegistration — Booking is CRM linkage.
  ticketRegistrations TicketRegistration[]

  @@index([tourEventId, status])
  @@index([dealId, status])
}

// Automatic group-slot scheduling. Each rule = one recurring weekly slot
// (product + variant + language + weekday + time + capacity — per product
// decision, so different products/languages can have their own recurring
// schedules). Generation materializes REAL TourEvents (kind='group_slot') as
// dates enter the horizon (TourSettings.generateDaysAhead).
//
// `generatedThrough` is the per-rule generation cursor ("slots exist up to
// this date"): generation only creates dates BEYOND it, so an operator who
// deletes an empty generated slot never sees it resurrected on the next read.
// The (generatedByRuleId, date) unique on TourEvent guards concurrent runs.
// Rules are the recipe — the slots are the truth: editing a rule never
// mutates already-created slots.
model TourScheduleRule {
  id               String          @id @default(cuid())
  product          Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId        String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  productVariantId String?
  weekday          Int // 0=ראשון … 6=שבת (JS getDay convention)
  startTime        String // "HH:MM"
  tourLanguage     String
  capacity         Int
  active           Boolean         @default(true)
  generatedThrough String? // "YYYY-MM-DD" generation cursor
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([active, weekday])
}

// Tours module global settings — a singleton row (id='singleton'), created
// lazily on first read. defaultCapacity seeds new rules/slots in the UI;
// generateDaysAhead is the auto-generation horizon.
model TourSettings {
  id                String   @id @default("singleton")
  defaultCapacity   Int      @default(30)
  generateDaysAhead Int      @default(60)
  updatedAt         DateTime @updatedAt
}

// ── Open Tours ───────────────────────────────────────────────────────────────
// A generic recurring open-tour architecture. NOTHING here encodes a product
// name/id: an open tour offers whichever Pricing Cards are flagged sellable
// (PriceRule.availableForGroupTickets), each mapped to its operational
// ProductVariant. The variant's activity components (incl. any isWorkshop
// component) are the ONLY source of operational capability — "workshop vs plain"
// is derived from active registrations, never selected.
//
// An OpenTourTemplate is the reusable "what" (where, how long, capacity, close
// rule, guide requirement, offered ticket products). OpenTourScheduleRule is the
// "when" (recurring weekday+time within a validity window / season).
// OpenTourScheduleException handles one-offs. The generation engine materializes
// real TourEvents (kind='group_slot') from template × rules − exceptions.
model OpenTourTemplate {
  id                       String    @id @default(cuid())
  nameHe                   String
  nameEn                   String?
  // Where it runs. locationId is the city/venue (catalog); meetingPoint is
  // free-text muster instructions carried onto generated slots' notes context.
  location                 Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationId               String?
  meetingPoint             String?
  tourLanguage             String    @default("he") // default language for generated slots
  // Operational duration: null = derive from the operational product's variant
  // (durationHours); a positive value forces a fixed duration on the slot.
  durationHoursOverride    Float?
  // Soft capacity ceiling seeded onto generated slots (warnings only, like
  // TourEvent.capacity). Null → TourSettings.defaultCapacity.
  capacity                 Int?
  // Registration close rule: minutes before startTime after which new
  // registrations are refused. Null = no automatic close.
  registrationCloseMinutes Int?
  // Default guide requirement (operational staffing hint; not DB-enforced).
  defaultLeadGuides        Int       @default(1)
  active                   Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  products      OpenTourTemplateProduct[]
  scheduleRules OpenTourScheduleRule[]
  exceptions    OpenTourScheduleException[]

  @@index([active])
  @@index([locationId])
}

// The sellable ticket products an OpenTourTemplate offers. Each row references
// the operational ProductVariant a ticket delivers (the generic capability
// source). priceRuleId/cardGroupId are loose refs to the Pricing Card that
// prices it (config; gated by availableForGroupTickets). Exactly one row SHOULD
// be isDefault — the base operational product for a slot with zero active
// registrations — enforced at the API, not the DB.
model OpenTourTemplateProduct {
  id               String           @id @default(cuid())
  template         OpenTourTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId       String
  productVariant   ProductVariant?  @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  productVariantId String?
  priceRuleId      String? // loose ref to a representative sellable PriceRule
  cardGroupId      String? // loose ref to the Pricing Card identity (sibling rules)
  isDefault        Boolean          @default(false)
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([templateId])
  @@index([productVariantId])
}

// The "when": a recurring weekly slot for a template, bounded by an optional
// validity window and tagged with an optional season label (so summer/winter
// schedules coexist and toggle). Same idempotency contract as the retired
// TourScheduleRule — rules are the recipe, slots are the truth: editing a rule
// never mutates already-created slots. generatedThrough is the forward cursor.
model OpenTourScheduleRule {
  id               String           @id @default(cuid())
  template         OpenTourTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId       String
  weekday          Int // 0=ראשון … 6=שבת (JS getDay convention)
  startTime        String // "HH:MM"
  validFrom        String? // "YYYY-MM-DD" inclusive; null = unbounded
  validUntil       String? // "YYYY-MM-DD" inclusive; null = unbounded
  season           String? // optional label, e.g. "קיץ 2026" — grouping/toggle only
  active           Boolean          @default(true)
  generatedThrough String? // "YYYY-MM-DD" forward generation cursor
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([templateId, active, weekday])
}

// One-off exceptions layered on a template's recurring rules, keyed by date:
//   add           — create an extra occurrence on this date (time or default)
//   cancel        — suppress the occurrence that would fall on this date
//   time_override — the occurrence on this date runs at `time` instead
// (a "move" = cancel(oldDate) + add(newDate)). Applied by the generation engine.
model OpenTourScheduleException {
  id         String           @id @default(cuid())
  template   OpenTourTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String
  date       String // "YYYY-MM-DD"
  type       String // add | cancel | time_override
  time       String? // "HH:MM" for add / time_override
  note       String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([templateId, date, type])
  @@index([templateId, date])
}

// ── Canonical ticket registration (SSOT for ticket allocation) ───────────────
// The single source of truth for WHO holds seats on a TourEvent and WHICH
// sellable product they bought — source-agnostic by design. Admin/Deal bookings,
// WooCommerce webhooks, and future channels ALL write here; nothing else stores
// ticket-seat truth. Occupancy = SUM(quantity WHERE status='active'), and the
// tour's operational product is derived ONLY from active rows here.
//
// productVariantId is the operational identity (drives derivation — its activity
// components, incl. any isWorkshop, decide the tour's operational product).
// priceRuleId/cardGroupId are loose refs to the Pricing Card that priced it.
// bookingId/dealId link CRM context where applicable (SetNull — history
// survives). For external sources, external order/line ids give idempotent
// upsert. status is the ALLOCATION state (active counts; cancelled/refunded do
// not); paymentStatus is the separate money state.
model TicketRegistration {
  id               String          @id @default(cuid())
  tourEvent        TourEvent       @relation(fields: [tourEventId], references: [id], onDelete: Restrict)
  tourEventId      String
  // Operational product identity (SetNull preserves the registration if the
  // variant catalog entry is later removed; derivation simply ignores null).
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  productVariantId String?
  priceRuleId      String? // loose ref — the sellable PriceRule (pricing is config)
  cardGroupId      String? // loose ref — the Pricing Card identity
  quantity         Int             @default(1)
  // The CANONICAL purchased ticket composition (from the Group Ticket Builder's
  // quote lines): [{ cardGroupId, cardTitle, ticketTypeId, ticketLabel,
  // productVariantId, quantity }]. productVariantId above is the operationally-
  // DOMINANT card variant derived from this (so a plain-only deal contributes
  // only plain capabilities — never a stale tour-variant snapshot). Drives the
  // per-customer + aggregate breakdown UI; generic over any future card/ticket.
  ticketBreakdown  Json?
  // Where this registration originated: admin | deal | woocommerce | …
  // (validated in code, no Postgres enum — project convention).
  source           String          @default("admin")
  // CRM linkage where applicable (SetNull — registration outlives the booking).
  booking          Booking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  bookingId        String?
  deal             Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId           String?
  // External source identifiers (e.g. WooCommerce order/line) for idempotent
  // ingest. Nulls are distinct in Postgres, so admin rows never collide.
  externalOrderId  String?
  externalLineId   String?
  // Customer identity snapshot for non-Deal sources (WooCommerce/public).
  customerName     String?
  customerEmail    String?
  customerPhone    String?
  // Allocation lifecycle (validated in code, no Postgres enum):
  //   held      — conditional reservation; CONSUMES capacity + participates in
  //               derivation, but is NOT a confirmed customer (no guide comms);
  //               expiresAt is set. Deal stays OPEN.
  //   confirmed — a confirmed customer (guide sees full contact). 'active' is the
  //               legacy synonym (pre-lifecycle rows + the deal-WON path).
  //   expired   — a held reservation that lapsed unpaid; capacity RELEASED.
  //   cancelled / refunded — released, terminal.
  // Capacity + derivation count held|confirmed|active (see registrationStatus.js).
  status           String          @default("active")
  // Money state (independent of allocation): pending | paid | refunded | comp | …
  paymentStatus    String?
  // Canonical held-reservation expiry (null unless status='held' or historical).
  expiresAt        DateTime?
  heldAt           DateTime?
  confirmedAt      DateTime?
  expiredAt        DateTime?
  cancelledAt      DateTime?
  refundedAt       DateTime?
  // "register without payment" reason (Part 7) — stored canonically here.
  noPaymentReason  String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([source, externalOrderId, externalLineId])
  @@index([tourEventId, status])
  @@index([productVariantId])
  @@index([bookingId])
  @@index([dealId])
  @@index([status, expiresAt])
}

// Durable one-time maintenance jobs (versioned backfills/reconciliations). The
// key is the job identity (e.g. "reconcile_open_tour_products_v1"); the row is
// the completion MARKER so the job runs exactly once across restarts AND across
// multiple Railway instances. Claiming is a concurrency-safe conditional update
// (pending/failed/stale-running → running); a fresh version = a new key.
model MaintenanceJob {
  key        String    @id
  status     String    @default("pending") // pending | running | done | failed
  startedAt  DateTime?
  finishedAt DateTime?
  attempts   Int       @default(0)
  summary    Json?
  error      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// Guide Portal permissions — a singleton row (id='singleton'), created lazily
// on first read (same convention as TourSettings / TourGallerySettings).
// These are SERVER-ENFORCED: every guide-facing /api/portal route resolves
// them and gates data/actions on the server, never by hiding buttons.
// Gallery delete/share stay on TourGallerySettings (the gallery SSOT) —
// deliberately NOT duplicated here.
model GuidePortalSettings {
  id                   String   @id @default("singleton")
  viewTeam             Boolean  @default(true)
  viewParticipantPhone Boolean  @default(true)
  viewParticipantEmail Boolean  @default(true)
  viewCustomerInfo     Boolean  @default(true)
  viewFieldRep         Boolean  @default(true)
  fillTourSummary      Boolean  @default(true)
  useTourGallery       Boolean  @default(true)
  useCoordinationForms Boolean  @default(true)
  viewPay              Boolean  @default(true)
  viewProcedures       Boolean  @default(true)
  viewTraining         Boolean  @default(true)
  editPersonalProfile  Boolean  @default(true)
  updatedAt            DateTime @updatedAt
}

// Guide assignment — a staff member (PersonRef, the GOS staff SSOT) working a
// specific TourEvent. The ROLE lives on the assignment, not the person: the
// same guide can lead on Tuesday and assist on Thursday. Role changes UPDATE
// the row (one assignment per person per tour) and emit a tour timeline event.
// `externalPersonId` snapshots the stable staff handle (same convention as
// Attempt.externalPersonId) and `displayName` snapshots the name, so history
// survives PersonRef deletion (SetNull). Pay/attendance are a future phase.
model TourAssignment {
  id               String     @id @default(cuid())
  tourEvent        TourEvent  @relation(fields: [tourEventId], references: [id], onDelete: Cascade)
  tourEventId      String
  personRef        PersonRef? @relation(fields: [personRefId], references: [id], onDelete: SetNull)
  personRefId      String?
  externalPersonId String
  displayName      String
  role             String // lead_guide | guide | workshop_assistant
  notes            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([tourEventId, externalPersonId])
  @@index([tourEventId])
  @@index([personRefId])
  @@index([externalPersonId])
}

// ── Activity Components catalog ──────────────────────────────────────────────
// A small, reusable catalog of the operational building blocks an activity is
// made of (e.g. "סיור גרפיטי", "סדנת תקליטים", "טעימת אוכל"). A ProductVariant
// declares its DEFAULT components (ProductVariantActivityComponent); a TourEvent
// stores what is actually being delivered (TourEventActivityComponent, seeded at
// creation from the selected variant).
// Soft-delete convention (isActive), same as TaskType/OrganizationType: an entry
// that was ever used is deactivated, never hard-deleted, so history stays valid.
model ActivityComponent {
  id         String   @id @default(cuid())
  nameHe     String
  nameEn     String?
  icon       String? // emoji or short glyph shown on the chip
  color      String? // tone key from a fixed client palette (emerald|blue|…)
  isWorkshop Boolean  @default(false) // workshop components carry a WorkshopLocation per tour
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  variantLinks   ProductVariantActivityComponent[]
  tourEventLinks TourEventActivityComponent[]
  dealPlanLinks  DealTourPlanActivityComponent[]

  @@index([sortOrder])
}

// ProductVariant DEFAULT components — which activity components a specific
// VARIANT delivers by default, and in what order. Defaults belong to the variant
// (not the product): the same product family can have a tour-only variant, a
// tour+workshop variant, etc. Seeded onto a TourEvent at creation from the
// SELECTED variant; after that the tour owns its own components (no live link
// back). onDelete Restrict on the component keeps a referenced catalog entry
// from being hard-deleted (the API deactivates instead).
model ProductVariantActivityComponent {
  id                  String            @id @default(cuid())
  productVariant      ProductVariant    @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  productVariantId    String
  activityComponent   ActivityComponent @relation(fields: [activityComponentId], references: [id], onDelete: Restrict)
  activityComponentId String
  sortOrder           Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([productVariantId, activityComponentId])
  @@index([productVariantId])
  @@index([activityComponentId])
}

// Catalog of physical places a workshop component can take place in. Referenced
// per TourEventActivityComponent row (a tour can hold several workshop
// components, each in a different place). Same soft-delete convention.
model WorkshopLocation {
  id           String   @id @default(cuid())
  nameHe       String
  address      String?
  instructions String? // access / parking / setup notes for the team
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tourEventLinks TourEventActivityComponent[]
  dealPlanLinks  DealTourPlanActivityComponent[]

  @@index([sortOrder])
}

// A TourEvent's ACTUAL delivered components — seeded from the Product defaults
// at creation, then owned by the tour (operational truth; no live link back to
// the Product). workshopLocationId is set ONLY for workshop components, and a
// tour may hold several workshop components each in a DIFFERENT location — hence
// the location lives on this row, never on TourEvent. onDelete: component &
// location are Restrict (referenced catalog entries are deactivated, not
// deleted); the tour link Cascades with the tour.
model TourEventActivityComponent {
  id                  String            @id @default(cuid())
  tourEvent           TourEvent         @relation(fields: [tourEventId], references: [id], onDelete: Cascade)
  tourEventId         String
  activityComponent   ActivityComponent @relation(fields: [activityComponentId], references: [id], onDelete: Restrict)
  activityComponentId String
  workshopLocation    WorkshopLocation? @relation(fields: [workshopLocationId], references: [id], onDelete: Restrict)
  workshopLocationId  String?
  sortOrder           Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([tourEventId, activityComponentId])
  @@index([tourEventId])
  @@index([activityComponentId])
  @@index([workshopLocationId])
}

// ── Deal Tour PLANNING (pre-WON) ─────────────────────────────────────────────
// The canonical PLANNING model for a private/business deal's future tour —
// everything the operator prepares BEFORE the deal is WON that the Deal's own
// planning scalars (product/variant/city/date/time/participants/language)
// cannot hold: the planned team, the planned activity components + workshop
// locations, and operational notes. STRICTLY internal: nothing here creates a
// TourEvent, touches Google Calendar, invites guides, or shows in the Guide
// Portal. At WON, tourFromDeal.js materializes the plan into the real
// TourEvent/TourAssignment/TourEventActivityComponent rows (a copy — the tour
// owns its state from then on); on reopen-with-cancel the tour's operational
// state is copied BACK here so a future WON recreates it. There is never a
// partially-real TourEvent.
model DealTourPlan {
  id                   String   @id @default(cuid())
  deal                 Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId               String   @unique
  // Planned operational notes → TourEvent.notes at materialization.
  notes                String?
  // FALSE = the component list still FOLLOWS the selected variant's live
  // defaults (materialization seeds from the variant, exactly like a deal with
  // no plan — today's behavior). TRUE = the operator customized the list; the
  // plan's rows are authoritative, INCLUDING an intentionally-empty list.
  // Without this flag "customized to empty" and "never touched" would be
  // indistinguishable.
  componentsCustomized Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  assignments        DealTourPlanAssignment[]
  activityComponents DealTourPlanActivityComponent[]
}

// A PLANNED guide — deliberately NOT a TourAssignment: no calendar attendee,
// no portal visibility, no invitation. Same shape as TourAssignment (snapshot
// externalPersonId/displayName, role on the row) so materialization is a
// mechanical copy. Eligibility (people/eligibility.js) gates creation exactly
// like real assignments.
model DealTourPlanAssignment {
  id               String       @id @default(cuid())
  plan             DealTourPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId           String
  personRef        PersonRef?   @relation(fields: [personRefId], references: [id], onDelete: SetNull)
  personRefId      String?
  externalPersonId String
  displayName      String
  role             String // lead_guide | guide | workshop_assistant
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([planId, externalPersonId])
  @@index([planId])
  @@index([personRefId])
}

// A PLANNED activity component (+ optional workshop location) — same shape as
// TourEventActivityComponent for mechanical copy at materialization. Restrict
// on catalog FKs mirrors the tour-row convention (catalog entries are
// deactivated, never hard-deleted while referenced).
model DealTourPlanActivityComponent {
  id                  String            @id @default(cuid())
  plan                DealTourPlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId              String
  activityComponent   ActivityComponent @relation(fields: [activityComponentId], references: [id], onDelete: Restrict)
  activityComponentId String
  workshopLocation    WorkshopLocation? @relation(fields: [workshopLocationId], references: [id], onDelete: Restrict)
  workshopLocationId  String?
  sortOrder           Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([planId, activityComponentId])
  @@index([planId])
  @@index([activityComponentId])
  @@index([workshopLocationId])
}

// ============================================================================
// QUESTIONNAIRE ENGINE (generic, blueprint: docs/architecture/
// questionnaire-engine-design.md)
// ============================================================================
// ONE generic engine; consumers supply (subjectType, subjectId, purpose).
// Definition cluster (Template → Version → Section → Question → Option) is
// FROZEN on publish; response cluster (Submission → Answer) is frozen forever.
// This is a separate system from the Flow/learning engine — zero shared
// tables, different semantics (one-shot subject-bound forms vs. attempt/
// review learning).
//
// All human-facing strings are localized JSON maps { he, en, … } — a new
// language never needs a schema change (§11).

// The stable identity of a form across all its versions. Holds what KIND of
// form this is — never its questions (those live on a version).
model QuestionnaireTemplate {
  id           String @id @default(cuid())
  // Stable machine slug (e.g. 'tour_coordination') — consumer-facing handle.
  key          String @unique
  // Business purpose (registry-validated: tour_summary | coordination |
  // general | future). Orthogonal to subject: purpose = WHY the form exists.
  purpose      String
  // Admin-facing name (list screens); public title is localized below.
  internalName String
  title        Json
  description  Json?
  // draft | active | archived — 'active' + a published version = live form.
  status       String @default("draft")
  // public | staff | both — governs whether public links may be issued.
  audience     String @default("staff")

  defaultLanguage    String   @default("he")
  supportedLanguages String[] @default(["he"])

  // One ACTIVE submission per (subjectType, subjectId, purpose) — enforced by
  // QuestionnaireSubmission.singletonKey (unique, null = unbound/non-singleton).
  singletonPerSubject     Boolean @default(true)
  // Policy when a filler resumes a draft whose version was superseded.
  allowResumeOnOldVersion Boolean @default(true)

  // The published version NEW submissions use. In-flight submissions keep the
  // version they started on. SetNull can never fire in practice (published
  // versions are undeletable via service guards) but keeps the FK honest.
  currentVersionId String?               @unique
  currentVersion   QuestionnaireVersion? @relation("TemplateCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)

  versions       QuestionnaireVersion[]       @relation("TemplateVersions")
  submissions    QuestionnaireSubmission[]
  links          QuestionnaireLink[]
  purposeConfigs QuestionnairePurposeConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purpose, status])
}

// The frozen structural snapshot — versioning's heart (§6). A published
// version is IMMUTABLE: the service refuses structural writes; editing a live
// form auto-creates the next draft version. Old submissions keep pointing at
// their old version, so "editing a template never changes previous answers"
// is structurally impossible to get wrong.
model QuestionnaireVersion {
  id          String                @id @default(cuid())
  template    QuestionnaireTemplate @relation("TemplateVersions", fields: [templateId], references: [id], onDelete: Cascade)
  templateId  String
  versionNo   Int
  // draft | published | archived
  status      String                @default("draft")
  publishedAt DateTime?
  // Changelog note for the version-history panel.
  notes       String?
  // Localized rich intro (shown before section 1) and outro (thank-you).
  intro       Json?
  outro       Json?
  // full_list | step_by_step — fill-runtime layout.
  displayMode String                @default("full_list")

  sections    QuestionnaireSection[]
  questions   QuestionnaireQuestion[]
  submissions QuestionnaireSubmission[]
  currentFor  QuestionnaireTemplate?    @relation("TemplateCurrentVersion")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templateId, versionNo])
  @@index([templateId, status])
}

// First-class ordered section (§2). `key` is stable across version clones —
// it survives reorder and is the durable identity inside a template.
model QuestionnaireSection {
  id                 String               @id @default(cuid())
  version            QuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  versionId          String
  key                String
  title              Json
  description        Json?
  sortOrder          Int                  @default(0)
  collapsible        Boolean              @default(false)
  collapsedByDefault Boolean              @default(false)
  // Conditional visibility (capped grammar, shared evaluator). May reference
  // only questions from EARLIER sections — enforced at publish.
  visibleWhen        Json?

  questions QuestionnaireQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([versionId, key])
  @@index([versionId, sortOrder])
}

// A field. `key` is the identity answers + conditions bind to (stable across
// versions); `type` comes from the server-side type registry
// (server/src/questionnaires/types.js); `config` holds type-specific settings
// (min/max, maxLength, allowOther, scaleMax, …).
model QuestionnaireQuestion {
  id          String               @id @default(cuid())
  version     QuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  versionId   String
  section     QuestionnaireSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId   String
  key         String
  type        String
  label       Json
  helpText    Json?
  placeholder Json?
  required    Boolean              @default(false)
  sortOrder   Int                  @default(0)
  config      Json?
  // Backward-only conditional visibility (enforced at publish → acyclic).
  visibleWhen Json?

  options QuestionnaireQuestionOption[]
  answers QuestionnaireAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([versionId, key])
  @@index([sectionId, sortOrder])
  @@index([versionId])
}

model QuestionnaireQuestionOption {
  id         String                @id @default(cuid())
  question   QuestionnaireQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String
  // Stable machine value stored in answers; label is the localized display.
  value      String
  label      Json
  sortOrder  Int                   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([questionId, value])
  @@index([questionId, sortOrder])
}

// One response instance (§2). Pins the EXACT version it was filled against;
// polymorphic subject (no FK — the Subject Adapter Registry validates
// existence; subjectSnapshot preserves display context if the subject is
// later deleted). Immutable after submit — answer writes are refused.
model QuestionnaireSubmission {
  id         String                @id @default(cuid())
  template   QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  templateId String
  version    QuestionnaireVersion  @relation(fields: [versionId], references: [id], onDelete: Restrict)
  versionId  String

  // Polymorphic subject binding (§4): booking | tour_event | future types.
  // Null = unbound (anonymous survey, purpose must allow it).
  subjectType String?
  subjectId   String?
  // Denormalized from the template for indexing/reporting without a join.
  purpose     String

  // draft | submitted | reviewed | void
  status   String @default("draft")
  // Language the responder actually filled in (snapshots resolve to it).
  language String @default("he")

  // Who filled: public (customer via token link) | staff | system. staff →
  // submittedByRef = AdminUser.id (+ optional PersonRef handle in meta).
  submittedByType String  @default("staff")
  submittedByRef  String?
  submittedByName String?

  // The public link used (Slice 3+); survives link revocation via SetNull.
  link   QuestionnaireLink? @relation(fields: [linkId], references: [id], onDelete: SetNull)
  linkId String?

  // Frozen display context of the subject at start time (survives deletion).
  subjectSnapshot Json?
  // UTM / channel / device etc. (reserved).
  meta            Json?

  // Per-actor singleton scope (perActor purposes — tour_summary): the guide's
  // externalPersonId this submission belongs to. Joins the singleton key so
  // each required guide files their OWN summary. NULL elsewhere.
  actorScope String?

  // DB-enforced one-active-submission-per-subject:
  //   `${subjectType}:${subjectId}:${purpose}[:${actorScope}]` while status is
  //   draft/submitted/reviewed on a singleton template; NULL otherwise
  //   (Postgres allows many NULLs). Cleared when a submission is voided.
  singletonKey String? @unique

  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  // Tour-operational lifecycle: while NULL the submission follows the
  // template's CURRENT published version and stays editable (even after
  // submit). Set once when the subject's tour closes — from then on the
  // version pin + answer snapshots are the immutable historical record.
  frozenAt    DateTime?

  answers QuestionnaireAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectType, subjectId, purpose, status])
  @@index([templateId, status])
  @@index([versionId])
}

// One answer. `questionKey` + `questionSnapshot` make the row renderable
// forever, independent of the version tree (§7 layer 2): snapshot freezes the
// RESOLVED single-language view (label/options/config) the responder saw.
// questionId is a soft link (SetNull) — history survives anything.
model QuestionnaireAnswer {
  id               String                  @id @default(cuid())
  submission       QuestionnaireSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId     String
  question         QuestionnaireQuestion?  @relation(fields: [questionId], references: [id], onDelete: SetNull)
  questionId       String?
  questionKey      String
  // string | number | boolean | string[] — validated by the type registry.
  value            Json?
  // Frozen at submit; null while the submission is a draft.
  questionSnapshot Json?
  // Render-order snapshot (document order at submit time).
  sortOrder        Int                     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([submissionId, questionKey])
  @@index([questionId])
}

// Public capability token (§12) — binds a URL to (subject, purpose, template).
// GOS-native convention: high-entropy plaintext token, exact-match resolve,
// no enumeration (same as QuoteDocument.publicToken / portalToken).
model QuestionnaireLink {
  id         String                @id @default(cuid())
  template   QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String

  subjectType String?
  subjectId   String?
  purpose     String

  token      String    @unique
  // Force a language (e.g. from TourEvent.tourLanguage); null → resolve chain.
  language   String?
  label      String?
  expiresAt  DateTime?
  singleUse  Boolean   @default(false)
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?

  submissions QuestionnaireSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectType, subjectId, purpose])
  @@index([templateId])
}

// Which template serves a business purpose (settings surface: the tour
// summary / coordination cards pick a template here). SetNull — deleting a
// template leaves the purpose unconfigured, never dangling.
model QuestionnairePurposeConfig {
  id         String                 @id @default(cuid())
  purpose    String                 @unique
  template   QuestionnaireTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Tour Gallery ──────────────────────────────────────────────────────────────
// Per-TourEvent media gallery (photos/videos taken on the tour). The gallery is
// OWNED by the TourEvent — Deal surfaces only read through. One lazy row per
// tour (unique tourEventId), created on first touch; counts and status are
// ALWAYS derived from TourMedia rows, never stored. Original bytes live in R2
// under the immutable-ID prefix `tour-galleries/<tourEventId>/…` — display
// titles are computed live from TourEvent data, so product/date/customer
// changes never move storage objects.
model TourGallery {
  id                    String            @id @default(cuid())
  tourEvent             TourEvent         @relation(fields: [tourEventId], references: [id], onDelete: Cascade)
  tourEventId           String            @unique
  // Loose ref to the cover TourMedia (no FK — falls back to newest ready image
  // when unset or when the referenced media is deleted).
  coverMediaId          String?
  customerUploadEnabled Boolean           @default(true)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  media                 TourMedia[]
  links                 TourGalleryLink[]
}

// One uploaded photo/video. Bytes are NEVER stored in Postgres — objectKey
// points at the R2 original; thumbKey/posterKey at client-generated
// derivatives. uploadStatus: 'pending' (row created, direct-to-R2 upload in
// flight) → 'ready' (completion verified server-side). Pending rows older than
// the abandon window are swept (multipart aborted + objects deleted). Soft
// delete (deletedAt) keeps attribution/audit while the R2 object is removed.
model TourMedia {
  id                    String      @id @default(cuid())
  gallery               TourGallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  galleryId             String
  // Denormalized owner id — matches the objectKey prefix, survives for cleanup
  // queries, and keeps key building free of joins.
  tourEventId           String
  objectKey             String      @unique
  thumbKey              String?
  posterKey             String?
  mediaType             String // 'image' | 'video'
  mimeType              String
  originalFileName      String
  byteSize              BigInt?
  width                 Int?
  height                Int?
  durationSeconds       Float?
  capturedAt            DateTime?
  checksum              String?
  uploadStatus          String      @default("pending") // pending | ready
  // R2 multipart upload id while a chunked upload is in flight (null for
  // single-part). partSize is fixed at initiate so part numbers stay stable.
  uploadId              String?
  partSize              Int?
  // Client upload batch — one timeline event per batch, not per photo.
  batchId               String?
  uploadedByType        String // 'office' | 'guide' | 'customer'
  uploadedById          String? // AdminUser.id (office; loose)
  uploadedByPersonRefId String? // PersonRef.id (guide; loose)
  uploadedByLinkId      String? // TourGalleryLink.id (customer; loose)
  uploadedByLabel       String? // display snapshot for the uploader chip
  deletedAt             DateTime?
  deletedById           String?
  createdAt             DateTime    @default(now())
  completedAt           DateTime?
  updatedAt             DateTime    @updatedAt

  @@index([galleryId, uploadStatus, deletedAt])
  @@index([tourEventId])
  @@index([uploadStatus, createdAt])
  @@index([batchId])
}

// Secure customer access to ONE tour gallery. Capability-URL model (same
// convention as QuestionnaireLink / portal tokens): 24-byte base64url token,
// unique, stored as-is. Rotation = revoke old row + create a new one; tour
// cancellation revokes all active links. The public routes derive the gallery
// from the token — a client-supplied tour id is never trusted.
model TourGalleryLink {
  id            String      @id @default(cuid())
  gallery       TourGallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  galleryId     String
  token         String      @unique
  status        String      @default("active") // active | revoked
  createdById   String? // AdminUser.id (loose)
  createdAt     DateTime    @default(now())
  revokedAt     DateTime?
  revokedReason String? // rotated | manual | tour_cancelled

  @@index([galleryId, status])
}

// Durable R2 cleanup work for a gallery whose tour was cancelled or deleted.
// Deliberately NO FK — the task must survive TourEvent deletion (cascade wipes
// the gallery rows; this row still knows the R2 prefix to purge). Idempotent:
// one active task per tour, and purging a prefix twice is harmless. notBefore
// gives a grace window so an accidental cancel that is immediately reverted
// does not lose media; the worker re-checks tour status before deleting.
//
// SAFETY INVARIANT (בקרה): a gallery that still contains live media is NEVER
// purged automatically. Such a task is created as (or demoted to)
// 'awaiting_approval' + an OperationalIssue; only an explicit admin approval
// (approvedAt/approvedBy) moves it to 'pending'. Empty galleries purge
// automatically as before. The worker re-checks this on every claim.
model TourGalleryCleanupTask {
  id             String    @id @default(cuid())
  tourEventId    String
  prefix         String // R2 prefix to purge (tour-galleries/<tourEventId>/)
  reason         String // tour_cancelled | tour_deleted
  status         String    @default("pending") // awaiting_approval | pending | running | done | skipped
  attempts       Int       @default(0)
  lastError      String?
  deletedObjects Int?
  notBefore      DateTime
  // Explicit admin approval to purge a gallery WITH media (loose AdminUser.id).
  approvedAt     DateTime?
  approvedBy     String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt

  @@index([status, notBefore])
  @@index([tourEventId, status])
}

// Gallery behavior settings (singleton, same pattern as TourSettings). Only
// switches that materially control current behavior — no speculative knobs.
model TourGallerySettings {
  id                        String   @id @default("singleton")
  guideCanDelete            Boolean  @default(true)
  guideCanShareCustomerLink Boolean  @default(true)
  // Default for NEW galleries (each gallery keeps its own flag).
  customerUploadEnabled     Boolean  @default(true)
  // Optional subtitle line on the public customer gallery page.
  publicBrandingText        String?
  // How long a "download all" archive stays alive in R2.
  archiveExpiryHours        Int      @default(72)
  updatedAt                 DateTime @updatedAt
}

// "Download all" export job — an async ZIP build (media streamed from R2
// through a store-only zipper back into R2; the API process NEVER buffers a
// gallery in memory and NEVER builds archives inside a request). The archive
// object lives under the gallery prefix (archives/<exportId>.zip) so tour
// cancellation cleanup purges it with everything else; expiry is enforced by
// the gallery worker (TourGallerySettings.archiveExpiryHours).
model TourGalleryExport {
  id                String    @id @default(cuid())
  tourEventId       String // loose — mirrors TourMedia.tourEventId
  galleryId         String
  requestedByType   String // office | guide | customer
  requestedByLinkId String? // TourGalleryLink.id for customer requests
  status            String    @default("pending") // pending | running | ready | failed | expired
  archiveKey        String?
  byteSize          BigInt?
  mediaCount        Int?
  attempts          Int       @default(0)
  error             String?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  completedAt       DateTime?
  updatedAt         DateTime  @updatedAt

  @@index([tourEventId, status])
  @@index([status, updatedAt])
  @@index([status, expiresAt])
}

// ═══════════════ Payroll module (שכר צוות) ═══════════════
// One PayrollEntry per person per activity — a tour assignment or a general
// activity participant. The office matrix, guide portal, and reports are all
// views over the same entries. Money is BigInt agorot (system convention).
//
// Approval model (ONE truth each):
//   • Office approval lives on PayrollActivity ONLY — one action covers every
//     entry in the activity. Entries never carry a second office-approval flag.
//   • Guide approval is inherently per-entry (each guide answers for their own
//     pay): PayrollEntry.guideStatus pending | approved | inquiry (בבירור).
// Entries are NEVER technically immutable — no status blocks office edits.
// History rides the immutable Timeline (subjectType 'payroll_activity').

// The payroll component catalog — nothing is hardcoded. System rows (isSystem)
// are seeded with stable ids and drive the engine's auto rules; office-defined
// rows are manual. Amounts on lines are stored POSITIVE; `sign` decides the
// direction of the contribution (deductions are sign=-1).
model PayrollComponent {
  id           String   @id @default(cuid())
  key          String?  @unique // stable key for system components; null for custom
  nameHe       String
  kind         String   @default("manual") // 'auto' | 'manual'
  autoRule     String? // base | weekend_holiday | participant_bonus | seniority | travel | general_quantity
  sign         Int      @default(1) // +1 payment, -1 deduction
  // VAT semantics per component, mapped onto splitVat modes:
  //   'net'   → amount is before VAT; VAT added for vat_18 guides (excluded)
  //   'gross' → amount already includes VAT (included)
  //   'none'  → never carries VAT, e.g. expense reimbursements (exempt)
  vatMode      String   @default("net")
  // Which activity source the component belongs to: 'all' | 'tour' | 'general'.
  scope        String   @default("all")
  // Office matrix renders this row even when every value is zero (the "enter
  // one value quickly" rows). The guide portal NEVER shows zero rows.
  officeAlways Boolean  @default(false)
  guideVisible Boolean  @default(true)
  // autoRule parameters (e.g. weekend { amountMinor }, participant bonus
  // { fromParticipants, perExtraMinor }). Interpreted by payroll/engine.js.
  config       Json?
  isSystem     Boolean  @default(false)
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lines PayrollEntryLine[]
}

// Catalog of general (non-tour) activity kinds: team meeting, office work,
// training, photo day… Quantity is generic UNITS, not necessarily hours.
model GeneralActivityType {
  id                    String   @id @default(cuid())
  nameHe                String
  defaultUnitPriceMinor BigInt   @default(0)
  defaultQuantity       Decimal  @default(1) @db.Decimal(10, 2)
  defaultNotes          String?
  // Configurable unit noun for the quantity, so the payroll breakdown reads
  // "₪40 לשעה × 1.5 שעות" instead of a unitless "₪40 × 1.5". Belongs to the
  // TYPE (it describes the activity), never a specific PayrollEntry/Line.
  // Nullable → legacy types stay unlabelled and the portal falls back to the
  // unitless display (never a wrong noun). New types default to שעה/שעות at the
  // API layer.
  unitLabelSingularHe   String?
  unitLabelPluralHe     String?
  active                Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  activities GeneralActivity[]
}

// One occurrence of a general activity. MUST belong to a payroll month; the
// specific day is optional (a dateless activity still belongs to its month).
model GeneralActivity {
  id           String              @id @default(cuid())
  type         GeneralActivityType @relation(fields: [typeId], references: [id], onDelete: Restrict)
  typeId       String
  titleHe      String // snapshot of the type name at creation (editable)
  payrollMonth String // "YYYY-MM" — REQUIRED
  date         String? // "YYYY-MM-DD" — optional
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  payrollActivity PayrollActivity?

  @@index([payrollMonth])
}

// The office-approval SSOT and the drawer subject — exactly one per completed
// tour (unique tourEventId) or per general activity. Payroll history must
// outlive its source: tour deletion SetNulls the link and titleHe keeps the
// display name. Cancellation/reopen NEVER deletes — state flips to 'cancelled'.
model PayrollActivity {
  id                String           @id @default(cuid())
  sourceType        String // 'tour_event' | 'general'
  tourEvent         TourEvent?       @relation(fields: [tourEventId], references: [id], onDelete: SetNull)
  tourEventId       String?          @unique
  generalActivity   GeneralActivity? @relation(fields: [generalActivityId], references: [id], onDelete: Restrict)
  generalActivityId String?          @unique
  titleHe           String // display snapshot (product/variant or activity title)
  payrollMonth      String // "YYYY-MM" (tours: derived from the tour date)
  date              String? // "YYYY-MM-DD" (null only for month-level general)
  state             String           @default("active") // active | cancelled | voided
  // DEPRECATED (2026-07 selective-approval refinement): office approval moved
  // to PayrollEntry.officeStatus — THE single approval truth. The activity
  // office-state (draft | partially_approved | office_approved) is DERIVED
  // from its entries (engine deriveOfficeState) and never persisted. These
  // three columns are frozen: never read, never written (kept only because
  // migrations are additive).
  status            String           @default("draft")
  officeApprovedAt  DateTime?
  officeApprovedBy  String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  entries PayrollEntry[]

  @@index([payrollMonth])
  @@index([date])
  @@index([state, status])
}

// One person's pay for one activity. Person identity follows the
// TourAssignment convention: stable externalPersonId + displayName snapshot +
// soft personRefId link, so payroll history survives staff deletion.
// vatStatus/vatRate are SNAPSHOTS stamped at calculation time — future system
// changes never rewrite old payroll; office edits always can.
model PayrollEntry {
  id                String          @id @default(cuid())
  activity          PayrollActivity @relation(fields: [activityId], references: [id], onDelete: Restrict)
  activityId        String
  personRef         PersonRef?      @relation(fields: [personRefId], references: [id], onDelete: SetNull)
  personRefId       String?
  externalPersonId  String
  displayName       String
  role              String? // lead_guide | guide | workshop_assistant | null (general)
  tourAssignmentId  String? // loose ref — assignments may be deleted/recreated
  state             String          @default("active") // active | cancelled | voided
  // Office approval — THE single source of truth, PER ENTRY (selective
  // approval inside a multi-person activity). The activity-level "אשר שכר"
  // is only a bulk operation over these fields, never a second truth.
  officeStatus      String          @default("draft") // draft | approved
  officeApprovedAt  DateTime?
  officeApprovedBy  String? // AdminUser username snapshot
  // Guide side of the approval flow (meaningful once THIS entry is
  // office-approved): pending | approved. Inquiry is a SEPARATE canonical
  // concept below — approval and inquiry resolution are never collapsed
  // into one field.
  guideStatus       String          @default("pending")
  guideApprovedAt   DateTime?
  // The inquiry lifecycle: none | open (בבירור) | accepted | rejected.
  // Resolution never touches the conversation (immutable timeline) and never
  // implies guide approval — after accept/reject the guide approves again.
  inquiryStatus     String          @default("none")
  inquiryResolvedAt DateTime?
  inquiryResolvedBy String? // AdminUser username snapshot
  vatStatusSnapshot String          @default("exempt") // exempt | vat_18
  vatRateSnapshot   Int             @default(18)
  // Latest calculation inputs (versioned via Timeline events, not by mutating
  // this): { engineVersion, at, inputs } — enough to reproduce every
  // calculatedMinor on the lines forever.
  calcSnapshot      Json?
  engineVersion     Int             @default(1)
  notes             String?
  // The OFFICIAL office note — admin-only editable, shown to the guide with
  // the entry ("הערת המשרד"). NOT part of the conversation thread and NOT a
  // line note: it explains the final calculation / a correction / a decision.
  // Old→new recorded in the timeline on every change.
  officeNote        String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  lines PayrollEntryLine[]

  @@unique([activityId, externalPersonId])
  @@index([externalPersonId])
  @@index([personRefId])
}

// One component row inside one entry. Calculated value, override, and final
// value are SEPARATE concepts: final = overrideMinor ?? calculatedMinor ?? 0,
// contribution = sign × final. The calculation is never replaced by an edit.
// Component name/sign/vatMode are snapshotted so catalog edits never rewrite
// history; componentId keeps Restrict so catalog rows with history can't go.
model PayrollEntryLine {
  id              String           @id @default(cuid())
  entry           PayrollEntry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId         String
  component       PayrollComponent @relation(fields: [componentId], references: [id], onDelete: Restrict)
  componentId     String
  componentNameHe String // snapshot
  sign            Int              @default(1) // snapshot
  vatMode         String           @default("net") // snapshot
  quantity        Decimal?         @db.Decimal(10, 2) // generic units
  unitPriceMinor  BigInt?
  calculatedMinor BigInt? // engine result (null for pure-manual rows)
  overrideMinor   BigInt? // office override — stored separately, never replaces
  note            String?
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([entryId, componentId])
  @@index([entryId])
}

// ── בקרה (Operations Control) ────────────────────────────────────────────────
// THE canonical operational-issue record. Every subsystem that detects an
// operational problem (gallery cleanup awaiting approval, skipped WhatsApp
// messages, deal↔tour drift, future: calendar/email/payment failures) reports
// through this ONE model — no module owns its own warning system. Issues are
// raised/auto-resolved by detectors that always re-derive from live domain
// state (server/src/control/) so a fixed problem disappears on its own.
model OperationalIssue {
  id           String @id @default(cuid())
  // Registry key (server/src/control/registry.js) — decides rendering + actions.
  type         String
  severity     String // 'critical' | 'warning' | 'info'
  sourceModule String // 'tours' | 'gallery' | 'whatsapp' | 'deals' | …

  // One NON-RESOLVED issue per real-world problem: `${type}:${entity id}`.
  // Deliberately not DB-unique — the lifecycle allows a resolved issue to
  // recur later as a NEW row; the service layer (raiseIssue) enforces
  // single-active per key.
  dedupeKey String

  title       String
  explanation String
  // Loose entity refs (no FKs — issues must survive entity deletion):
  // [{ type: 'tour_event'|'deal'|…, id, orderNo?, label? }]
  entityRefs  Json   @default("[]")
  // Type-specific payload for rendering + actions (diff lists, task ids, …).
  data        Json?

  // Lifecycle: open → acknowledged (operator saw it, keeps it out of the way)
  //            → resolved (fixed — by an action, or auto when the detector
  //            observes the underlying condition is gone).
  status         String    @default("open")
  detectedAt     DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  acknowledgedAt DateTime?
  acknowledgedBy String? // AdminUser.id (loose)
  resolvedAt     DateTime?
  resolvedBy     String? // AdminUser.id (loose); null = auto-resolved
  resolvedByName String?
  resolution     String? // 'auto' | action key that resolved it | 'requirements_complete'

  // The impact change/revision this issue currently reflects (Part 4). A
  // materially different change bumps the revision → new requirements, while the
  // previous revision's requirements + notification audit are preserved.
  revision String?

  requirements IssueRequirement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, severity, detectedAt])
  @@index([dedupeKey, status])
  @@index([sourceModule, status])
  @@index([type, status])
}

// A sub-requirement that must resolve before its parent OperationalIssue can
// close (Part 4). First-class lifecycle state — NOT a JSON blob. The parent
// issue closes only when EVERY requirement of the current revision is completed
// or waived.
//   kind:  customer_notification | calendar_sync | woo_sync | guide_notification | manual_decision
//   state: pending | in_progress | completed | failed | waived
model IssueRequirement {
  id             String              @id @default(cuid())
  issue          OperationalIssue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId        String
  revision       String // the impact revision this requirement belongs to
  kind           String
  state          String              @default("pending")
  note           String? // required for manual completion / waive
  resolvedAt     DateTime?
  resolvedBy     String? // AdminUser.id (loose)
  resolvedByName String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  notifications  IssueNotification[]

  // One requirement per (issue, revision, kind) → repeated reconciliation never
  // duplicates; a new revision creates a fresh set alongside the old audit.
  @@unique([issueId, revision, kind])
  @@index([issueId, state])
}

// One per (requirement × recipient × channel) customer notification (Part 4).
// The per-recipient send audit — snapshots the exact subject/body sent, the
// provider result, and retry history. Retrying updates the SAME row.
model IssueNotification {
  id             String           @id @default(cuid())
  requirement    IssueRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  requirementId  String
  recipientKey   String // stable identity: registrationId or dealId
  recipientName  String?
  address        String? // email address
  phone          String? // whatsapp phone
  channel        String // email | whatsapp
  subject        String? // snapshot of what was sent
  body           String? // snapshot of what was sent
  status         String           @default("pending") // pending | sent | failed
  sentAt         DateTime?
  attempts       Int              @default(0)
  providerResult Json? // provider payload / error (flexible)
  retryHistory   Json             @default("[]") // [{ at, status, error }]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([requirementId, recipientKey, channel])
  @@index([requirementId, status])
}

// ============================================================================
// Legacy Data Migration (Pipedrive + Airtable → GOS) — Slice 1 FOUNDATION ONLY
// ============================================================================
// The infrastructure spine for the one-time legacy migration. These three
// tables carry NO customer data yet — Slice 1 only creates the structures and
// their observability. Extraction (Slice 2), review (Slices 3-5), and imports
// (Slices 6+) fill them. See docs/architecture/GOS-migration-implementation-
// roadmap.md. Additive-only; nothing in the live app reads or writes these.
//
// Design follows proven GOS patterns: cuid ids + string status (live-schema
// convention), loose entity refs (no FK — survive entity deletion, like
// TimelineEntry.subjectId / OperationalIssue.entityRefs), claim-based resumable
// runs (like WhatsAppScheduledMessage / MaintenanceJob), and a stable source
// crosswalk key (like TicketRegistration external ids / PersonRef.externalPersonId).

// THE crosswalk + archive record. One row per legacy source record. Carries the
// raw preserved `payload` (Legacy Archive) + a curated `cardData` map for the
// "מידע ממערכת קודמת" card, and a LOOSE link to the GOS entity it became (filled
// at import time). The (sourceSystem, sourceType, sourceId) triple is the
// idempotency + reversibility key: extraction/import upsert on it, so re-runs
// never duplicate, and a whole import batch can be rolled back by batchId.
model LegacyRecord {
  id            String   @id @default(cuid())
  // 'pipedrive' | 'airtable' (validated in code — project convention, no enum).
  sourceSystem  String
  // e.g. 'deal' | 'person' | 'organization' | 'note' | 'activity' | 'deal_product'
  //      | 'deal_flow' | 'tour' | 'participant' | 'file' | … (source entity kind).
  sourceType    String
  // The legacy record id, as a string (Pipedrive numeric ids + Airtable recIds
  // both fit). Uniqueness is per (system, type) — see the compound unique.
  sourceId      String
  // The snapshot batch this row was last extracted from (set by Slice 2). Null
  // until first extracted.
  snapshotId    String?
  // The import batch that wrote the linked GOS entity (set by Slices 6+). Null
  // until imported; the handle for batch rollback until cutover.
  importBatchId String?
  // Raw preserved source record (the Legacy Archive payload). Never rendered as
  // JSON to users — the "View complete legacy archive" action renders it readably.
  payload       Json?
  // Curated label→value pairs for the permanent "מידע ממערכת קודמת" card
  // (owner, legacy stage, meaningful custom fields, pricing notes, Drive links…).
  // Shaped at import time from `payload` per the frozen mapping — no ids/JSON.
  cardData      Json?
  // LOOSE link to the migrated GOS entity (no FK — survives entity deletion,
  // same convention as TimelineEntry.subjectId). entityType e.g. 'Deal' |
  // 'Contact' | 'Organization' | 'TourEvent'.
  entityType    String?
  entityId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([sourceSystem, sourceType, sourceId])
  @@index([entityType, entityId])
  @@index([snapshotId])
  @@index([importBatchId])
  @@index([sourceSystem, sourceType])
}

// The migration review ledger — one row per decision the Review Center presents
// (org merge, contact dedup, name split, stage-config approval, exceptional
// record). The decision AUDIT is the point: who decided what, when, and the
// resolved action (which may differ from the proposal when edited). Seeding is
// idempotent via the (queue, subjectKey) unique, so re-building a queue from a
// fresh snapshot never duplicates rows.
model MigrationDecision {
  id            String    @id @default(cuid())
  // 'org_dedup' | 'contact_dedup' | 'name_cleanup' | 'stage_config' | 'exceptional'
  queue         String
  // Stable identity of the thing being decided (e.g. a normalized cluster key,
  // a legacy contact id). Unique per queue → idempotent re-seed.
  subjectKey    String
  // The proposed action + the evidence panel data (candidates, confidence, links).
  proposal      Json
  // 'pending' | 'approved' | 'rejected' | 'edited' (validated in code).
  status        String    @default("pending")
  // The resolved decision (equals the proposal for a plain approve; carries the
  // operator's edits otherwise). Null while pending.
  decision      Json?
  decidedBy     String? // AdminUser.id (loose)
  decidedByName String? // username snapshot (survives rename/deactivation)
  decidedAt     DateTime?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([queue, subjectKey])
  @@index([queue, status])
}

// The resumable-run spine. One row per unit of migration work (a snapshot, an
// extraction target, an import batch, a delta pass, a reconciliation). Claim-
// based like WhatsAppScheduledMessage / MaintenanceJob so a run survives
// restarts and can never be double-claimed across instances. `cursor` holds the
// resume position; `counters` the observable progress. History stays honest —
// a failed run keeps its error and is retried, never silently reset.
model MigrationRun {
  id         String    @id @default(cuid())
  // 'snapshot' | 'extract' | 'import' | 'delta' | 'reconcile' (validated in code).
  kind       String
  // What this run operates on, e.g. 'pipedrive.deals' | 'airtable.main' |
  // 'import.identity'. Null for whole-phase runs.
  target     String?
  // 'pending' | 'running' | 'done' | 'failed'.
  status     String    @default("pending")
  // The snapshot this run belongs to / produces (extraction + import trace back
  // to a snapshot). Null for runs that don't touch a snapshot.
  snapshotId String?
  // The import batch this run produced (import runs). Null otherwise.
  batchId    String?
  // Resume position (source-specific: pagination cursor, last id, table offset).
  cursor     Json?
  // Observable progress: { extracted, written, skipped, errors, total, … }.
  counters   Json?
  // Claim-based concurrency (atomic updateMany claim, same pattern as the
  // scheduled-message worker) so restarts/multiple instances are safe.
  claimedAt  DateTime?
  claimedBy  String?
  attempts   Int       @default(0)
  startedAt  DateTime?
  finishedAt DateTime?
  error      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([kind, status])
  @@index([status, claimedAt])
  @@index([snapshotId])
  @@index([batchId])
}
