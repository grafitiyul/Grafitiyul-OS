// Grafitiyul OS - Prisma schema (V1: Learning / Procedures module)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Nested organisational folder for the item bank. Folders can contain items
// (content + question) and/or other folders — no depth cap at the data level.
// parentId=null means the folder sits at the root. sortOrder is scoped by
// parent, so reindexing only touches siblings in the same parent.
// ON DELETE SET NULL on the self-relation mirrors the behaviour on items:
// deleting a parent unparents its children rather than cascading.
model ItemBankFolder {
  id            String           @id @default(cuid())
  name          String
  parent        ItemBankFolder?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: SetNull)
  parentId      String?
  children      ItemBankFolder[] @relation("FolderChildren")
  sortOrder     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  contentItems  ContentItem[]
  questionItems QuestionItem[]

  @@index([parentId, sortOrder])
}

// Reusable content item in the bank.
// `title` holds HTML (single-line TipTap output) so dynamic-field chips can
// live in the title. Plain-text titles remain valid HTML, so no migration is
// required for the column itself — only the read sites adapt.
model ContentItem {
  id           String          @id @default(cuid())
  title        String
  body         String          @default("")
  internalNote String?
  sortOrder    Int             @default(0)
  folder       ItemBankFolder? @relation(fields: [folderId], references: [id])
  folderId     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  flowNodes    FlowNode[]

  @@index([folderId, sortOrder])
}

// Reusable question item in the bank. Unified model — a single question
// can present predefined choices, a free-text field, or both, with a
// single `requirement` field controlling when an answer is required.
//
//   options          — choice labels; empty = no choices
//   allowTextAnswer  — show the free-text field to the learner
//   requirement      — one of:
//     'optional' — the question can be skipped
//     'choice'   — learner must select a choice (text is optional)
//     'text'     — learner must fill the text (choice is optional)
//     'any'      — learner must fill at least one of choice / text
//     'both'     — learner must fill both choice and text
//   Only the values that make sense for the current shape are allowed at
//   the API / editor layer; see lib/questionRequirement.js.
//
// `answerType` is kept as a deprecated column for one release cycle so
// a rollback is safe. New behaviour reads the three fields above and
// ignores answerType. The column will be removed in a follow-up slice.
model QuestionItem {
  id              String          @id @default(cuid())
  title           String
  questionText    String          @default("")
  answerType      String          // DEPRECATED — see block comment above
  options         String[]        @default([])
  allowTextAnswer Boolean         @default(false)
  requirement     String          @default("optional")
  internalNote    String?
  sortOrder       Int             @default(0)
  folder          ItemBankFolder? @relation(fields: [folderId], references: [id])
  folderId        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  flowNodes       FlowNode[]

  @@index([folderId, sortOrder])
}

// status: 'draft' | 'published'
// Assignment model: any of openToAll / team targets / person targets grants
// visibility to a learner (union). `mandatory` drives the ללמידה vs זמינים
// split in the learner portal — a non-mandatory visible flow sits in זמינים
// until the learner chooses to take it.
model Flow {
  id           String             @id @default(cuid())
  title        String
  description  String?
  status       String             @default("draft")
  sortOrder    Int                @default(0)
  openToAll    Boolean            @default(false)
  mandatory    Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  nodes        FlowNode[]
  attempts     Attempt[]
  targetTeams  FlowTargetTeam[]
  targetPeople FlowTargetPerson[]
}

// Recursive tree: a node is a content ref, question ref, or a group container.
// Groups can nest groups (no depth limit at the data level).
model FlowNode {
  id              String        @id @default(cuid())
  flow            Flow          @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId          String
  parent          FlowNode?     @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  parentId        String?
  children        FlowNode[]    @relation("NodeChildren")
  order           Int
  kind            String // 'content' | 'question' | 'group'
  contentItem     ContentItem?  @relation(fields: [contentItemId], references: [id])
  contentItemId   String?
  questionItem    QuestionItem? @relation(fields: [questionItemId], references: [id])
  questionItemId  String?
  groupTitle      String?
  checkpointAfter Boolean       @default(false)
  answers         FlowAnswer[]
  currentFor      Attempt[]     @relation("AttemptCurrentNode")
}

// status: 'in_progress' | 'submitted' | 'approved'
// A rejected question does NOT move the attempt to "rejected" — rejection
// lives only on FlowAnswer. An attempt becomes 'approved' only when every
// question's latest FlowAnswer has status='approved'.
//
// externalPersonId links an attempt to a PersonRef (the guide who took it)
// by their stable upstream id. Nullable to stay backward-compatible with
// pre-guide-management attempts that only carried learnerName. When real
// auth lands, this is the field the resolver will populate; nothing else
// in the attempt/answer pipeline needs to change.
model Attempt {
  id               String       @id @default(cuid())
  flow             Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId           String
  learnerName      String
  workerIdentifier String?
  externalPersonId String?
  status           String       @default("in_progress")
  currentNode      FlowNode?    @relation("AttemptCurrentNode", fields: [currentNodeId], references: [id])
  currentNodeId    String?
  submittedAt      DateTime?
  approvedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  answers          FlowAnswer[]

  @@index([externalPersonId])
}

// Versioned answer. Each worker edit appends a new row; existing rows are
// never mutated (except status/adminComment/reviewedAt when an admin reviews).
// status: 'pending' | 'approved' | 'rejected'
model FlowAnswer {
  id             String    @id @default(cuid())
  attempt        Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId      String
  flowNode       FlowNode  @relation(fields: [flowNodeId], references: [id], onDelete: Cascade)
  flowNodeId     String
  questionItemId String
  openText       String?
  answerChoice   String?
  answerLabel    String?
  version        Int
  status         String    @default("pending")
  adminComment   String?
  createdAt      DateTime  @default(now())
  reviewedAt     DateTime?

  @@unique([attemptId, flowNodeId, version])
  @@index([attemptId, flowNodeId])
}

// Embedded media uploaded by admins and referenced inside item HTML.
// `bytes` holds the raw file. The content is immutable for a given id.
// kind: 'image' | 'video'
model MediaAsset {
  id        String   @id @default(cuid())
  kind      String
  mimeType  String
  filename  String
  byteSize  Int
  bytes     Bytes
  createdAt DateTime @default(now())
}

// ============================================================================
// Business Documents module (V1)
// ============================================================================

// Global fixed fields (company name, VAT, bank details, etc.). Referenced by
// DocumentField.valueSource = 'business_field'. Editing the value here is
// reflected in draft instances (live preview), never in finalized ones
// (instance carries its own frozen field snapshot).
model BusinessField {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  // Bilingual values — each field carries its Hebrew and English text so
  // documents can render either language without duplicating field rows.
  valueHe   String   @default("")
  valueEn   String   @default("")
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A signer (person or entity). Has identity + free-form extra fields map
// (e.g. supplier_code, national_id). Extra fields are document-specific —
// they're referenced by DocumentField.signerFieldKey.
model SignerPerson {
  id          String        @id @default(cuid())
  displayName String
  role        String?
  email       String?
  phone       String?
  extraFields Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  assets      SignerAsset[]
}

// Signature / stamp / combined asset. renderedBytes is canonical (PNG) and
// used by all document renders. drawBytes + stampConfigJson are retained
// informationally for 'combined' re-composition or stamp re-render.
// assetType: 'draw' | 'stamp' | 'combined'
model SignerAsset {
  id              String       @id @default(cuid())
  person          SignerPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId        String
  assetType       String
  label           String?
  renderedBytes   Bytes
  drawBytes       Bytes?
  stampConfigJson Json?
  byteSize        Int
  createdAt       DateTime     @default(now())

  @@index([personId])
}

// The ORIGINAL uploaded file. V1 = PDF only. Immutable for a given id.
model DocumentSource {
  id         String             @id @default(cuid())
  filename   String
  mimeType   String
  sourceKind String
  bytes      Bytes
  byteSize   Int
  createdAt  DateTime           @default(now())
  snapshots  DocumentSnapshot[]
}

// A stable PDF rendering of a DocumentSource. V1 generator = 'passthrough'
// (PDF source → same bytes; no conversion). Reserved for future Word/Excel
// support without schema churn.
model DocumentSnapshot {
  id               String             @id @default(cuid())
  source           DocumentSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId         String
  pdfBytes         Bytes
  pageCount        Int
  generator        String             @default("passthrough")
  generatorVersion String             @default("v1")
  createdAt        DateTime           @default(now())
  templates        DocumentTemplate[]
}

// Reusable template: a named wrapper around a snapshot + a set of fields.
// Editing fields is ONLY allowed when no instance exists. Deleting is blocked
// if instances exist.
model DocumentTemplate {
  id          String             @id @default(cuid())
  title       String
  description String?
  snapshot    DocumentSnapshot   @relation(fields: [snapshotId], references: [id])
  snapshotId  String
  status      String             @default("draft") // 'draft' | 'published'
  origin      String             @default("library") // 'adhoc' | 'library'
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  fields      DocumentField[]
  instances   DocumentInstance[]

  @@index([origin])
}

// A placement on the template PDF. Percentage coordinates (0..100) from the
// page top-left. valueSource + the matching reference column determine what
// value the field gets at render time.
//
// fieldType:    'text' | 'signature' | 'stamp' | 'date' | 'number' | 'email' | 'phone'
// valueSource:  'business_field' | 'signer_field' | 'signer_asset' | 'static' | 'override_only'
// signerAssetMode: 'draw' | 'stamp' | 'combined'
model DocumentField {
  id              String           @id @default(cuid())
  template        DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId      String
  page            Int
  xPct            Float
  yPct            Float
  wPct            Float
  hPct            Float
  fieldType       String
  label           String           @default("")
  required        Boolean          @default(false)
  order           Int              @default(0)
  valueSource     String           @default("override_only")
  businessFieldId String?
  signerPersonId  String?
  signerFieldKey  String?
  signerAssetMode String?
  staticValue     String?
  // Language selector for business_field resolution. Defaults to Hebrew.
  language        String  @default("he") // 'he' | 'en'

  @@index([templateId, page])
}

// A specific use of a template. ALWAYS carries its own frozen field list and
// PDF bytes so later template/field/snapshot edits cannot mutate it.
// status: 'draft' | 'finalized'
model DocumentInstance {
  id                String                     @id @default(cuid())
  template          DocumentTemplate           @relation(fields: [templateId], references: [id])
  templateId        String
  title             String
  status            String                     @default("draft")
  fieldsSnapshot    Json // frozen DocumentField list at create time
  snapshotPdfBytes  Bytes // frozen PDF bytes at create time
  snapshotPageCount Int
  businessSnapshot  Json // frozen BusinessField map (key → value) at create time
  signersSnapshot   Json // frozen SignerPerson (+ assets) list at create time
  // Free-form visual annotations (check/x/highlight/line/note). Separate
  // from fieldsSnapshot so annotations never flow through value resolution.
  annotationsSnapshot Json                     @default("[]")
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  finalizedAt       DateTime?
  overrides         DocumentInstanceOverride[]
  finalDocuments    FinalDocument[]

  @@index([templateId])
}

// Per-field override scoped to one instance. Never mutates global values.
// A field can have at most one override row. Either textValue (for text-like
// fields) or assetBytes (for signature/stamp uploads).
model DocumentInstanceOverride {
  id              String           @id @default(cuid())
  instance        DocumentInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  instanceId      String
  snapshotFieldId String // id from the frozen fieldsSnapshot
  textValue       String?
  assetBytes      Bytes?
  updatedAt       DateTime         @updatedAt

  @@unique([instanceId, snapshotFieldId])
}

// The rendered final PDF for an instance. Append-only audit trail (one row
// per finalization; V1 finalizes once and locks the instance).
model FinalDocument {
  id               String           @id @default(cuid())
  instance         DocumentInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  instanceId       String
  pdfBytes         Bytes
  pdfSize          Int
  generatorVersion String           @default("v1")
  generatedAt      DateTime         @default(now())

  @@index([instanceId])
}

// ============================================================================
// Guide Management module — people + teams + flow assignment
// ============================================================================

// Team — managed natively in this system. The recruitment system is NOT
// a source of truth for teams (it doesn't model teams at all), so TeamRef
// has no external id. Admins create, rename, and delete teams here; guide
// ↔ team membership is managed here too via PersonRef.teamRefId.
model TeamRef {
  id          String           @id @default(cuid())
  displayName String
  meta        Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  members     PersonRef[]
  flowTargets FlowTargetTeam[]
}

// Identity layer for a guide. Today `identitySource='recruitment'` means
// name / email / phone are a read-only mirror of the upstream recruitment
// record. When management takes over as source of truth for a given
// person, the flag flips to 'management' and the same fields become
// writable here — with NO schema migration required.
//
// `externalPersonId` is stable across that ownership transition. All
// procedures data (FlowTargetPerson, Attempt.externalPersonId) references
// this id — not PersonRef.id — so ownership flips never break audit or
// assignment data.
//
// `portalToken` is the learner portal's only auth for now (see CLAUDE.md
// §12). It is regenerated on demand by the admin; `portalEnabled=false`
// blocks access even when the token is known.
model PersonRef {
  id               String             @id @default(cuid())
  externalPersonId String             @unique
  identitySource   String             @default("recruitment") // 'recruitment' | 'management'
  displayName      String
  email            String?
  phone            String?
  identitySyncedAt DateTime?
  status           String             @default("active") // 'active' | 'blocked'
  team             TeamRef?           @relation(fields: [teamRefId], references: [id])
  teamRefId        String?
  portalToken      String             @unique
  portalEnabled    Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  profile          PersonProfile?
  flowTargets      FlowTargetPerson[]

  @@index([teamRefId])
}

// Operational data, always owned by management. Split out from PersonRef so
// the identity-vs-operational authority line is structural, not
// convention-based. One-to-one with PersonRef.
model PersonProfile {
  personRef    PersonRef @relation(fields: [personRefId], references: [id], onDelete: Cascade)
  personRefId  String    @id
  imageUrl     String?
  description  String?
  notes        String?
  bankDetails  Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Flow → teams assignment. The WHERE for "flows visible to team T" indexes
// on teamRefId, which is why this is a join table (not a string[] column
// on Flow).
model FlowTargetTeam {
  flow       Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId     String
  teamRef    TeamRef  @relation(fields: [teamRefId], references: [id], onDelete: Cascade)
  teamRefId  String
  assignedAt DateTime @default(now())

  @@id([flowId, teamRefId])
  @@index([teamRefId])
}

// Flow → people assignment. FK is to PersonRef, but the stable handle is
// externalPersonId — callers that resolve "flows for this person" should
// match on externalPersonId so data survives PersonRef row reshuffles.
model FlowTargetPerson {
  flow        Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId      String
  personRef   PersonRef @relation(fields: [personRefId], references: [id], onDelete: Cascade)
  personRefId String
  assignedAt  DateTime  @default(now())

  @@id([flowId, personRefId])
  @@index([personRefId])
}
