// Grafitiyul OS - Prisma schema (V1: Learning / Procedures module)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Reusable content item in the bank
model ContentItem {
  id           String     @id @default(cuid())
  title        String
  body         String     @default("")
  internalNote String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  flowNodes    FlowNode[]
}

// Reusable question item in the bank
// answerType: 'open_text' | 'single_choice'
model QuestionItem {
  id           String     @id @default(cuid())
  title        String
  questionText String     @default("")
  answerType   String
  options      String[]   @default([])
  internalNote String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  flowNodes    FlowNode[]
}

// status: 'draft' | 'published'
model Flow {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      String     @default("draft")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  nodes       FlowNode[]
  attempts    Attempt[]
}

// Recursive tree: a node is a content ref, question ref, or a group container.
// Groups can nest groups (no depth limit at the data level).
model FlowNode {
  id              String        @id @default(cuid())
  flow            Flow          @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId          String
  parent          FlowNode?     @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  parentId        String?
  children        FlowNode[]    @relation("NodeChildren")
  order           Int
  kind            String // 'content' | 'question' | 'group'
  contentItem     ContentItem?  @relation(fields: [contentItemId], references: [id])
  contentItemId   String?
  questionItem    QuestionItem? @relation(fields: [questionItemId], references: [id])
  questionItemId  String?
  groupTitle      String?
  checkpointAfter Boolean       @default(false)
  answers         FlowAnswer[]
  currentFor      Attempt[]     @relation("AttemptCurrentNode")
}

// status: 'in_progress' | 'submitted' | 'approved'
// A rejected question does NOT move the attempt to "rejected" — rejection
// lives only on FlowAnswer. An attempt becomes 'approved' only when every
// question's latest FlowAnswer has status='approved'.
model Attempt {
  id               String       @id @default(cuid())
  flow             Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId           String
  learnerName      String
  workerIdentifier String?
  status           String       @default("in_progress")
  currentNode      FlowNode?    @relation("AttemptCurrentNode", fields: [currentNodeId], references: [id])
  currentNodeId    String?
  submittedAt      DateTime?
  approvedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  answers          FlowAnswer[]
}

// Versioned answer. Each worker edit appends a new row; existing rows are
// never mutated (except status/adminComment/reviewedAt when an admin reviews).
// status: 'pending' | 'approved' | 'rejected'
model FlowAnswer {
  id             String    @id @default(cuid())
  attempt        Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId      String
  flowNode       FlowNode  @relation(fields: [flowNodeId], references: [id], onDelete: Cascade)
  flowNodeId     String
  questionItemId String
  openText       String?
  answerChoice   String?
  answerLabel    String?
  version        Int
  status         String    @default("pending")
  adminComment   String?
  createdAt      DateTime  @default(now())
  reviewedAt     DateTime?

  @@unique([attemptId, flowNodeId, version])
  @@index([attemptId, flowNodeId])
}

// Embedded media uploaded by admins and referenced inside item HTML.
// `bytes` holds the raw file. The content is immutable for a given id.
// kind: 'image' | 'video'
model MediaAsset {
  id        String   @id @default(cuid())
  kind      String
  mimeType  String
  filename  String
  byteSize  Int
  bytes     Bytes
  createdAt DateTime @default(now())
}
