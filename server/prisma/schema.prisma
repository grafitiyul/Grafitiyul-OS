// Grafitiyul OS - Prisma schema (V1: Learning / Procedures module)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Internal admin user. The whole point of this table is to take admin
// credentials OFF Railway env vars and INTO the DB so the user can
// manage them from inside the system.
//
// Bootstrap rule (enforced server-side, see auth.js):
//   * Zero ACTIVE admins → /admin is reachable, POST /api/auth/setup
//     creates the first user. No login required.
//   * One+ active admins → /admin requires a valid session, /setup is
//     locked out (403). The "first-user-wins" pattern.
//
// `passwordHash` is a scrypt KDF output ("<saltHex>:<derivedKeyHex>") —
// no plaintext, no need for an external bcrypt/argon2 dependency.
// `role` is reserved for future role-based access; today everyone is
// 'admin'. `isActive=false` is a soft-delete; the bootstrap count
// only considers active users so a deactivated admin doesn't
// re-open bootstrap mode.
model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         String    @default("admin")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Nested organisational folder for the item bank. Folders can contain items
// (content + question) and/or other folders — no depth cap at the data level.
// parentId=null means the folder sits at the root. sortOrder is scoped by
// parent, so reindexing only touches siblings in the same parent.
// ON DELETE SET NULL on the self-relation mirrors the behaviour on items:
// deleting a parent unparents its children rather than cascading.
model ItemBankFolder {
  id            String           @id @default(cuid())
  name          String
  parent        ItemBankFolder?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: SetNull)
  parentId      String?
  children      ItemBankFolder[] @relation("FolderChildren")
  sortOrder     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  contentItems  ContentItem[]
  questionItems QuestionItem[]
  // Reverse relation for FlowNode.kind='folderRef' — flow nodes that
  // include this folder by reference. SetNull on delete (mirrored on
  // FlowNode.bankFolder) so deleting a referenced bank folder
  // gracefully degrades the folderRef to an empty block instead of
  // orphaning rows.
  flowNodeRefs  FlowNode[]       @relation("FlowNodeBankFolderRef")

  @@index([parentId, sortOrder])
}

// Reusable content item in the bank.
// `title` holds HTML (single-line TipTap output) so dynamic-field chips can
// live in the title. Plain-text titles remain valid HTML, so no migration is
// required for the column itself — only the read sites adapt.
model ContentItem {
  id           String          @id @default(cuid())
  title        String
  body         String          @default("")
  internalNote String?
  sortOrder    Int             @default(0)
  folder       ItemBankFolder? @relation(fields: [folderId], references: [id])
  folderId     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  flowNodes    FlowNode[]

  @@index([folderId, sortOrder])
}

// Reusable question item in the bank. Unified model — a single question
// can present predefined choices, a free-text field, or both, with a
// single `requirement` field controlling when an answer is required.
//
//   options          — choice labels; empty = no choices
//   allowTextAnswer  — show the free-text field to the learner
//   requirement      — one of:
//     'optional' — the question can be skipped
//     'choice'   — learner must select a choice (text is optional)
//     'text'     — learner must fill the text (choice is optional)
//     'any'      — learner must fill at least one of choice / text
//     'both'     — learner must fill both choice and text
//   Only the values that make sense for the current shape are allowed at
//   the API / editor layer; see lib/questionRequirement.js.
//
// `answerType` is kept as a deprecated column for one release cycle so
// a rollback is safe. New behaviour reads the three fields above and
// ignores answerType. The column will be removed in a follow-up slice.
model QuestionItem {
  id              String          @id @default(cuid())
  title           String
  questionText    String          @default("")
  answerType      String // DEPRECATED — see block comment above
  options         String[]        @default([])
  allowTextAnswer Boolean         @default(false)
  requirement     String          @default("optional")
  internalNote    String?
  sortOrder       Int             @default(0)
  folder          ItemBankFolder? @relation(fields: [folderId], references: [id])
  folderId        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  flowNodes       FlowNode[]

  @@index([folderId, sortOrder])
}

// status: 'draft' | 'published'
// Assignment model: any of openToAll / team targets / person targets grants
// visibility to a learner (union). `mandatory` drives the ללמידה vs זמינים
// split in the learner portal — a non-mandatory visible flow sits in זמינים
// until the learner chooses to take it.
model Flow {
  id           String             @id @default(cuid())
  title        String
  description  String?
  status       String             @default("draft")
  sortOrder    Int                @default(0)
  openToAll    Boolean            @default(false)
  mandatory    Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  nodes        FlowNode[]
  attempts     Attempt[]
  targetTeams  FlowTargetTeam[]
  targetPeople FlowTargetPerson[]
}

// Recursive tree: a node is a content ref, question ref, group container,
// or a folderRef — a reference to a bank folder. The folderRef is
// authoring-time only; at attempt creation time the referenced folder
// is snapshotted into Attempt.expansion so in-flight attempts don't
// see structural changes the admin makes to the bank folder. Item
// CONTENT (titles, bodies, options) still resolves live by id, so
// typo fixes / wording changes propagate to in-flight attempts. Only
// the FOLDER STRUCTURE is frozen per attempt.
model FlowNode {
  id              String          @id @default(cuid())
  flow            Flow            @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId          String
  parent          FlowNode?       @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  parentId        String?
  children        FlowNode[]      @relation("NodeChildren")
  order           Int
  kind            String // 'content' | 'question' | 'group' | 'folderRef'
  contentItem     ContentItem?    @relation(fields: [contentItemId], references: [id])
  contentItemId   String?
  questionItem    QuestionItem?   @relation(fields: [questionItemId], references: [id])
  questionItemId  String?
  groupTitle      String?
  checkpointAfter Boolean         @default(false)
  // Set when kind='folderRef'. SetNull so deleting the bank folder
  // degrades the folderRef to an empty block; the flow node row stays
  // (preserves admin's intent) but the runtime expansion sees no
  // contents.
  bankFolder      ItemBankFolder? @relation("FlowNodeBankFolderRef", fields: [bankFolderId], references: [id], onDelete: SetNull)
  bankFolderId    String?
  answers         FlowAnswer[]
  currentFor      Attempt[]       @relation("AttemptCurrentNode")

  @@index([bankFolderId])
}

// status: 'in_progress' | 'submitted' | 'approved'
// A rejected question does NOT move the attempt to "rejected" — rejection
// lives only on FlowAnswer. An attempt becomes 'approved' only when every
// question's latest FlowAnswer has status='approved'.
//
// externalPersonId links an attempt to a PersonRef (the guide who took it)
// by their stable upstream id. Nullable to stay backward-compatible with
// pre-guide-management attempts that only carried learnerName. When real
// auth lands, this is the field the resolver will populate; nothing else
// in the attempt/answer pipeline needs to change.
model Attempt {
  id               String       @id @default(cuid())
  flow             Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId           String
  learnerName      String
  workerIdentifier String?
  externalPersonId String?
  status           String       @default("in_progress")
  // Authoring-side cursor (deprecated). Kept for legacy attempts that
  // predate `expansion`. New runtime uses `currentStepId` against the
  // expansion. Old attempts (expansion=null) still use this.
  currentNode      FlowNode?    @relation("AttemptCurrentNode", fields: [currentNodeId], references: [id])
  currentNodeId    String?
  // Per-attempt resolved step list. Snapshots folderRef expansion so
  // bank structural changes don't disrupt in-flight attempts. Item
  // CONTENT still resolves live by id (typo fixes etc.). null on
  // legacy attempts created before this slice — runtime falls back to
  // computing from flow.nodes.
  expansion        Json?
  // Stable step id within `expansion`. For non-folderRef steps this
  // matches the FlowNode id; for folderRef-expanded steps it's a
  // synthetic id of the form `<folderRefNodeId>::<bankItemId>`.
  currentStepId    String?
  submittedAt      DateTime?
  approvedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  answers          FlowAnswer[]

  @@index([externalPersonId])
}

// Versioned answer. Each worker edit appends a new row; existing rows are
// never mutated (except status/adminComment/reviewedAt when an admin reviews).
// status: 'pending' | 'approved' | 'rejected'
//
// `stepId` (not `flowNodeId`) is the canonical identity used by the new
// runtime. For non-folderRef steps stepId == flowNodeId. For folderRef-
// expanded steps stepId is synthetic (`<folderRefNodeId>::<bankItemId>`)
// and flowNodeId is null — there's no real FlowNode row for those.
// Legacy answers had flowNodeId set; the migration backfills stepId =
// flowNodeId so they keep working.
model FlowAnswer {
  id             String    @id @default(cuid())
  attempt        Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId      String
  // Real FlowNode link — kept for non-folderRef steps so reviews and
  // legacy queries that join on flowNodeId still work. Nullable for
  // folderRef-expanded steps.
  flowNode       FlowNode? @relation(fields: [flowNodeId], references: [id], onDelete: Cascade)
  flowNodeId     String?
  // Attempt-stable step identifier. Matches expansion.steps[].stepId.
  stepId         String
  questionItemId String
  openText       String?
  answerChoice   String?
  answerLabel    String?
  version        Int
  status         String    @default("pending")
  adminComment   String?
  createdAt      DateTime  @default(now())
  reviewedAt     DateTime?

  @@unique([attemptId, stepId, version])
  @@index([attemptId, stepId])
}

// Embedded media uploaded by admins and referenced inside item HTML.
// `bytes` holds the raw file. The content is immutable for a given id.
// kind: 'image' | 'video'
model MediaAsset {
  id        String   @id @default(cuid())
  kind      String
  mimeType  String
  filename  String
  byteSize  Int
  bytes     Bytes
  createdAt DateTime @default(now())
}

// ============================================================================
// Business Documents module (V1)
// ============================================================================

// Global fixed fields (company name, VAT, bank details, etc.). Referenced by
// DocumentField.valueSource = 'business_field'. Editing the value here is
// reflected in draft instances (live preview), never in finalized ones
// (instance carries its own frozen field snapshot).
model BusinessField {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  // Bilingual values — each field carries its Hebrew and English text so
  // documents can render either language without duplicating field rows.
  valueHe   String   @default("")
  valueEn   String   @default("")
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A signer (person or entity). Has identity + free-form extra fields map
// (e.g. supplier_code, national_id). Extra fields are document-specific —
// they're referenced by DocumentField.signerFieldKey.
model SignerPerson {
  id          String        @id @default(cuid())
  displayName String
  role        String?
  email       String?
  phone       String?
  extraFields Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  assets      SignerAsset[]
}

// Signature / stamp / combined asset. renderedBytes is canonical (PNG) and
// used by all document renders. drawBytes + stampConfigJson are retained
// informationally for 'combined' re-composition or stamp re-render.
// assetType: 'draw' | 'stamp' | 'combined'
model SignerAsset {
  id              String       @id @default(cuid())
  person          SignerPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId        String
  assetType       String
  label           String?
  renderedBytes   Bytes
  drawBytes       Bytes?
  stampConfigJson Json?
  byteSize        Int
  createdAt       DateTime     @default(now())

  @@index([personId])
}

// The ORIGINAL uploaded file. V1 = PDF only. Immutable for a given id.
model DocumentSource {
  id         String             @id @default(cuid())
  filename   String
  mimeType   String
  sourceKind String
  bytes      Bytes
  byteSize   Int
  createdAt  DateTime           @default(now())
  snapshots  DocumentSnapshot[]
}

// A stable PDF rendering of a DocumentSource. V1 generator = 'passthrough'
// (PDF source → same bytes; no conversion). Reserved for future Word/Excel
// support without schema churn.
model DocumentSnapshot {
  id               String             @id @default(cuid())
  source           DocumentSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId         String
  pdfBytes         Bytes
  pageCount        Int
  generator        String             @default("passthrough")
  generatorVersion String             @default("v1")
  createdAt        DateTime           @default(now())
  templates        DocumentTemplate[]
}

// Reusable template: a named wrapper around a snapshot + a set of fields.
// Editing fields is ONLY allowed when no instance exists. Deleting is blocked
// if instances exist.
model DocumentTemplate {
  id          String             @id @default(cuid())
  title       String
  description String?
  snapshot    DocumentSnapshot   @relation(fields: [snapshotId], references: [id])
  snapshotId  String
  status      String             @default("draft") // 'draft' | 'published'
  origin      String             @default("library") // 'adhoc' | 'library'
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  fields      DocumentField[]
  instances   DocumentInstance[]

  @@index([origin])
}

// A placement on the template PDF. Percentage coordinates (0..100) from the
// page top-left. valueSource + the matching reference column determine what
// value the field gets at render time.
//
// fieldType:    'text' | 'signature' | 'stamp' | 'date' | 'number' | 'email' | 'phone'
// valueSource:  'business_field' | 'signer_field' | 'signer_asset' | 'static' | 'override_only'
// signerAssetMode: 'draw' | 'stamp' | 'combined'
model DocumentField {
  id              String           @id @default(cuid())
  template        DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId      String
  page            Int
  xPct            Float
  yPct            Float
  wPct            Float
  hPct            Float
  fieldType       String
  label           String           @default("")
  required        Boolean          @default(false)
  order           Int              @default(0)
  valueSource     String           @default("override_only")
  businessFieldId String?
  signerPersonId  String?
  signerFieldKey  String?
  signerAssetMode String?
  staticValue     String?
  // Language selector for business_field resolution. Defaults to Hebrew.
  language        String           @default("he") // 'he' | 'en'

  @@index([templateId, page])
}

// A specific use of a template. ALWAYS carries its own frozen field list and
// PDF bytes so later template/field/snapshot edits cannot mutate it.
// status: 'draft' | 'finalized'
model DocumentInstance {
  id                  String                     @id @default(cuid())
  template            DocumentTemplate           @relation(fields: [templateId], references: [id])
  templateId          String
  title               String
  status              String                     @default("draft")
  fieldsSnapshot      Json // frozen DocumentField list at create time
  snapshotPdfBytes    Bytes // frozen PDF bytes at create time
  snapshotPageCount   Int
  businessSnapshot    Json // frozen BusinessField map (key → value) at create time
  signersSnapshot     Json // frozen SignerPerson (+ assets) list at create time
  // Free-form visual annotations (check/x/highlight/line/note). Separate
  // from fieldsSnapshot so annotations never flow through value resolution.
  annotationsSnapshot Json                       @default("[]")
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  finalizedAt         DateTime?
  overrides           DocumentInstanceOverride[]
  finalDocuments      FinalDocument[]

  @@index([templateId])
}

// Per-field override scoped to one instance. Never mutates global values.
// A field can have at most one override row. Either textValue (for text-like
// fields) or assetBytes (for signature/stamp uploads).
model DocumentInstanceOverride {
  id              String           @id @default(cuid())
  instance        DocumentInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  instanceId      String
  snapshotFieldId String // id from the frozen fieldsSnapshot
  textValue       String?
  assetBytes      Bytes?
  updatedAt       DateTime         @updatedAt

  @@unique([instanceId, snapshotFieldId])
}

// The rendered final PDF for an instance. Append-only audit trail (one row
// per finalization; V1 finalizes once and locks the instance).
model FinalDocument {
  id               String           @id @default(cuid())
  instance         DocumentInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  instanceId       String
  pdfBytes         Bytes
  pdfSize          Int
  generatorVersion String           @default("v1")
  generatedAt      DateTime         @default(now())

  @@index([instanceId])
}

// ============================================================================
// Guide Management module — people + teams + flow assignment
// ============================================================================

// Team — managed natively in this system. The recruitment system is NOT
// a source of truth for teams (it doesn't model teams at all), so TeamRef
// has no external id. Admins create, rename, and delete teams here; guide
// ↔ team membership is managed here too via PersonRef.teamRefId.
model TeamRef {
  id          String           @id @default(cuid())
  displayName String
  meta        Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  members     PersonRef[]
  flowTargets FlowTargetTeam[]
}

// Identity layer for a guide. Today `identitySource='recruitment'` means
// name / email / phone are a read-only mirror of the upstream recruitment
// record. When management takes over as source of truth for a given
// person, the flag flips to 'management' and the same fields become
// writable here — with NO schema migration required.
//
// `externalPersonId` is stable across that ownership transition. All
// procedures data (FlowTargetPerson, Attempt.externalPersonId) references
// this id — not PersonRef.id — so ownership flips never break audit or
// assignment data.
//
// `portalToken` is the learner portal's only auth for now (see CLAUDE.md
// §12). It is regenerated on demand by the admin; `portalEnabled=false`
// blocks access even when the token is known.
model PersonRef {
  id               String             @id @default(cuid())
  externalPersonId String             @unique
  identitySource   String             @default("recruitment") // 'recruitment' | 'management'
  displayName      String
  email            String?
  phone            String?
  identitySyncedAt DateTime?
  status           String             @default("active") // 'active' | 'blocked'
  team             TeamRef?           @relation(fields: [teamRefId], references: [id])
  teamRefId        String?
  portalToken      String             @unique
  portalEnabled    Boolean            @default(true)
  // Lifecycle hint from the upstream source-of-truth (recruitment).
  // Stable mappable values: 'trainee' | 'staff' | 'evaluator'.
  // Hebrew labels live in the client; the server NEVER reads display
  // text. Null means upstream didn't tell us (older guides, or upstream
  // hasn't shipped the field yet).
  lifecycleHint    String?
  // Audit timestamps for the access grant. portalEnabled is the gate;
  // these two record WHEN it last flipped, for the access UI to show
  // "granted X days ago" / "revoked Y days ago". They are independent
  // of the upstream lifecycle and never touched by sync.
  accessGrantedAt  DateTime?
  accessRevokedAt  DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  profile          PersonProfile?
  flowTargets      FlowTargetPerson[]

  @@index([teamRefId])
}

// Operational data, always owned by management. Split out from PersonRef so
// the identity-vs-operational authority line is structural, not
// convention-based. One-to-one with PersonRef.
model PersonProfile {
  personRef   PersonRef @relation(fields: [personRefId], references: [id], onDelete: Cascade)
  personRefId String    @id
  imageUrl    String?
  description String?
  notes       String?
  bankDetails Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Flow → teams assignment. The WHERE for "flows visible to team T" indexes
// on teamRefId, which is why this is a join table (not a string[] column
// on Flow).
model FlowTargetTeam {
  flow       Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId     String
  teamRef    TeamRef  @relation(fields: [teamRefId], references: [id], onDelete: Cascade)
  teamRefId  String
  assignedAt DateTime @default(now())

  @@id([flowId, teamRefId])
  @@index([teamRefId])
}

// Flow → people assignment. FK is to PersonRef, but the stable handle is
// externalPersonId — callers that resolve "flows for this person" should
// match on externalPersonId so data survives PersonRef row reshuffles.
model FlowTargetPerson {
  flow        Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId      String
  personRef   PersonRef @relation(fields: [personRefId], references: [id], onDelete: Cascade)
  personRefId String
  assignedAt  DateTime  @default(now())

  @@id([flowId, personRefId])
  @@index([personRefId])
}

// ============================================================================
// CRM module (Phase 1 foundation) — Organizations, Units, Contacts
// ============================================================================
//
// This is the reference-data foundation for the future Deals/Activities
// workflow (the Pipedrive replacement). Phase 1 builds ONLY foundation:
// Organizations, Organization Units, Organization Types, Contacts, phones,
// emails, and contact↔organization links. NO Deals, NO Activities, NO
// WhatsApp/Gmail/iCount/automation yet.
//
// Conventions: this slice follows the LIVE app conventions (cuid ids, string
// status/type fields, no Postgres enums/citext) for consistency with the
// existing 20+ models. The Phase-0 design (UUID v7 + enums + citext +
// timestamptz, see docs/architecture/) remains the FUTURE TARGET applied during
// the governed migration — not here.
//
// Source-of-truth notes:
//   * Organization is the parent; Organization Units (departments/divisions)
//     belong to it. An Organization may have zero units.
//   * Organization Type belongs to the Organization (School/Corporate/…). It
//     will later drive pricing, quote wording, payment terms, templates.
//   * Organization SUBTYPE does NOT belong to the Organization — it belongs to
//     the future Deal. OrganizationSubtype here is a prepared catalog with NO
//     consumer yet; a Deal will reference it once Deals are built.
//   * Finance fields exist on both Organization and Organization Unit to support
//     the future resolution priority: Deal override → Unit → Organization →
//     Organization Type defaults. That resolution is NOT implemented yet.

// Configurable organization type. `key` is the stable internal key (logic never
// reads the Hebrew label). Will later affect pricing/templates/terms/workflows.
model OrganizationType {
  id                 String                @id @default(cuid())
  key                String                @unique
  label              String // Hebrew display label
  labelEn            String?
  // Quote content owned by the org classification (rich HTML). Inserted into
  // future quotes by selected type/subtype. NOT wired to Quotes yet.
  quoteContentHe     String?
  quoteContentEn     String?
  sortOrder          Int                   @default(0)
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  organizations      Organization[]
  subtypes           OrganizationSubtype[]
  // Deals that point directly at this type (used only while a deal has no linked
  // Organization — see Deal.organizationType).
  deals              Deal[]
  // Pricing (Slice 2): default price list for deals of this org type. Subtype
  // overrides this. Null → fall back to the system default price list.
  defaultPriceList   PriceList?            @relation("OrgTypeDefaultPriceList", fields: [defaultPriceListId], references: [id], onDelete: SetNull)
  defaultPriceListId String?

  // Payment defaults (additive). The terms/methods CATALOG is owned by Payment
  // Configuration (PaymentTerm/PaymentMethod) — we only reference it, never copy
  // it. `defaultPaymentMethod` is an OPTIONAL OVERRIDE: when null, the effective
  // method is INHERITED from the chosen term's own default
  // (PaymentTerm.defaultPaymentMethod). When set, it overrides that inherited
  // value. NOT wired to Quotes/Deals yet.
  defaultPaymentTerm     PaymentTerm?   @relation("OrgTypeDefaultPaymentTerm", fields: [defaultPaymentTermId], references: [id], onDelete: SetNull)
  defaultPaymentTermId   String?
  defaultPaymentMethod   PaymentMethod? @relation("OrgTypeDefaultPaymentMethod", fields: [defaultPaymentMethodId], references: [id], onDelete: SetNull)
  defaultPaymentMethodId String?
  paymentTermsNote       String?

  @@index([sortOrder])
}

// Subtype belongs to the DEAL, not the Organization. Prepared as a catalog now;
// it has NO consumer until Deals exist (a Deal will reference a subtype). May be
// scoped to an OrganizationType (e.g. School → Teachers / Students).
model OrganizationSubtype {
  id                 String            @id @default(cuid())
  key                String            @unique
  label              String
  labelEn            String?
  // Quote content owned by the org classification (rich HTML). Overrides the
  // type's content when set. Inserted into future quotes. NOT wired to Quotes yet.
  quoteContentHe     String?
  quoteContentEn     String?
  organizationType   OrganizationType? @relation(fields: [organizationTypeId], references: [id], onDelete: SetNull)
  organizationTypeId String?
  sortOrder          Int               @default(0)
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deals              Deal[]
  // Pricing (Slice 2): default price list for this subtype. Overrides the
  // OrganizationType default. Null → fall back to the type / system default.
  defaultPriceList   PriceList?        @relation("OrgSubtypeDefaultPriceList", fields: [defaultPriceListId], references: [id], onDelete: SetNull)
  defaultPriceListId String?
  priceRules         PriceRule[]
  pricingSegments    PricingSegment[]

  @@index([organizationTypeId])
}

// The parent organization. Departments/divisions are OrganizationUnit children.
// Finance fields are optional — many organizations have no departments. When a
// Deal is tied to a Unit, the Unit's finance values normally win (see resolution
// priority above).
model Organization {
  id                 String                @id @default(cuid())
  name               String
  organizationType   OrganizationType?     @relation(fields: [organizationTypeId], references: [id], onDelete: SetNull)
  organizationTypeId String?
  notes              String?
  // Optional finance / identity fields.
  taxId              String?
  address            String?
  financeContactName String?
  financePhone       String?
  financeEmail       String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  units              OrganizationUnit[]
  contactLinks       ContactOrganization[]
  deals              Deal[]

  @@index([organizationTypeId])
  @@index([name])
}

// A department / division / business unit. Belongs to one Organization. Every
// unit may behave differently, so it carries its own optional finance fields.
model OrganizationUnit {
  id                 String                @id @default(cuid())
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId     String
  name               String
  taxId              String?
  address            String?
  financeContactName String?
  financePhone       String?
  financeEmail       String?
  sortOrder          Int                   @default(0)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  contactLinks       ContactOrganization[]
  deals              Deal[]

  @@index([organizationId])
}

// A person. Bilingual required names (He + En). Full names are DERIVED at the
// API/UI layer, not stored (no duplicate full-name columns). A contact may
// belong to zero, one, or many organizations (via ContactOrganization), and
// optionally to a specific unit.
model Contact {
  id           String                @id @default(cuid())
  firstNameHe  String
  lastNameHe   String
  firstNameEn  String
  lastNameEn   String
  notes        String?
  // Preferred communication language with this person (he | en). Lives on the
  // Contact — the Deal/Quote never copies it; a future Quote defaults from here.
  communicationLanguage String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  phones       ContactPhone[]
  emails       ContactEmail[]
  orgLinks     ContactOrganization[]
  dealContacts DealContact[]

  @@index([lastNameHe])
  @@index([lastNameEn])
}

// One of a contact's phone numbers. Exactly one should be primary (enforced at
// the API layer for now; a partial unique index is the future-target version).
model ContactPhone {
  id        String   @id @default(cuid())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  value     String
  label     String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
}

// One of a contact's email addresses. One primary (API-enforced for now).
model ContactEmail {
  id        String   @id @default(cuid())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  value     String
  label     String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
}

// Contact ↔ Organization membership, with an optional specific Unit. A contact
// may be linked to many organizations; within an organization it may be tied to
// a unit or to the organization as a whole (organizationUnitId null).
model ContactOrganization {
  id                 String            @id @default(cuid())
  contact            Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId          String
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId     String
  organizationUnit   OrganizationUnit? @relation(fields: [organizationUnitId], references: [id], onDelete: SetNull)
  organizationUnitId String?
  role               String?
  isPrimary          Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([contactId, organizationId, organizationUnitId])
  @@index([organizationId])
  @@index([organizationUnitId])
  @@index([contactId])
}

// ============================================================================
// Deal module (commercial core) — Deal, DealStage, DealContact
// ============================================================================
//
// The Deal is the COMMERCIAL object (the Pipedrive "deal"). It OWNS the
// commercial agreement: agreed value, discount, payment terms, pipeline stage
// and outcome status. Operational execution (tours, scheduling) and finance
// documents (quotes, payments, invoices) are SEPARATE and not built yet — a
// Deal will link to Tours via a Booking and to iCount via finance later.
//
// Money: integer MINOR units (agorot) as BigInt + a currency code. Never float.
// The server serializes BigInt → number in JSON (see index.js json replacer)
// and converts incoming numbers → BigInt on write.
//
// `key`/slug pattern and live conventions (cuid ids, string status) mirror the
// rest of the live schema; the Phase-0 UUID/enum target stays for the governed
// migration.

// Pipeline stage (configuration, ordered). Managed in CRM settings, drag-
// orderable. A stage is a pipeline POSITION; won/lost is the Deal's `status`,
// kept separate (Pipedrive model) so a closed deal still remembers its stage.
model DealStage {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  labelEn   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  // Platform inline-edit Display Mode for deals in this stage: 'read' (Read First —
  // fields shown as read-only, click to edit) or 'edit' (Edit First — fields open
  // as inputs for data entry). Configurable in CRM settings; not hardcoded.
  displayMode String @default("read")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deals     Deal[]

  @@index([sortOrder])
}

// The commercial agreement. Owns money + stage + outcome. Optional links to an
// Organization, a specific Unit, and the deal's Subtype (subtype belongs to the
// Deal, not the Organization).
model Deal {
  id                    String               @id @default(cuid())
  title                 String
  organization          Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationId        String?
  organizationUnit      OrganizationUnit?    @relation(fields: [organizationUnitId], references: [id], onDelete: SetNull)
  organizationUnitId    String?
  organizationSubtype   OrganizationSubtype? @relation(fields: [organizationSubtypeId], references: [id], onDelete: SetNull)
  organizationSubtypeId String?
  // Activity classification (group | private | business). Applies to the Deal
  // now and later to the actual tour/activity. Nullable for backward compat;
  // no Postgres enum (project convention is string enums validated at the API).
  activityType          String?
  // THIS deal's organization type — its quote/business classification. It is kept
  // independently of any linked Organization: the Organization's own type is only a
  // DEFAULT, and a specific deal may OVERRIDE it for the quote context. Precedence
  // (composer + pricing): deal.organizationType first, org's type as the fallback.
  // Not a duplicate source of truth — org = default classification, deal = override.
  organizationType      OrganizationType?    @relation(fields: [organizationTypeId], references: [id], onDelete: SetNull)
  organizationTypeId    String?
  // Operational tour selection: the chosen Product and its Product×Location
  // variant ("city"). Pricing reads these as engine context; nullable so a deal
  // can exist before a product is picked. SetNull so catalog edits never delete deals.
  product               Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId             String?
  productVariant        ProductVariant?      @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  productVariantId      String?
  // Operational tour CITY. Usually the location of the chosen productVariant, but
  // may be ANY CRM location (manual override) even if no variant exists for it —
  // pricing still resolves via productVariantId (null → manual). SetNull on delete.
  location              Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationId            String?
  dealStage             DealStage            @relation(fields: [dealStageId], references: [id])
  dealStageId           String
  status                String               @default("open") // 'open' | 'won' | 'lost'
  valueMinor            BigInt               @default(0)
  currency              String               @default("ILS")
  discountMinor         BigInt?
  // Payment — FK to the CRM catalog (the source of truth). The Deal stores only
  // IDs, never names, so renaming a term/method in settings never affects deals.
  paymentTerm           PaymentTerm?         @relation(fields: [paymentTermId], references: [id], onDelete: SetNull)
  paymentTermId         String?
  paymentMethodRef      PaymentMethod?       @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  paymentMethodId       String?
  // DEPRECATED back-compat only — no longer written. Superseded by the FK fields.
  paymentTerms          String?
  // Lead source. `dealSource` references the admin-managed DealSource catalog
  // (the structured "how did this lead arrive"). `source` is kept as the OPTIONAL
  // free-text detail (specific campaign / referrer name / conference, …).
  dealSource            DealSource?          @relation(fields: [dealSourceId], references: [id], onDelete: SetNull)
  dealSourceId          String?
  source                String?
  ownerUserId           String? // loose actor id (no User model yet)
  expectedCloseDate     DateTime?
  wonAt                 DateTime?
  lostAt                DateTime?
  // LOST outcome — structured. lostReasonRef points at the shared LostReason
  // catalog (required at the API layer when status='lost'); lostNotes is free
  // optional detail. `lostReason` (legacy free text) is RETAINED only as a
  // backward-compat display fallback for old rows — new saves leave it null and
  // write the structured fields instead.
  lostReasonRef         LostReason?          @relation(fields: [lostReasonId], references: [id], onDelete: SetNull)
  lostReasonId          String?
  lostNotes             String?
  lostReason            String?
  notes                 String?
  // "פרטי הסיור" — working fields for the sales-call workspace. Simple Deal
  // scalars (single source of truth = the Deal). String enums validated at the
  // API (no Postgres enum). Product/City/pricing remain in the deferred quote
  // slice and are NOT stored here yet.
  tourDate              String? // "YYYY-MM-DD"
  tourTime              String? // "HH:MM"
  participants          Int?
  // DEPRECATED back-compat only — no longer written. Superseded by paymentMethodId.
  paymentMethod         String?
  communicationLanguage String? // he | en
  tourLanguage          String? // he | en | es | fr | ru
  customerInfo          String? // internal working note (lightweight rich HTML)
  // "פתיח אישי למייל" — commercial (Quote) card. Temporary home on Deal until the
  // QuoteVersion model lands (then it becomes per-quote, this stays as a default).
  quoteEmailIntro       String?
  // Legacy flag from the inline base-price input (now unused — per-line override
  // lives on QuoteLine.overridden). Kept to avoid a destructive drop; removable later.
  basePriceOverridden   Boolean              @default(false)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  contacts              DealContact[]
  quoteVersions         QuoteVersion[]
  quoteDocuments        QuoteDocument[]
  paymentLinks          DealPaymentLink[]

  @@index([organizationId])
  @@index([organizationUnitId])
  @@index([organizationSubtypeId])
  @@index([organizationTypeId])
  @@index([productId])
  @@index([productVariantId])
  @@index([locationId])
  @@index([paymentTermId])
  @@index([paymentMethodId])
  @@index([dealStageId])
  @@index([lostReasonId])
  @@index([dealSourceId])
  @@index([status])
}

// Deal ↔ Contact link. A deal often has MULTIPLE contacts with different roles
// and per-deal communication preferences. `roles` is a structured set (array,
// not a single flattened role): coordinator | payer | decisionMaker |
// participant | invoiceContact | other. Preferences are operational routing,
// later gated by Contact-level consent.
model DealContact {
  id                        String   @id @default(cuid())
  deal                      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId                    String
  contact                   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId                 String
  roles                     String[] @default([])
  isPrimary                 Boolean  @default(false)
  receiveConfirmations      Boolean  @default(false)
  receiveOperationalUpdates Boolean  @default(false)
  receivePaymentLinks       Boolean  @default(false)
  receiveQuotes             Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@unique([dealId, contactId])
  @@index([contactId])
  @@index([dealId])
}

// ── iCount payment links ("תשלום באייקאונט" — Deal payment module) ───────────
// GOS stays the operational source of truth; iCount is ONLY the payment/invoice
// provider. One row per generate action: regenerating marks the previous row
// 'superseded' and inserts a new one (full history kept; the latest 'created'
// row is THE deal's personal link). Customer/amount fields are FROZEN copies of
// what was actually sent to iCount — the deal may change later, the link won't.
// Generating a link NEVER changes deal status or marks anything paid; payment
// confirmation is a future slice (webhook processing / manual admin action).
model DealPaymentLink {
  id                  String   @id @default(cuid())
  deal                Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId              String
  provider            String   @default("icount")
  status              String   @default("created") // 'created' | 'superseded'
  paymentLinkUrl      String
  paypageId           String? // iCount paypage template the sale was generated from
  amountMinor         BigInt // agorot, VAT-inclusive gross (Deal.valueMinor at generation time)
  currency            String   @default("ILS")
  productName         String
  customerName        String?
  customerPhone       String?
  customerEmail       String?
  createdBy           String? // loose AdminUser id (same convention as Deal.ownerUserId)
  rawProviderResponse Json? // iCount generate_sale response, for audit/debug
  createdAt           DateTime @default(now())

  @@index([dealId])
}

// Raw iCount IPN payloads — audit log ONLY in this slice. The receiver persists
// the payload and returns 200; it changes NO deal/payment state (processing is
// a future slice). Logged now so links generated today aren't deaf: every
// payment made through them is captured and can be processed retroactively.
model IcountWebhookLog {
  id        String   @id @default(cuid())
  dealId    String? // from the ipn_url query param, when present (not an FK — log survives deal deletion)
  payload   Json
  createdAt DateTime @default(now())

  @@index([dealId])
}

// ── Quote model (canonical line storage) ────────────────────────────────────
// QuoteVersion + QuoteLine are the SINGLE source of truth for a deal's pricing
// lines. For now each deal has exactly ONE working version (isWorking=true) that
// the Price Builder edits — no quote workflow yet (no alternatives, sending,
// acceptance, or WON). Those are added later as fields/rows ON TOP of this model,
// with no storage migration. Deal.valueMinor caches the working version's gross.
model QuoteVersion {
  id         String      @id @default(cuid())
  deal       Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId     String
  status     String      @default("draft") // draft | produced | accepted | rejected (only 'draft' used now)
  isWorking  Boolean     @default(true) // the version the builder/panel edits (exactly one per deal for now)
  isSelected Boolean     @default(false) // the accepted/main version (unused until the quote workflow)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  lines      QuoteLine[]
  quoteDocuments QuoteDocument[]

  @@index([dealId])
}

// One priced line on a quote version. Same shape the Price Builder UI uses; refs
// are typed (productVariant for the product line, addon for add-on lines) with
// SetNull so catalog edits never break a saved quote line (the price is frozen on
// the line). kind: product | addon | discount | credit | manual.
model QuoteLine {
  id               String          @id @default(cuid())
  quoteVersion     QuoteVersion    @relation(fields: [quoteVersionId], references: [id], onDelete: Cascade)
  quoteVersionId   String
  kind             String
  label            String          @default("")
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  productVariantId String?
  addon            Addon?          @relation(fields: [addonId], references: [id], onDelete: SetNull)
  addonId          String?
  quantity         Int             @default(1)
  unitPriceMinor   BigInt          @default(0)
  vatMode          String          @default("inherit") // inherit | included | excluded | exempt
  vatRate          Int?
  active           Boolean         @default(true)
  // `note` is USER content only — never a system identifier. Safe to edit, clear or
  // translate without affecting what the line represents (see structured identity).
  note             String?
  overridden       Boolean         @default(false)
  // Structured identity for Group Ticket Builder lines. A group-ticket line is ONE
  // ticket type sold from ONE Pricing Card, so it persists exactly that — never
  // encoded into `note`. All additive/nullable; regular builder lines leave them
  // null. `sourceKind` names the originating workspace (e.g. 'group_ticket').
  // `sourceCardGroupId` is a LOOSE key (cardGroupId is shared across a card's
  // sibling PriceRules; there is no CardGroup table — same loose-key approach as
  // FlowAnswer.stepId / ownerUserId). `ticketType` is a real FK (SetNull) so a
  // catalog delete degrades gracefully like productVariant/addon.
  sourceKind        String?
  sourceCardGroupId String?
  ticketType        TicketType?     @relation(fields: [ticketTypeId], references: [id], onDelete: SetNull)
  ticketTypeId      String?
  sortOrder        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([quoteVersionId])
  @@index([productVariantId])
  @@index([addonId])
  @@index([ticketTypeId])
}

// ============================================================================
// Products & Pricing — Slice 1 (Catalog + Files + Payment configuration)
// ============================================================================
//
// Product = what we sell; Pricing (Slice 2) = how price is computed; Deal lines
// (Slice 3) = the frozen snapshot. This slice adds ONLY the catalog, the R2 file
// metadata, the activity-type seed, and payment config. No pricing, no add-ons,
// no Deal changes. See docs/architecture/GOS-products-pricing-architecture.md.
//
// Images live in Cloudflare R2; the DB stores only metadata + object keys/URLs
// (no DB blobs for this module). Money = BigInt minor units + currency.

// R2 object metadata. Foundation for a reusable Files service (images now;
// PDFs/documents later).
model MediaFile {
  id           String   @id @default(cuid())
  r2Key        String   @unique
  url          String
  bucket       String
  filename     String
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  kind         String   @default("image") // image | pdf | doc
  uploadedById String? // loose actor id (no FK)
  createdAt    DateTime @default(now())

  variantMeetingImages  ProductVariant[]      @relation("VariantMeetingImage")
  variantGalleryLinks   ProductVariantImage[]
  locationMeetingImages Location[]            @relation("LocationMeetingImage")
  quoteDocumentRenders  QuoteDocumentRender[]
  // Shared Content Library items that use this file as their image (by reference;
  // no byte copy — a MediaFile is already reusable-by-reference).
  sharedContentImages   SharedContent[]
  // Tour Content (Phase 1a) — hero images on stations and re-hosted block assets
  // reference R2/MediaFile (never DB binary). By reference; no byte copy.
  tourStationHeroes     TourStation[]        @relation("TourStationHero")
  tourBlockAssets       TourBlockAsset[]     @relation("TourBlockAssetMedia")
}

// Simple location catalog (e.g. "תל אביב - פלורנטין"). No City/Area split.
model Location {
  id                  String           @id @default(cuid())
  nameHe              String
  nameEn              String?
  meetingPointHe      String? // rich HTML
  meetingPointEn      String? // rich HTML
  // City marketing content for quotes — owned by the Location (NOT a generic
  // QuoteSection). Bilingual rich HTML. Referenced by the City content block.
  marketingDescHe     String? // rich HTML
  marketingDescEn     String? // rich HTML
  meetingPointImage   MediaFile?       @relation("LocationMeetingImage", fields: [meetingPointImageId], references: [id], onDelete: SetNull)
  meetingPointImageId String?
  active              Boolean          @default(true)
  // Business setting: the single "home base" location. At most one row is true —
  // enforced at the API (setting one unsets the previous), matching the
  // PriceList.isDefault convention. Drives a visual-only reminder on the Deal panel
  // when a deal's city differs from home; never affects pricing or any workflow.
  isHomeLocation      Boolean          @default(false)
  sortOrder           Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  variants            ProductVariant[]
  deals               Deal[]
  // Shared Content Library items anchored to this location. Back-relation only.
  sharedContent       SharedContent[]  @relation("SharedContentAnchor")
  // Location Defaults (source of truth per type; a variant link is an override).
  // Explicit references to Shared Content — no block mutation when chosen. SetNull
  // so deleting the block clears the default. Resolution: variant link → these →
  // legacy columns. Arrival/safety/etc. can be added the same way later.
  defaultMeetingPoint   SharedContent? @relation("LocationDefaultMeeting", fields: [defaultMeetingPointId], references: [id], onDelete: SetNull)
  defaultMeetingPointId String?
  defaultEndingPoint    SharedContent? @relation("LocationDefaultEnding", fields: [defaultEndingPointId], references: [id], onDelete: SetNull)
  defaultEndingPointId  String?

  @@index([sortOrder])
  @@index([defaultMeetingPointId])
  @@index([defaultEndingPointId])
}

// What we sell. Bilingual name + rich marketing descriptions. No pricing, no
// location/operational data (those live on the variant).
model Product {
  id              String           @id @default(cuid())
  nameHe          String
  nameEn          String?
  marketingDescHe String? // rich HTML
  marketingDescEn String? // rich HTML
  active          Boolean          @default(true)
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  variants        ProductVariant[]
  priceRules      PriceRule[]
  deals           Deal[]

  @@index([sortOrder])
}

// Product × Location. Owns all product-location detail incl. operational data,
// guide-pay defaults, and per-format availability.
model ProductVariant {
  id                    String                @id @default(cuid())
  product               Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId             String
  location              Location              @relation(fields: [locationId], references: [id])
  locationId            String
  marketingDescHe       String? // rich HTML
  marketingDescEn       String?
  guideDescHe           String? // internal, rich HTML
  guideDescEn           String? // internal, rich HTML
  durationHours         Float? // numeric source of truth; display derived
  meetingPointHe        String? // rich HTML (long instructions, links, lists)
  meetingPointEn        String? // rich HTML
  endingPointHe         String? // rich HTML
  endingPointEn         String? // rich HTML
  // "אז מה בתוכנית?" — variant-specific programme copy for the quote section of the
  // same name. Title lives in the Quote Template (one source of truth); this is the
  // CONTENT only. NOT Shared Content / Location Defaults / meeting-ending points.
  programHe             String? // rich HTML
  programEn             String? // rich HTML
  meetingPointImage     MediaFile?            @relation("VariantMeetingImage", fields: [meetingPointImageId], references: [id], onDelete: SetNull)
  meetingPointImageId   String?
  baseGuidePaymentMinor BigInt                @default(0)
  travelPaymentMinor    BigInt?
  currency              String                @default("ILS")
  // Per-format availability (defaults all true; admin disables manually).
  availablePublic       Boolean               @default(true)
  availablePrivate      Boolean               @default(true)
  availableBusiness     Boolean               @default(true)
  active                Boolean               @default(true)
  sortOrder             Int                   @default(0)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  galleryImages         ProductVariantImage[]
  priceRules            PriceRule[]
  deals                 Deal[]
  quoteLines            QuoteLine[]
  // Explicit references to Shared Content Library items (meeting point, ending
  // point, …). Content is never copied onto the variant — see ProductVariantSharedContent.
  sharedContentLinks    ProductVariantSharedContent[]

  @@unique([productId, locationId])
  @@index([productId])
  @@index([locationId])
}

// Ordered quote gallery for a variant (explicit per-owner join, not polymorphic).
model ProductVariantImage {
  id               String         @id @default(cuid())
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  productVariantId String
  mediaFile        MediaFile      @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  mediaFileId      String
  sortOrder        Int            @default(0)

  @@index([productVariantId])
  @@index([mediaFileId])
}

// Seeded: public | private | business. priceModel drives Slice-2 pricing.
model ActivityType {
  id              String           @id @default(cuid())
  key             String           @unique // public | private | business
  nameHe          String
  nameEn          String?
  priceModel      String // per_head | tiered
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  priceRules      PriceRule[]
  pricingSegments PricingSegment[]
}

// Payment terms ⇄ methods with bidirectional optional defaults. The auto-fill on
// the Deal happens in Slice 3.
model PaymentTerm {
  id                     String             @id @default(cuid())
  nameHe                 String
  nameEn                 String?
  defaultPaymentMethod   PaymentMethod?     @relation("TermDefaultMethod", fields: [defaultPaymentMethodId], references: [id], onDelete: SetNull)
  defaultPaymentMethodId String?
  active                 Boolean            @default(true)
  sortOrder              Int                @default(0)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  methodsDefaultingHere  PaymentMethod[]    @relation("MethodDefaultTerm")
  // Org types that point here as their default payment term (back-relation only).
  orgTypeDefaults        OrganizationType[] @relation("OrgTypeDefaultPaymentTerm")
  deals                  Deal[]

  @@index([sortOrder])
}

model PaymentMethod {
  id                   String             @id @default(cuid())
  nameHe               String
  nameEn               String?
  defaultPaymentTerm   PaymentTerm?       @relation("MethodDefaultTerm", fields: [defaultPaymentTermId], references: [id], onDelete: SetNull)
  defaultPaymentTermId String?
  active               Boolean            @default(true)
  sortOrder            Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  termsDefaultingHere  PaymentTerm[]      @relation("TermDefaultMethod")
  // Org types that point here as their override payment method (back-relation).
  orgTypeDefaults      OrganizationType[] @relation("OrgTypeDefaultPaymentMethod")
  deals                Deal[]

  @@index([sortOrder])
}

// ── Products & Pricing — Slice 2: Pricing Engine + Add-ons ──────────────────
// Not yet wired to Deals. No DealLineItem, no Quotes. This is the catalog +
// resolution foundation only.

// A named set of pricing rules. One row is the system default (isDefault), used
// when no organization type/subtype points at a specific list. VAT defaults here
// are inherited by rules that don't override them.
model PriceList {
  id             String   @id @default(cuid())
  nameHe         String
  nameEn         String?
  defaultVatMode String   @default("included") // included | excluded
  defaultVatRate Int      @default(18)
  currency       String   @default("ILS")
  isDefault      Boolean  @default(false) // exactly one system-default list
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rules                 PriceRule[]
  addonPriceRules       AddonPriceRule[]
  orgTypesDefaulting    OrganizationType[]    @relation("OrgTypeDefaultPriceList")
  orgSubtypesDefaulting OrganizationSubtype[] @relation("OrgSubtypeDefaultPriceList")

  @@index([sortOrder])
}

// A single pricing rule inside a PriceList. The four scope fields are optional;
// NULL means "wildcard / matches anything". A rule matches a context when every
// non-null scope equals the context. priceModel selects which price fields are
// used and must match the context ActivityType's priceModel.
model PriceRule {
  id          String    @id @default(cuid())
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  priceListId String

  // Scopes — null = wildcard. Cascade-delete the rule when a scoped target is
  // removed, so a specific rule never silently becomes a broader wildcard.
  product               Product?             @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId             String?
  productVariant        ProductVariant?      @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  productVariantId      String?
  activityType          ActivityType?        @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  activityTypeId        String?
  organizationSubtype   OrganizationSubtype? @relation(fields: [organizationSubtypeId], references: [id], onDelete: Cascade)
  organizationSubtypeId String?

  // Authoring layer (Slice A) — NOT used by resolution. `pricingSegment` tags the
  // rule with the business tab it was created under; `cardGroupId` ties sibling
  // rules (one per chosen location) into a single editable UI "card". The engine
  // ignores both and keeps resolving per scope as before.
  pricingSegment   PricingSegment? @relation(fields: [pricingSegmentId], references: [id], onDelete: SetNull)
  pricingSegmentId String?
  cardGroupId      String?

  priceModel String // per_head | tiered | tiered_group | fixed | ticket_types

  // per_head model fields. (per_person UX reuses per_head with a single price.)
  adultPriceMinor BigInt?
  childPriceMinor BigInt?

  // tiered (single-tier, legacy) model fields.
  basePriceMinor                BigInt?
  baseParticipants              Int?
  // Also the "every participant above the last tier" rate for tiered_group.
  perAdditionalParticipantMinor BigInt?

  // fixed model field — one flat total per group.
  fixedPriceMinor BigInt?

  // tiered_group model — ordered ladder of (uptoParticipants → totalPriceMinor).
  tiers PriceTier[]

  // ticket_types model — a price per TicketType (e.g. מבוגר/ילד). The set of
  // ticket categories is the editable TicketType catalog, NOT hard-coded.
  ticketPrices PriceRuleTicketPrice[]

  // Card-level add-ons. The Addon catalog owns the label/active/order; the price,
  // VAT mode and auto-apply rule live HERE (per card). Duplicated across a card's
  // sibling rules like tiers/ticketPrices; replace-synced on save.
  addons PriceRuleAddon[]

  // VAT override — null inherits the PriceList defaults.
  vatMode String? // included | excluded
  vatRate Int?

  priority      Int      @default(0)
  // Business capability (card-level, business-driven): when true, this Pricing
  // Card is offered in the Group Ticket Builder. The Pricing Card itself is the
  // SOLE authority for what appears there — the builder NEVER filters by product,
  // city, activity type, segment, or any hardcoded rule. Default false so existing
  // cards stay out until the owner opts a card in. Duplicated across a card's
  // sibling rules (one per location) like cardSortOrder; replace-synced on save.
  availableForGroupTickets Boolean @default(false)
  // Business-facing display order of the CARD within its tab. Shared across all
  // sibling rules of one cardGroupId. NOT used by the engine — resolution uses
  // `priority`; this only orders how cards render on the Pricing board.
  cardSortOrder Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([priceListId])
  @@index([productId])
  @@index([productVariantId])
  @@index([activityTypeId])
  @@index([organizationSubtypeId])
  @@index([pricingSegmentId])
  @@index([cardGroupId])
}

// A single tier row in a tiered_group price rule (model 1: base + tiers + extra
// participant). `uptoParticipants` is the inclusive upper bound for this tier;
// `totalPriceMinor` is the TOTAL group price for a group up to that size (not
// per-person). Tiers are read in `sortOrder` order; beyond the largest tier the
// rule's `perAdditionalParticipantMinor` applies per extra participant. No
// hard-coded count of tiers — the owner adds as many rows as needed.
model PriceTier {
  id               String    @id @default(cuid())
  priceRule        PriceRule @relation(fields: [priceRuleId], references: [id], onDelete: Cascade)
  priceRuleId      String
  uptoParticipants Int
  totalPriceMinor  BigInt
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([priceRuleId])
}

// Editable catalog of ticket categories (e.g. מבוגר / ילד). The SOURCE OF TRUTH
// for ticket-based pricing — adult/child are seed examples, never hard-coded in
// code. A type referenced by any price rule is deactivated, not hard-deleted
// (enforced in the route).
model TicketType {
  id            String                 @id @default(cuid())
  nameHe        String
  nameEn        String?
  descriptionHe String?
  descriptionEn String?
  active        Boolean                @default(true)
  sortOrder     Int                    @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  priceEntries  PriceRuleTicketPrice[]
  // Group-ticket quote lines that froze this ticket type as their structured
  // identity. SetNull on delete (see QuoteLine.ticketType).
  quoteLines    QuoteLine[]

  @@index([sortOrder])
}

// Per-rule price for one ticket type (ticket_types model). One row per
// (priceRule, ticketType). Cascade-deletes with either side.
model PriceRuleTicketPrice {
  id           String     @id @default(cuid())
  priceRule    PriceRule  @relation(fields: [priceRuleId], references: [id], onDelete: Cascade)
  priceRuleId  String
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  ticketTypeId String
  priceMinor   BigInt
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([priceRuleId, ticketTypeId])
  @@index([priceRuleId])
  @@index([ticketTypeId])
}

// The 6 business-facing pricing tabs (קבוצתי / פרטי / עסקי / בית ספר / סוכנים /
// מפיקים). This is an AUTHORING catalog only — it buckets pricing cards into
// tabs. The optional bindings let the owner map a tab to an ActivityType and/or
// OrganizationSubtype from the admin UI (NO hard-coded org mappings). Resolution
// does not read this table; the bindings are applied to a rule's own scope
// fields at authoring time, so the engine is unchanged.
model PricingSegment {
  id                    String               @id @default(cuid())
  key                   String               @unique
  nameHe                String
  nameEn                String?
  sortOrder             Int                  @default(0)
  active                Boolean              @default(true)
  // Owner-set resolution bindings — null until configured in the admin UI.
  activityType          ActivityType?        @relation(fields: [activityTypeId], references: [id], onDelete: SetNull)
  activityTypeId        String?
  organizationSubtype   OrganizationSubtype? @relation(fields: [organizationSubtypeId], references: [id], onDelete: SetNull)
  organizationSubtypeId String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  priceRules            PriceRule[]

  @@index([sortOrder])
}

// A sellable extra that is NOT a Product (e.g. transport, insurance, materials).
// Carries its own default price + VAT behaviour. Per-price-list overrides live
// in AddonPriceRule.
model Addon {
  id                String   @id @default(cuid())
  nameHe            String
  nameEn            String?
  // Stable key for SYSTEM add-ons (e.g. 'sabbath_holiday'). Null for ordinary
  // owner-created add-ons. Logic identifies the system surcharge by THIS key,
  // never by name. This Addon row is the global default (price/VAT/active) every
  // card inherits unless it stores a PriceRuleAddon override.
  systemKey         String?  @unique
  defaultPriceMinor BigInt   @default(0)
  currency          String   @default("ILS")
  // null = "כמו כרטיס התמחור" — the add-on inherits the Pricing Card's VAT.
  // included | excluded | exempt = the add-on fixes its own VAT (overrides card).
  vatMode           String?
  vatRate           Int      @default(18)
  defaultQuantity   Int      @default(1)
  active            Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  priceRules  AddonPriceRule[]
  cardEntries PriceRuleAddon[]
  quoteLines  QuoteLine[]

  @@index([sortOrder])
}

// Per-card add-on configuration (one row per card×addon, duplicated across the
// card's sibling rules). The Addon catalog is the label/active/order source of
// truth; price + VAT + auto-apply are owned HERE, per card.
//   vatMode null  → inherit the card's VAT; else included | excluded | exempt
//   autoApply     → 'manual' (toggled in Deal/Quote) | 'weekdays'
//   autoApplyWeekdays → 0=Sun … 6=Sat (matches JS getDay); e.g. [6] = Saturday.
//                       No weekday is hard-coded — this is owner-entered data.
model PriceRuleAddon {
  id                String    @id @default(cuid())
  priceRule         PriceRule @relation(fields: [priceRuleId], references: [id], onDelete: Cascade)
  priceRuleId       String
  addon             Addon     @relation(fields: [addonId], references: [id], onDelete: Cascade)
  addonId           String
  enabled           Boolean   @default(true)
  // Nullable = INHERIT for that field. For the system add-on, null price/VAT
  // inherits the Addon catalog default (resolved server-side); a concrete value
  // is a per-card override. (For ordinary add-ons the UI always sets a price.)
  priceMinor        BigInt?
  vatMode           String? // null = inherit (catalog default for system; card VAT otherwise)
  vatRate           Int?
  autoApply         String    @default("manual") // manual | weekdays
  autoApplyWeekdays Int[]     @default([])
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([priceRuleId, addonId])
  @@index([priceRuleId])
  @@index([addonId])
}

// Per-price-list override of an Addon's price / VAT. priceListId NULL = a global
// override applied regardless of the resolved price list.
model AddonPriceRule {
  id          String     @id @default(cuid())
  addon       Addon      @relation(fields: [addonId], references: [id], onDelete: Cascade)
  addonId     String
  priceList   PriceList? @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  priceListId String?
  priceMinor  BigInt     @default(0)
  currency    String     @default("ILS")
  vatMode     String     @default("included") // included | excluded
  vatRate     Int        @default(18)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([addonId])
  @@index([priceListId])
}

// ── CRM Settings — Lost Reasons & Quote Content (catalog only) ───────────────
// Reusable, admin-managed reference data. NOT yet wired to Deals or to quote
// generation — this is content/config the future deal-loss and quote-template
// flows will read. Additive only.

// Reasons a Deal was lost. Reusable picklist. Not wired to Deal.status yet.
model LostReason {
  id        String   @id @default(cuid())
  nameHe    String
  nameEn    String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Deals that selected this reason. SetNull on delete (see Deal.lostReasonRef)
  // so removing a catalog reason nulls the link rather than deleting deals.
  deals     Deal[]

  @@index([sortOrder])
}

// How a lead/deal arrived (admin-managed picklist used by the Create Deal flow):
// e.g. Facebook, website, referral, conference. Drag-orderable; `active` retires
// a source without deleting history. SetNull on delete (see Deal.dealSource).
model DealSource {
  id        String   @id @default(cuid())
  label     String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deals     Deal[]

  @@index([sortOrder])
}

// ── Timeline (reusable activity feed) ──────────────────────────────────────
// A single polymorphic "spine": every timeline item (V1 = note; later activity /
// email / whatsapp / file / system event) is one TimelineEntry, scoped to ANY
// subject via (subjectType, subjectId). There is intentionally NO database FK on
// the subject — integrity is enforced at the API (the same loose-key approach as
// FlowAnswer.stepId / ownerUserId). This is exactly what lets the SAME timeline
// component+feed attach to Deals, Contacts, Organizations and future entities
// with zero schema change. Light/variable payload lives in `data` (JSON); a heavy
// future type can get a 1:1 companion table keyed by id without touching the feed.
model TimelineEntry {
  id           String            @id @default(cuid())
  subjectType  String // 'deal' | 'contact' | 'organization' | future…
  subjectId    String
  kind         String            @default("note") // 'note' (V1) | future kinds
  body         String? // rich HTML for notes; optional text on other kinds
  data         Json? // kind-specific light payload, e.g. { origin: 'inquiry' }
  isPinned     Boolean           @default(false)
  pinSortOrder Int               @default(0) // manual FOCUS order, scoped to the subject
  isSystem     Boolean           @default(false) // system events: not user-editable
  // Origin — every entry has an explicit, NON-anonymous source:
  //   'user'       → a logged-in admin (createdBy + createdByName set)
  //   'api'        → an external integration  (actorLabel, e.g. "API: ייבוא לידים")
  //   'automation' → a CRM rule / flow        (actorLabel, e.g. "אוטומציה: WhatsApp")
  //   'system'     → GOS itself               (actorLabel, e.g. "דיל נוצר")
  //   'import'     → a migration / import      (actorLabel, e.g. "ייבוא נתונים")
  // For non-'user' origins createdBy/createdByName are null and actorLabel names
  // the source. The API forbids an entry with neither a user nor an actorLabel.
  actorType    String            @default("user")
  actorLabel   String? // human-readable source label for non-'user' origins
  // Author attribution for the 'user' origin. createdBy = AdminUser.id (canonical
  // identity, ready for a future User model); createdByName = a username snapshot
  // so the feed renders the author with no join and survives rename/deactivation.
  createdBy    String?
  createdByName String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  editedAt     DateTime? // set on CONTENT edits (distinct from pin/reorder)
  deletedAt    DateTime? // soft delete (keeps history honest)
  comments     TimelineComment[]

  @@index([subjectType, subjectId, createdAt])
  @@index([subjectType, subjectId, isPinned, pinSortOrder])
}

// A comment ALWAYS belongs to exactly one entry (real FK + cascade — not
// polymorphic). Rendered white, nested under the (yellow) note. Future reactions
// can hang off this model.
model TimelineComment {
  id        String        @id @default(cuid())
  entry     TimelineEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId   String
  body      String
  // Same explicit-origin model as TimelineEntry (a comment may also come from a
  // user, an automation, etc.). Never anonymous.
  actorType String        @default("user")
  actorLabel String?
  createdBy String? // AdminUser.id (canonical identity)
  createdByName String? // author username snapshot (see TimelineEntry)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  @@index([entryId, createdAt])
}

// Reusable fixed content sections for future quote templates. Rich HTML, He/En.
// Stored as content only — quote generation is not built yet.
model QuoteSection {
  id         String   @id @default(cuid())
  titleHe    String
  titleEn    String?
  richTextHe String? // HTML from the shared RichEditor
  richTextEn String? // HTML from the shared RichEditor
  // Library classification so content is structured, not an unstructured pile.
  // Validated at the API (no Postgres enum): faq | cancellation |
  // participant_policy | why_us | marketing | terms | custom.
  category   String?
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sortOrder])
}

// ============================================================================
// Quote Layout Template — the GLOBAL default quote composition (control center)
// ============================================================================
//
// Single-row settings record (enforced by the unique `singleton`). Holds the
// default quote LAYOUT as one flexible JSON blob so the screen can grow (hero,
// sections order/visibility, technical-detail fields today; colors, fonts, PDF
// later) without a migration per option. This is the DEFAULT SEED only: a
// per-quote QuoteDocument.compositionDraft still overrides section order/hidden
// for that one quote. Code (DEFAULT_QUOTE_BLOCKS) is the final fallback when no
// row exists, so behaviour is unchanged until an admin saves here.
model QuoteTemplate {
  id        String   @id @default(cuid())
  singleton String   @unique @default("global") // exactly one row
  layout    Json? // { hero, sections:[{key,hidden}], technical:{fields:[{key,visible}]} }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// שעות שבת וחג — Sabbath & Holiday hours (source of truth for time detection)
// ============================================================================
//
// Defines WHEN a date/time counts as שבת / חג / ערב חג. Two shapes feeding one
// detector: recurring weekly windows + dated holiday rows (imported or manual,
// with a review/approval workflow). NOT wired to pricing yet — a later slice
// switches PriceRuleAddon.autoApply='sabbath_holiday' to read these rules. No
// holiday date is hard-coded in code; weekly times are owner-entered, holidays
// come from the import source (Hebcal). Money/Deals/Quotes untouched.

// Recurring weekly window, e.g. "כניסת שבת — שישי מ-15:00", "שבת — כל היום".
// Times are minutes-from-midnight (Israel local wall-clock); null start = open,
// null end = until end of day. allDay covers the whole day.
model SabbathWeeklyRule {
  id          String   @id @default(cuid())
  nameHe      String
  nameEn      String?
  dayOfWeek   Int // 0=Sun … 6=Sat (matches JS getDay)
  allDay      Boolean  @default(false)
  startMinute Int? // 0..1439
  endMinute   Int?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

// One reviewable holiday row per date. `source`/`externalId` dedupe imports;
// `manuallyEdited` + `status='approved'` LOCK a row from being overwritten by a
// re-import (only the sourceName/sourceDate mirror refreshes, for change
// detection). Only `approved` + `active` rows will later affect pricing.
model HolidayRule {
  id             String    @id @default(cuid())
  nameHe         String
  nameEn         String?
  date           DateTime  @db.Date
  allDay         Boolean   @default(true)
  startMinute    Int? // ערב חג start (minutes from midnight, Israel local)
  endMinute      Int?
  type           String    @default("chag") // 'erev_chag' | 'chag' | 'other'
  source         String    @default("imported") // 'imported' | 'manual'
  status         String    @default("pending") // 'pending' | 'approved' | 'ignored'
  active         Boolean   @default(true)
  externalId     String? // stable key from the import source (dedupe)
  manuallyEdited Boolean   @default(false)
  reviewedAt     DateTime?
  reviewedBy     String? // loose actor id (no User model yet)
  sourceName     String? // raw source mirror — to flag "source changed since approval"
  sourceDate     DateTime? @db.Date
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([source, externalId])
  @@index([date])
  @@index([status])
}

// Reviewed classification for a recurring holiday, applied to FUTURE imports.
// When the owner marks a holiday as חג/ערב חג (or edits its type/times), we store
// the decision keyed by the source's stable name (year-independent), so next
// year's imported instance inherits the same type + times automatically. Pending
// rows only; approved/manuallyEdited rows are never overwritten.
model HolidayClassificationRule {
  id                   String   @id @default(cuid())
  source               String // matches HolidayRule.source ('imported')
  normalizedHolidayKey String // stable, year-independent (Hebcal title)
  defaultType          String // 'chag' | 'erev_chag' | 'other'
  defaultStartMinute   Int?
  defaultEndMinute     Int?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([source, normalizedHolidayKey])
}

// ============================================================================
// Calendar Markers — operational/informational date markers (NOT pricing)
// ============================================================================
//
// A SECOND, independent dimension alongside the pricing classification
// (SabbathWeeklyRule + HolidayRule.type). Markers are display/operational only
// (Chol HaMoed, school vacations, election day, municipal events, high-demand
// periods, …) and are NEVER read by the pricing engine or the preview route.
// New marker kinds need NO schema change — they are CalendarMarkerType rows.

// The extensible catalog of marker kinds. `source='system'` marks types the
// import depends on (e.g. chol_hamoed) — not hard-deletable.
model CalendarMarkerType {
  id        String   @id @default(cuid())
  key       String   @unique
  nameHe    String
  nameEn    String?
  color     String? // hex/token for Gantt/calendar display
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  source    String   @default("manual") // 'system' | 'manual'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  markers   CalendarMarker[]

  @@index([sortOrder])
}

// A dated marker instance. A date RANGE (start..end) covers a single day
// (start==end), a multi-day Chol HaMoed, or a multi-week vacation in one row.
// `source`/`externalId` make the Hebcal import idempotent. Independent of
// HolidayRule (markers also apply to non-holiday dates).
model CalendarMarker {
  id           String             @id @default(cuid())
  markerType   CalendarMarkerType @relation(fields: [markerTypeId], references: [id], onDelete: Cascade)
  markerTypeId String
  startDate    DateTime           @db.Date
  endDate      DateTime           @db.Date
  nameHe       String? // optional label override (else the type name is used)
  note         String?
  source       String             @default("manual") // 'imported' | 'manual'
  externalId   String?
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([source, externalId])
  @@index([startDate])
  @@index([endDate])
  @@index([markerTypeId])
}

// ============================================================================
// Quote Module — Slice 1 (Quote document foundation)
// ============================================================================
//
// QuoteDocument is the DRAFT/PRODUCED composed proposal (Architecture B; see
// docs/architecture/GOS-quote-module-architecture.md §7B). It belongs to a Deal
// and references the priced QuoteVersion it renders. The renderer, public page,
// signature, PDF and delivery are NOT built in this slice — only the storage
// shape + a minimal draft service. No prices live here: the Pricing block reads
// QuoteVersion/QuoteLine (the Builder is the single source of commercial data).
//
// Three JSON shapes (renderer not built yet):
//   * compositionDraft     — ordered block list (structure: order, hidden, ad-hoc)
//   * overrideState        — per-block/field presentation overrides + overridden flags
//   * renderModelSnapshot  — frozen, fully-resolved render-model (null until produced)
// displayProductName is the ONE quote-level product-name override (display-only;
// never mutates Deal/product/Builder).
model QuoteDocument {
  id                  String                @id @default(cuid())
  deal                Deal                  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId              String
  // The priced version this document renders. Cascade with the deal; a produced
  // document's content survives independently inside renderModelSnapshot.
  quoteVersion        QuoteVersion          @relation(fields: [quoteVersionId], references: [id], onDelete: Cascade)
  quoteVersionId      String
  status              String                @default("draft") // draft | produced | accepted | rejected | expired
  // Resolved automatically from the relevant Contact.communicationLanguage at
  // create time (role priority: payer -> decisionMaker -> coordinator -> isPrimary),
  // falling back to the Deal's working language, then Hebrew. Admin-overridable.
  language            String                @default("he") // he | en
  // High-entropy capability token for the (future) public quote page. Present
  // now; no public route consumes it yet.
  publicToken         String                @unique
  expiresAt           DateTime?
  producedAt          DateTime?
  // Preview / Override layer (presentation-only; never writes back to source).
  displayProductName  String?
  // Draft + snapshot storage (renderer NOT built yet).
  compositionDraft    Json?
  overrideState       Json?
  renderModelSnapshot Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  renders             QuoteDocumentRender[]
  signature           QuoteSignature?

  @@index([dealId])
  @@index([quoteVersionId])
  @@index([status])
}

// The permanent audit record of a customer signing a proposal. Exactly ONE per
// QuoteDocument (the unique quoteDocumentId is the lock — a signed document can
// never be signed again; a change requires a NEW QuoteDocument revision). The
// signature is NEVER stored inside the quote HTML. `method` is the single source
// of truth for how it was signed (typed | uploaded | drawn) — no parallel boolean
// columns. For typed, signerName renders the signature; for uploaded/drawn,
// signatureImage holds the PNG as a data URL (public signing has no admin R2 path).
model QuoteSignature {
  id              String        @id @default(cuid())
  quoteDocument   QuoteDocument @relation(fields: [quoteDocumentId], references: [id], onDelete: Cascade)
  quoteDocumentId String        @unique
  quoteVersionId  String // the priced QuoteVersion that was signed (audit)
  method          String // typed | uploaded | drawn
  signerName      String
  signatureImage  String? // data URL (image/png) for uploaded/drawn; null for typed
  signedAt        DateTime      @default(now())
  ipAddress       String?
  userAgent       String?
  language        String        @default("he") // he | en (the language the customer saw)
  timezone        String? // IANA tz reported by the browser
  createdBy       String? // actor id if an admin signed on behalf; null for the customer
  createdAt       DateTime      @default(now())

  @@index([quoteDocumentId])
}

// Append-only record of each rendered artifact (HTML/PDF) for a QuoteDocument.
// The artifact bytes live in R2 via MediaFile (no duplicate r2Key/url here — the
// file platform is the single source for object storage). No renders are created
// in this slice; this is storage shape only.
model QuoteDocumentRender {
  id              String        @id @default(cuid())
  quoteDocument   QuoteDocument @relation(fields: [quoteDocumentId], references: [id], onDelete: Cascade)
  quoteDocumentId String
  format          String // html | pdf
  contentHash     String?
  rendererVersion String        @default("v1")
  mediaFile       MediaFile?    @relation(fields: [mediaFileId], references: [id], onDelete: SetNull)
  mediaFileId     String?
  byteSize        Int?
  generatedAt     DateTime      @default(now())

  @@index([quoteDocumentId])
  @@index([mediaFileId])
}

// ============================================================================
// Shared Content Library — platform-wide reusable content (Slice 1: foundation)
// ============================================================================
//
// SINGLE SOURCE OF TRUTH for reusable content that many consumers reference
// instead of duplicating. First consumer = Product Variants (meeting point,
// ending point, …); designed to grow into a platform-wide library (any future
// entity can reference the same rows through its own explicit join table).
//
// Design mirrors patterns ALREADY proven in this project:
//   * QuoteSection  — bilingual rich HTML classified by a validated string
//   * ContentItem   — reusable content referenced by many consumers by id
//   * ProductVariantImage — explicit per-owner join (NOT polymorphic)
//
// Locked principles (see docs/architecture/GOS-quote-content-model.md + audit):
//   * Explicit references, never copying. Editing a row updates every linked
//     DRAFT consumer automatically (they read it by reference).
//   * Produced quotes stay frozen forever via QuoteDocument.renderModelSnapshot —
//     they never re-read SharedContent.
//   * "Update only this variant" = FORK (clone into a new row + repoint the link),
//     never a silent copy. There is NO background synchronization.
//
// `type` is validated at the API against src/shared-content/sharedContentTypes.js
// (no Postgres enum — project convention). `isLocationDefault` marks the row a
// location's default for its (location, type): the fallback used when a variant
// has no explicit link (making today's silent meeting-point fallback EXPLICIT and
// reference-counted). `updatedById` is a loose actor id (no User model yet, same
// as MediaFile.uploadedById / HolidayRule.reviewedBy). `active=false` = archived.
model SharedContent {
  id                String                        @id @default(cuid())
  type              String // meeting_point | ending_point | arrival_instructions | walking_notes | safety | map | custom
  internalName      String // admin-facing library name (never shown to customers)
  description       String? // optional internal note
  bodyHe            String? // rich HTML (shared RichEditor)
  bodyEn            String? // rich HTML
  image             MediaFile?                    @relation(fields: [imageId], references: [id], onDelete: SetNull)
  imageId           String?
  mapUrl            String? // reserved (embedded map); not rendered in V1
  location          Location?                     @relation("SharedContentAnchor", fields: [locationId], references: [id], onDelete: SetNull)
  locationId        String?
  // DEPRECATED (kept, not removed): the Slice-2 location-default flag. Location
  // defaults now live as explicit FKs on Location (defaultMeetingPointId / …),
  // migrated from this flag. Resolution no longer reads it.
  isLocationDefault Boolean                       @default(false)
  active            Boolean                       @default(true)
  sortOrder         Int                           @default(0)
  updatedById       String? // loose actor id (no User model yet)
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
  variantLinks      ProductVariantSharedContent[]
  // Locations that reference this block as their default (back-relations).
  locationDefaultMeeting Location[]               @relation("LocationDefaultMeeting")
  locationDefaultEnding  Location[]               @relation("LocationDefaultEnding")

  @@index([type])
  @@index([locationId])
  @@index([locationId, type])
  @@index([active, sortOrder])
}

// Explicit reference: a Product Variant uses a Shared Content row. Mirrors
// ProductVariantImage. The block's `type` lives on SharedContent, not here, so
// resolution is "the linked row whose type = X". onDelete:
//   * productVariant → Cascade (deleting a variant drops its links)
//   * sharedContent  → Restrict (a referenced row is NOT silently deletable;
//     deletion is a deliberate library operation guarded by "where used")
// V1 enforces at-most-one link per single-cardinality type at the API layer.
model ProductVariantSharedContent {
  id               String         @id @default(cuid())
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  productVariantId String
  sharedContent    SharedContent  @relation(fields: [sharedContentId], references: [id], onDelete: Restrict)
  sharedContentId  String
  sortOrder        Int            @default(0)

  @@unique([productVariantId, sharedContentId])
  @@index([productVariantId])
  @@index([sharedContentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Tour Content domain (Phase 1a — foundation)
//
// GOS is the source of truth for internal tour content (trainees + guides).
// Shape: Tour → Station → ordered Step → (reference) → ContentBlock → BlockAsset.
// Media lives in R2 via MediaFile (never DB binary). See
// docs/architecture/phase1-tour-content-domain.md for the full design.
//
// Deferred to later phases (NOT in this migration): station-level access
// (TourStationAccess, Phase 2) and quiet block versioning
// (TourContentBlockVersion). No recruitment data is migrated here.
//
// `sourceRef` (unique) preserves the recruitment source id for the future,
// idempotent, re-runnable ETL — unused at runtime in Phase 1a.
// ─────────────────────────────────────────────────────────────────────────────

model Tour {
  id            String        @id @default(cuid())
  sourceRef     String?       @unique // "tour:<recruitment.id>" (migration only)
  titleHe       String
  descriptionHe String?
  active        Boolean       @default(true)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  stations      TourStation[]
}

model TourStation {
  id            String     @id @default(cuid())
  sourceRef     String?    @unique // "station:<recruitment.id>" (migration only)
  tour          Tour       @relation(fields: [tourId], references: [id], onDelete: Cascade)
  tourId        String
  titleHe       String
  descriptionHe String?
  // A stop is not always physical: location | artwork | printed_material | content_stop.
  kind          String     @default("location")
  // Hero image → R2/MediaFile (never DB binary). SetNull so removing a file
  // never deletes the station.
  heroImage     MediaFile? @relation("TourStationHero", fields: [heroImageId], references: [id], onDelete: SetNull)
  heroImageId   String?
  heroImageTitle String?
  // Optional future link to a GOS Location (decision 18) — unused in V1, no FK yet.
  locationId    String?
  active        Boolean    @default(true)
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  steps TourStep[]
  notes TourStationNote[]

  @@index([tourId, sortOrder])
}

// The reusable unit. Stored once; referenced by many steps across stations/tours.
// Editing it updates every placement (by reference, never copied). `shared=false`
// = one-off/inline block (hidden from the reuse picker); `shared=true` = library.
model TourContentBlock {
  id           String   @id @default(cuid())
  sourceRef    String?  @unique
  titleHe      String?
  bodyHe       String   @default("") // rich HTML; inline images via R2 public URLs
  internalNote String?
  shared       Boolean  @default(false)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assets     TourBlockAsset[]
  placements TourStep[]
}

// The ordered placement of a content block into a station. The step order IS the
// presentation order (no separate ordering table). Restrict on the block relation
// prevents deleting a block that is still placed somewhere.
model TourStep {
  id             String           @id @default(cuid())
  station        TourStation      @relation(fields: [stationId], references: [id], onDelete: Cascade)
  stationId      String
  contentBlock   TourContentBlock @relation(fields: [contentBlockId], references: [id], onDelete: Restrict)
  contentBlockId String
  sortOrder      Int              @default(0)
  isVisible      Boolean          @default(true)
  // Optional label carried from recruitment parts (build_up etc.). Not a constraint.
  roleHint       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([stationId, sortOrder])
}

// Media/attachments on a content block. Stable external links (YouTube/Vimeo/Drive)
// stay as `url`; re-hosted binaries reference R2/MediaFile via `mediaId`.
// API invariant: exactly one of `url` / `mediaId` is present.
model TourBlockAsset {
  id             String           @id @default(cuid())
  sourceRef      String?          @unique
  contentBlock   TourContentBlock @relation(fields: [contentBlockId], references: [id], onDelete: Cascade)
  contentBlockId String
  assetType      String // video | image | file | link
  language       String? // he | en | null (he-only in V1; field kept for future)
  titleHe        String
  url            String?
  media          MediaFile?       @relation("TourBlockAssetMedia", fields: [mediaId], references: [id], onDelete: SetNull)
  mediaId        String?
  sortOrder      Int              @default(0)
  active         Boolean          @default(true)

  @@index([contentBlockId, sortOrder])
}

// Admin/curator annotations on a station. Never shown to the learner.
model TourStationNote {
  id        String      @id @default(cuid())
  station   TourStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  stationId String
  contentHe String      @default("")
  sortOrder Int         @default(0)

  @@index([stationId, sortOrder])
}
