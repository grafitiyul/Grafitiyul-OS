# gos-whatsapp-bridge — one service per WhatsApp number.
# See bridge/README.md for the full Railway setup.

# Same Postgres as the GOS server (the bridge NEVER runs migrations).
DATABASE_URL="postgresql://user:password@localhost:5432/grafitiyul_os?schema=public"

# Which account this bridge process owns — THE variable that differs between
# gos-whatsapp-main ('main') and gos-whatsapp-office ('office').
WHATSAPP_ACCOUNT_ID=main
# Optional first-boot display label (admin can rename in the UI later).
WHATSAPP_ACCOUNT_LABEL=מספר ראשי

# Shared secret for GOS-server → bridge calls. Must equal the GOS server's
# WHATSAPP_BRIDGE_SECRET.
BRIDGE_INTERNAL_SECRET=change-me-long-random

# ── Media capture (Slice 2) ─────────────────────────────────────
# Same values as the GOS server's R2 config. Incoming WhatsApp media
# (images/voice/video/documents) is downloaded AT INGEST and stored
# PRIVATE in R2 under whatsapp/<accountId>/… . When unset, messages
# still mirror — media rows are marked mediaStatus='disabled'.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# WHATSAPP_MEDIA_MAX_BYTES=67108864

# Optional tunables (defaults shown)
# PORT=3000
# BRIDGE_HTTP_HOST=::
# BRIDGE_RECONNECT_MIN_MS=1000
# BRIDGE_RECONNECT_MAX_MS=60000
# BRIDGE_RECONNECT_HEALTHY_MS=300000
# LOG_LEVEL=info
