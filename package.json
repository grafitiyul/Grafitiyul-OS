{
  "name": "grafitiyul-os",
  "version": "0.1.0",
  "private": true,
  "description": "Grafitiyul OS - single-service monorepo (Express serves API + built client)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "node scripts/railway-dispatch.mjs install",
    "prepare": "git config core.hooksPath .githooks || exit 0",
    "validate:migrations": "npm run validate:migrations --prefix server",
    "build": "node scripts/railway-dispatch.mjs build",
    "start": "node scripts/railway-dispatch.mjs start",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client"
  }
}
